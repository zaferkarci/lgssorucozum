<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LGS Hazırlık - Panel</title>
<link rel="stylesheet" href="/style.css">
</head>
<body class="panel-body">

<div class="panel-topbar-yeni">
  <div class="ptopbar-sol">
    <span class="ptopbar-logo">LGS Hazırlık</span>
    <div class="ptopbar-ayrac"></div>
    <div class="ptopbar-kullanici">
      <div class="ptopbar-avatar"><%= k.kullaniciAdi.substring(0,2).toUpperCase() %></div>
      <%= k.kullaniciAdi %> · <%= k.puan %> puan
    </div>
  </div>
  <div class="ptopbar-nav">
    <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru" class="ptopbar-link <%= mod==='soru'?'aktif':'' %>">Soru Çöz</a>
    <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="ptopbar-link <%= mod==='profil'?'aktif':'' %>">Profilim</a>
    <a href="/cikis" class="ptopbar-link cikis">Çıkış Yap</a>
  </div>
</div>

<div class="panel-main">

<% if (mod === 'profil') { %>
  <%
    var dp = k.dersPuanlari || [];
    var ortTop = ortToplamHesapla(k);
    var dersRenkleri = {
      'Matematik': '#185FA5',
      'Türkçe': '#3B6D11',
      'Fen Bilimleri': '#854F0B',
      'T.C. İnkılâp Tarihi': '#993C1D',
      'İngilizce': '#534AB7',
      'Din Kültürü': '#0F6E56'
    };
    var ds = (siralamaVerisi && siralamaVerisi.dersSiralamalari) ? siralamaVerisi.dersSiralamalari : {};
  %>

  <!-- Profil banner -->
  <div class="profil-banner">
    <div class="profil-banner-sol">
      <div class="profil-avatar-yeni"><%= k.kullaniciAdi.substring(0,2).toUpperCase() %></div>
      <div>
        <div class="profil-banner-isim"><%= k.kullaniciAdi %></div>
        <div class="profil-banner-alt"><%= k.sinif %>. Sınıf<%= k.sube ? ' / ' + k.sube + ' Şubesi' : '' %> · <%= k.okul %> · <%= k.il %> / <%= k.ilce %></div>
      </div>
    </div>
    <div class="profil-banner-sag">
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= k.puan %></div>
        <div class="profil-banner-label">Toplam puan</div>
      </div>
      <div class="profil-banner-sep"></div>
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= k.soruIndex %></div>
        <div class="profil-banner-label">Çözülen soru</div>
      </div>
      <div class="profil-banner-sep"></div>
      <div class="profil-banner-stat">
        <div class="profil-banner-no">#<%= siralamaVerisi.okul %></div>
        <div class="profil-banner-label">Okul sırası</div>
      </div>
    </div>
  </div>

  <!-- Sekme bar -->
  <div class="sekme-bar">
    <button class="sekme-btn aktif" onclick="sekmeAc('genel',this)">📊 Genel</button>
    <button class="sekme-btn" onclick="sekmeAc('istatistik',this)">📈 Ders İstatistikleri</button>
    <button class="sekme-btn" onclick="sekmeAc('guvenlik',this)">🔒 Güvenlik</button>
  </div>

  <!-- GENEL SEKMESİ -->
  <div id="sekme-genel" class="sekme-icerik aktif">
    <div style="display:grid; grid-template-columns:1fr 260px; gap:14px; align-items:start;">

      <div>
        <!-- Kişisel bilgiler -->
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Kişisel bilgiler</p>
          <div class="info-row"><span class="info-label">Okul</span><span class="info-val"><%= k.okul %></span></div>
          <div class="info-row"><span class="info-label">İl / İlçe</span><span class="info-val"><%= k.il %> / <%= k.ilce %></span></div>
          <form method="POST" action="/profil/sube-guncelle" style="margin-top:12px; display:flex; gap:8px; align-items:center;">
            <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
            <label style="font-size:13px; color:#666;">Şube:</label>
            <select name="sube" class="input-sm" style="flex:1;">
              <option value="">Şube yok</option>
              <% 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(function(h) { %>
                <option value="<%= h %>" <%= k.sube===h?'selected':'' %>><%= h %> Şubesi</option>
              <% }); %>
            </select>
            <button type="submit" style="background:#1a73e8; color:white; padding:7px 14px; font-size:12px; font-weight:600; border:none; border-radius:8px; cursor:pointer;">Güncelle</button>
          </form>
        </div>

        <!-- Davet linkleri -->
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Davet linklerin</p>
          <p style="font-size:12px; color:#888; margin-bottom:12px;">Bu linklerle arkadaşlarını davet edebilirsin. Her link tek kullanımlık.</p>
          <% (referansKodlari||[]).forEach(function(r) { %>
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; padding:10px 12px; background:#f8f9fa; border-radius:8px; border:1px solid #e8edf2;">
              <code style="flex:1; font-size:12px; color:<%= r.kullanildi ? '#aaa' : '#1a73e8' %>; letter-spacing:1px;"><%= baseUrl %>/kayit?ref=<%= r.kod %></code>
              <% if (r.kullanildi) { %>
                <span style="font-size:11px; color:#639922; font-weight:500; white-space:nowrap;">✅ Kullanıldı</span>
              <% } else { %>
                <button onclick="kopyala('<%= baseUrl %>/kayit?ref=<%= r.kod %>', this)" style="background:#1a73e8; color:white; border:none; border-radius:6px; padding:5px 10px; font-size:11px; cursor:pointer; white-space:nowrap;">Kopyala</button>
              <% } %>
            </div>
          <% }); %>
          <% if (!referansKodlari || referansKodlari.length === 0) { %>
            <p style="font-size:13px; color:#aaa;">Henüz referans kodun yok.</p>
          <% } %>
        </div>
      </div>

      <!-- Sağ: Sıralamalar -->
      <div>
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Genel sıralama</p>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Türkiye</span><div><div class="siralama-no-yeni">#<%= siralamaVerisi.turkiye %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.toplamKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İl</span><div><div class="siralama-no-yeni">#<%= siralamaVerisi.il %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.ilKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İlçe</span><div><div class="siralama-no-yeni">#<%= siralamaVerisi.ilce %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.ilceKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Okul</span><div><div class="siralama-no-yeni">#<%= siralamaVerisi.okul %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.okulKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Sınıf<%= k.sube ? ' ('+k.sinif+'-'+k.sube+')' : '' %></span><div><div class="siralama-no-yeni">#<%= siralamaVerisi.sinif %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.sinifKullanici %> öğrenci</div></div></div>
        </div>
        <% dp.forEach(function(d) {
          var sr = ds[d.ders] || {};
          var renk = dersRenkleri[d.ders] || '#888';
        %>
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni" style="color:<%= renk %>;"><%= d.ders %></p>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Türkiye</span><div><div class="siralama-no-yeni">#<%= sr.turkiye||'-' %></div><% if(sr.toplamKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.toplamKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İl</span><div><div class="siralama-no-yeni">#<%= sr.il||'-' %></div><% if(sr.ilKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.ilKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İlçe</span><div><div class="siralama-no-yeni">#<%= sr.ilce||'-' %></div><% if(sr.ilceKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.ilceKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Okul</span><div><div class="siralama-no-yeni">#<%= sr.okul||'-' %></div><% if(sr.okulKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.okulKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Sınıf<%= k.sube ? ' ('+k.sinif+'-'+k.sube+')' : '' %></span><div><div class="siralama-no-yeni">#<%= sr.sinif||'-' %></div><% if(sr.sinifKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.sinifKullanici %></div><% } %></div></div>
        </div>
        <% }); %>
      </div>
    </div>
  </div>

  <!-- İSTATİSTİK SEKMESİ -->
  <div id="sekme-istatistik" class="sekme-icerik">
    <% var dersler = Object.keys(dersIstatMap); %>
    <% if (dersler.length === 0) { %>
      <div class="yakin-wrap">
        <div class="yakin-ikon">📈</div>
        <div class="yakin-baslik">Henüz istatistik yok</div>
        <div class="yakin-alt">Soru çözdükçe ders ve konu bazlı istatistiklerin burada görünecek.</div>
      </div>
    <% } else { %>
      <% dersler.forEach(function(ders) {
        var di = dersIstatMap[ders];
        var toplamSoru = di.toplamDogru + di.toplamYanlis;
        var dogruOran = toplamSoru > 0 ? Math.round((di.toplamDogru / toplamSoru) * 100) : 0;
        var renk = dogruOran >= 70 ? '#2e7d32' : dogruOran >= 40 ? '#e65100' : '#c62828';
        var barRenk = dogruOran >= 70 ? '#43a047' : dogruOran >= 40 ? '#fb8c00' : '#e53935';
        var konular = Object.keys(di.konular);
      %>
      <div class="profil-kart-yeni" style="margin-bottom:14px;">
        <!-- Ders başlığı -->
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:14px;">
          <div>
            <p style="font-size:14px; font-weight:600; color:#202124; margin:0;"><%= ders %></p>
            <p style="font-size:12px; color:#888; margin:2px 0 0;"><%= toplamSoru %> soru çözüldü</p>
          </div>
          <div style="text-align:right;">
            <div style="font-size:22px; font-weight:700; color:<%= renk %>;"><%= dogruOran %>%</div>
            <div style="font-size:11px; color:#aaa;">doğru oranı</div>
          </div>
        </div>

        <!-- Genel progress bar -->
        <div style="height:6px; background:#f0f0f0; border-radius:3px; margin-bottom:16px; overflow:hidden;">
          <div style="height:100%; width:<%= dogruOran %>%; background:<%= barRenk %>; border-radius:3px; transition:width 0.6s;"></div>
        </div>

        <!-- Özet satırı -->
        <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; margin-bottom:16px;">
          <div style="background:#e8f5e9; border-radius:8px; padding:10px 12px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#2e7d32;"><%= di.toplamDogru %></div>
            <div style="font-size:11px; color:#66bb6a;">Doğru</div>
          </div>
          <div style="background:#ffebee; border-radius:8px; padding:10px 12px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#c62828;"><%= di.toplamYanlis %></div>
            <div style="font-size:11px; color:#ef9a9a;">Yanlış</div>
          </div>
          <div style="background:#e3f2fd; border-radius:8px; padding:10px 12px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#1565c0;"><%= toplamSoru %></div>
            <div style="font-size:11px; color:#90caf9;">Toplam</div>
          </div>
        </div>

        <!-- Konu bazlı detay -->
        <% if (konular.length > 0) { %>
        <p style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#b0bcc8; margin-bottom:10px;">Konu Detayı</p>
        <% konular.forEach(function(konu) {
          var kd = di.konular[konu];
          var kTop = kd.dogru + kd.yanlis;
          var kOran = kTop > 0 ? Math.round((kd.dogru / kTop) * 100) : 0;
          var kBarRenk = kOran >= 70 ? '#43a047' : kOran >= 40 ? '#fb8c00' : '#e53935';
          var ortSure = kTop > 0 ? Math.round(kd.toplamSure / kTop) : 0;
        %>
          <div style="padding:8px 0; border-bottom:1px solid #f5f5f5;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
              <span style="font-size:13px; color:#333; font-weight:500;"><%= konu %></span>
              <div style="display:flex; align-items:center; gap:12px;">
                <span style="font-size:11px; color:#888;">⏱ ort. <%= ortSure %>sn</span>
                <span style="font-size:12px; color:<%= kBarRenk %>; font-weight:600;"><%= kd.dogru %>/<%= kTop %></span>
                <span style="font-size:12px; font-weight:600; color:<%= kBarRenk %>; min-width:36px; text-align:right;"><%= kOran %>%</span>
              </div>
            </div>
            <div style="height:4px; background:#f0f0f0; border-radius:2px; overflow:hidden;">
              <div style="height:100%; width:<%= kOran %>%; background:<%= kBarRenk %>; border-radius:2px;"></div>
            </div>
          </div>
        <% }); %>
        <% } %>
      </div>
      <% }); %>
    <% } %>
  </div>

  <!-- GÜVENLİK SEKMESİ -->
  <div id="sekme-guvenlik" class="sekme-icerik">
    <div class="sifre-kart-profil">
      <div class="sifre-profil-header">
        <div>
          <div class="sifre-profil-baslik">Şifre Değiştir</div>
          <div class="sifre-profil-alt">Hesabınızı güvende tutmak için güçlü bir şifre seçin</div>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b0bcc8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <div class="sifre-profil-body">
        <form method="POST" action="/profil/sifre-degistir">
          <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">

          <div class="sf-field">
            <label class="sf-label">Mevcut şifre</label>
            <div class="sf-wrap">
              <input type="password" name="eskiSifre" required class="sf-input" placeholder="••••••••" id="sf-eski">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-eski',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
          </div>

          <hr class="sf-divider">

          <div class="sf-field">
            <label class="sf-label">Yeni şifre</label>
            <div class="sf-wrap">
              <input type="password" name="yeniSifre" required minlength="4" class="sf-input" placeholder="••••••••" id="sf-yeni" oninput="sfGuc(this.value);sfEsles();">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-yeni',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
            <div class="sf-guc-bars"><div class="sf-guc-bar" id="sfb1"></div><div class="sf-guc-bar" id="sfb2"></div><div class="sf-guc-bar" id="sfb3"></div><div class="sf-guc-bar" id="sfb4"></div></div>
            <div class="sf-guc-text" id="sfgt"></div>
          </div>

          <div class="sf-field">
            <label class="sf-label">Yeni şifre tekrar</label>
            <div class="sf-wrap">
              <input type="password" name="yeniSifreTekrar" required minlength="4" class="sf-input" placeholder="••••••••" id="sf-tekrar" oninput="sfEsles();">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-tekrar',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
            <div class="sf-hint" id="sf-hint"></div>
          </div>

          <button type="submit" class="sf-btn">Şifreyi Güncelle</button>
        </form>
      </div>
    </div>
  </div>

<% } else { %>

  <% if (!sorular.length) { %>
    <div style="text-align:center; margin-top:50px; padding:20px;">
      <% if (k.soruIndex > 0) { %>
        <h2 style="color:#27ae60;">🎉 Tebrikler!</h2>
        <p style="font-size:16px;">Sistemdeki tüm soruları çözdünüz.</p>
        <p style="color:#666;">Yeni soru eklenmesini bekleyiniz.</p>
        <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="btn btn-success" style="margin-top:16px;">Profilime Git</a>
      <% } else { %>
        <h2>Soru bulunamadı.</h2>
        <p>Henüz yayında soru yok. Yeni soru eklenmesini bekleyiniz.</p>
      <% } %>
    </div>

  <% } else if (!basla) { %>
    <div style="text-align:center; margin-top:100px;">
      <% if (yeniSoruSayisi > 0) { %>
      <div style="display:inline-flex; align-items:center; gap:10px; background:#e8f5e9; border:1.5px solid #a5d6a7; border-radius:12px; padding:12px 24px; margin-bottom:24px; font-size:14px; color:#2e7d32; font-weight:500;">
        <span style="font-size:20px;">🎉</span>
        <span>Sana özel <b><%= yeniSoruSayisi %> yeni soru</b> eklendi!</span>
      </div>
      <br>
      <% } %>
      <h1 style="color:#1a73e8;">Hazır mısın?</h1>
      <p>Sıradaki soruyu çözmek için butona tıkla.</p>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru&basla=true" class="btn btn-success btn-lg">SORU ÇÖZMEYE BAŞLA</a>
    </div>

  <% } else {
    const soru = sorular[0];
    const zb = zorlukBilgisi(soru);
    const harfler = ['A','B','C','D'];
  %>
    <div class="soru-kart-yeni">
      <div class="soru-etiket-bar">
        <span class="ep ep-zorluk">Zorluk: <%= zb.etiket %></span>
        <% if (soru.sinif) { %><span class="ep ep-sinif"><%= soru.sinif %>. Sınıf</span><% } %>
        <span class="ep ep-ders">Ders: <%= soru.ders %></span>
        <% if (soru.unite) { %><span class="ep ep-unite">Ünite: <%= soru.unite %></span><% } %>
        <% if (soru.konu) { %><span class="ep ep-konu">Konu: <%= soru.konu %></span><% } %>
        <div style="margin-left:auto; background:rgba(226,75,74,0.1); border:1px solid rgba(226,75,74,0.25); border-radius:20px; padding:4px 14px; font-size:12px; font-weight:600; color:#c0392b; white-space:nowrap;<% if(moderator){ %>display:none;<% } %>">⏱ <span id="timer">00:00</span> / 05:00</div>
      </div>
      <div class="soru-govde-yeni">
        <% if (soru.soruOnculu1) { %><div class="soru-oncul-yeni"><%- soru.soruOnculu1 %></div><% } %>
        <% if (soru.soruOnculu1Resmi) { %><div style="text-align:center; margin-bottom:8px;"><img src="<%= soru.soruOnculu1Resmi %>" style="max-width:100%; max-height:180px; border-radius:8px; object-fit:contain;"></div><% } %>
        <% if (soru.soruOnculu2) { %><div class="soru-oncul-yeni"><%- soru.soruOnculu2 %></div><% } %>
        <% if (soru.soruOnculu2Resmi) { %><div style="text-align:center; margin-bottom:8px;"><img src="<%= soru.soruOnculu2Resmi %>" style="max-width:100%; max-height:180px; border-radius:8px; object-fit:contain;"></div><% } %>
        <% if (soru.soruOnculu3) { %><div class="soru-oncul-yeni"><%- soru.soruOnculu3 %></div><% } %>
        <% if (soru.soruOnculu3Resmi) { %><div style="text-align:center; margin-bottom:10px;"><img src="<%= soru.soruOnculu3Resmi %>" style="max-width:100%; max-height:200px; border-radius:8px; object-fit:contain;"></div><% } %>
        <h2 class="soru-metni-yeni"><%- soru.soruMetni %></h2>
        <% if (soru.tabloBaslik && soru.tabloBaslik.length > 0) { %>
          <div style="margin-bottom:4px;">
            <table style="border-collapse:collapse; font-size:13px; table-layout:fixed;">
              <tr>
                <td style="padding:3px 0; width:48px;"></td>
                <% soru.tabloBaslik.forEach(function(b) { %>
                  <td style="padding:3px 0; width:90px; border-bottom:1px solid #999; font-weight:500; text-align:center;"><%= b %></td>
                <% }); %>
              </tr>
            </table>
          </div>
        <% } %>
        <%
          var dizilim = soru.sikDizilimi || 'dikey';
          var gridCols = dizilim === 'yatay' ? '1fr 1fr 1fr 1fr' : dizilim === 'ikili' ? '1fr 1fr' : '1fr';
          var formStyle = (dizilim === 'yatay' || dizilim === 'ikili') ? 'margin:0; display:contents;' : 'margin:0;';
        %>

        <div class="secenekler" style="display:grid; grid-template-columns:<%= gridCols %>; gap:8px; clear:both;">
          <% for (let i=0; i<4; i++) { %>
            <% if (soru.secenekler[i]) { %>
            <% var sikIcerigi = soru.secenekler[i].metin || ''; %>
            <% var tabloMu = sikIcerigi.indexOf('<table') !== -1; %>
            <% var dogruMu = soru.dogruCevapIndex === i; %>
            <% if (moderator) { %>
              <div class="secenek-btn-yeni" style="<%= dogruMu ? 'border-color:#43a047; background:#f1f8e9;' : '' %> cursor:default;">
                <% if (!tabloMu) { %><span class="sik-harf-yeni" style="<%= dogruMu ? 'background:#43a047; color:white;' : '' %>"><%= harfler[i] %></span><% } %>
                <%- sikIcerigi %>
                <% if (dogruMu) { %><span style="margin-left:auto; font-size:11px; color:#43a047; font-weight:600; white-space:nowrap;">✓ Doğru</span><% } %>
                <% if (soru.secenekler[i].gorsel) { %><br><img src="<%= soru.secenekler[i].gorsel %>" style="max-width:150px; margin-top:5px;"><% } %>
              </div>
            <% } else { %>
            <form method="POST" action="/cevap" style="<%= formStyle %>">
              <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
              <input type="hidden" name="soruId" value="<%= soru._id %>">
              <input type="hidden" name="secilenIndex" value="<%= i %>">
              <input type="hidden" name="gecenSure" id="gs<%= i %>" value="0">
              <button type="submit" onclick="document.getElementById('gs<%= i %>').value=saniye;" class="secenek-btn-yeni">
                <% if (!tabloMu) { %><span class="sik-harf-yeni"><%= harfler[i] %></span><% } %><%- sikIcerigi %>
                <% if (soru.secenekler[i].gorsel) { %><br><img src="<%= soru.secenekler[i].gorsel %>" style="max-width:150px; margin-top:5px;"><% } %>
              </button>
            </form>
            <% } %>
            <% } %>
          <% } %>
        </div>

        <% if (moderator) { %>
        <!-- Moderatör navigasyon çubuğu -->
        <div style="display:flex; align-items:center; justify-content:space-between; margin-top:16px; padding-top:14px; border-top:1px solid #f0f0f0;">
          <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru&basla=true&idx=<%= Math.max(0, modIdx-1) %>"
             class="secenek-btn-yeni"
             style="width:auto; padding:8px 20px; text-decoration:none; justify-content:center; background:<%= modIdx === 0 ? '#f5f5f5' : 'white' %>; color:<%= modIdx === 0 ? '#ccc' : '#1a73e8' %>; pointer-events:<%= modIdx === 0 ? 'none' : 'auto' %>;">
            ← Önceki
          </a>
          <span style="font-size:13px; color:#888; font-weight:500;">
            <b style="color:#1a73e8;"><%= modIdx + 1 %></b> / <%= toplamSoru %> soru
          </span>
          <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru&basla=true&idx=<%= Math.min(toplamSoru-1, modIdx+1) %>"
             class="secenek-btn-yeni"
             style="width:auto; padding:8px 20px; text-decoration:none; justify-content:center; background:<%= modIdx === toplamSoru-1 ? '#f5f5f5' : 'white' %>; color:<%= modIdx === toplamSoru-1 ? '#ccc' : '#1a73e8' %>; pointer-events:<%= modIdx === toplamSoru-1 ? 'none' : 'auto' %>;">
            Sonraki →
          </a>
        </div>
        <% } %>

        <p style="text-align:center; color:#aaa; font-size:11px; margin-top:10px; margin-bottom:4px;">Eğitim amaçlıdır. Soruların tüm hakları MEB'e aittir.</p>
      </div>
    </div>
    <script>
    var SORU_KEY = 'lgs_soru_baslangic_<%= soru._id %>';
    var simdi = Date.now();
    var kayitli = localStorage.getItem(SORU_KEY);
    var baslangic = kayitli ? parseInt(kayitli) : simdi;
    if (!kayitli) localStorage.setItem(SORU_KEY, baslangic);
    var saniye = Math.floor((simdi - baslangic) / 1000);
    if (saniye >= 300) {
        localStorage.removeItem(SORU_KEY);
        window.location.href='/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?basla=true';
    }
    var timerInterval = setInterval(function() {
        saniye = Math.floor((Date.now() - baslangic) / 1000);
        var dk = Math.floor(saniye/60); var sn = saniye%60;
        document.getElementById('timer').innerText = (dk<10?'0'+dk:dk)+':'+(sn<10?'0'+sn:sn);
        if (saniye >= 300) {
            clearInterval(timerInterval);
            localStorage.removeItem(SORU_KEY);
            window.location.href='/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?basla=true';
        }
    }, 1000);
    document.querySelectorAll('button[type=submit]').forEach(function(btn) {
        btn.addEventListener('click', function() { localStorage.removeItem(SORU_KEY); });
    });
    </script>
  <% } %>
<% } %>

<script>
function kopyala(metin, btn) {
    navigator.clipboard.writeText(metin).then(function() {
        var eski = btn.innerText;
        btn.innerText = '✓ Kopyalandı';
        btn.style.background = '#639922';
        setTimeout(function() { btn.innerText = eski; btn.style.background = '#1a73e8'; }, 2000);
    });
}
function sekmeAc(id, btn) {
    document.querySelectorAll('.sekme-icerik').forEach(function(el){ el.classList.remove('aktif'); });
    document.querySelectorAll('.sekme-btn').forEach(function(b){ b.classList.remove('aktif'); });
    document.getElementById('sekme-' + id).classList.add('aktif');
    btn.classList.add('aktif');
}
function sfToggle(id, btn) {
    var inp = document.getElementById(id);
    inp.type = inp.type === 'password' ? 'text' : 'password';
    btn.querySelector('svg').style.stroke = inp.type === 'text' ? '#1a73e8' : 'currentColor';
}
function sfGuc(v) {
    var bs = ['sfb1','sfb2','sfb3','sfb4'].map(function(x){ return document.getElementById(x); });
    var gt = document.getElementById('sfgt');
    if (!bs[0] || !gt) return;
    bs.forEach(function(b){ b.className='sf-guc-bar'; });
    if (!v) { gt.textContent=''; return; }
    var s = 0;
    if (v.length >= 6) s++;
    if (v.length >= 10) s++;
    if (/[A-Z]/.test(v) && /[0-9]/.test(v)) s++;
    if (/[^A-Za-z0-9]/.test(v)) s++;
    var cl = s<=1?'z':s<=2?'o':'g';
    var lb = {z:'Zayıf',o:'Orta',g:'Güçlü'};
    for (var i=0; i<s; i++) bs[i].classList.add(cl);
    gt.textContent = lb[cl]; gt.className = 'sf-guc-text ' + cl;
}
function sfEsles() {
    var y = document.getElementById('sf-yeni');
    var t = document.getElementById('sf-tekrar');
    var h = document.getElementById('sf-hint');
    if (!y || !t || !h) return;
    if (!t.value) { t.className='sf-input'; h.innerHTML=''; return; }
    if (y.value === t.value) {
        t.className='sf-input ok';
        h.className='sf-hint ok';
        h.innerHTML='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg> Şifreler uyuşuyor';
    } else {
        t.className='sf-input err';
        h.className='sf-hint err';
        h.innerHTML='<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg> Şifreler uyuşmuyor';
    }
}
</script>

</div>
</body>
</html>
