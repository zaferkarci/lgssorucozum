<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LGS Hazırlık - Panel</title>
<link rel="stylesheet" href="/style.css">
</head>
<body class="panel-body">

<div class="topbar">
  <span class="topbar-logo">LGS Hazırlık</span>
  <div class="topbar-nav">
    <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru" class="nav-link <%= mod==='soru'?'active':'' %>">Soru Çöz</a>
    <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="nav-link <%= mod==='profil'?'active':'' %>">Profilim</a>
    <a href="/" class="nav-link cikis">Çıkış Yap</a>
  </div>
</div>

<div class="panel-main">

<% if (mod === 'profil') { %>
  <%
    var dp = k.dersPuanlari || [];
    var ortTop = ortToplamHesapla(k);
    var dersRenkleri = {
      'Matematik': '#378ADD',
      'Türkçe': '#639922',
      'Fen Bilimleri': '#EF9F27',
      'T.C. İnkılâp Tarihi': '#D85A30',
      'İngilizce': '#7F77DD',
      'Din Kültürü': '#1D9E75'
    };
  %>

  <!-- Kişisel Bilgiler -->
  <div class="card">
    <p class="card-title">Kişisel bilgiler</p>
    <div style="display:flex; align-items:center; gap:14px; margin-bottom:16px;">
      <div class="avatar"><%= k.kullaniciAdi.substring(0,2).toUpperCase() %></div>
      <div>
        <p style="font-size:16px; font-weight:500; margin:0;"><%= k.kullaniciAdi %></p>
        <p style="font-size:13px; color:#666; margin:0;"><%= k.sinif %>. Sınıf öğrencisi</p>
      </div>
    </div>
    <div class="info-row"><span class="info-label">Okul</span><span class="info-val"><%= k.okul %></span></div>
    <div class="info-row"><span class="info-label">İl / İlçe</span><span class="info-val"><%= k.il %> / <%= k.ilce %></span></div>
  </div>

  <!-- Genel Özet -->
  <div class="card">
    <p class="card-title">Genel özet</p>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:10px; margin-bottom:10px;">
      <div class="stat"><div class="stat-label">Toplam puan</div><div class="stat-val"><%= k.puan %></div></div>
      <div class="stat"><div class="stat-label">Çözülen soru</div><div class="stat-val"><%= k.soruIndex %></div></div>
      <div class="stat">
        <div class="stat-label">Ders ort. toplamı</div>
        <div class="stat-val" style="font-size:18px;"><%= ortTop.toFixed(4) %></div>
      </div>
    </div>
    <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:10px;">
      <div class="stat" style="text-align:center;">
        <div class="stat-label">Türkiye sır.</div>
        <div class="stat-val" style="font-size:18px;">#<%= siralamaVerisi.turkiye %></div>
        <div style="font-size:11px; color:#888;">/ <%= siralamaVerisi.toplamKullanici %></div>
      </div>
      <div class="stat" style="text-align:center;">
        <div class="stat-label">İl sır.</div>
        <div class="stat-val" style="font-size:18px;">#<%= siralamaVerisi.il %></div>
        <div style="font-size:11px; color:#888;">/ <%= siralamaVerisi.ilKullanici %></div>
      </div>
      <div class="stat" style="text-align:center;">
        <div class="stat-label">İlçe sır.</div>
        <div class="stat-val" style="font-size:18px;">#<%= siralamaVerisi.ilce %></div>
        <div style="font-size:11px; color:#888;">/ <%= siralamaVerisi.ilceKullanici %></div>
      </div>
      <div class="stat" style="text-align:center;">
        <div class="stat-label">Okul sır.</div>
        <div class="stat-val" style="font-size:18px;">#<%= siralamaVerisi.okul %></div>
        <div style="font-size:11px; color:#888;">/ <%= siralamaVerisi.okulKullanici %></div>
      </div>
    </div>
  </div>

  <!-- Ders Bazlı Performans -->
  <% if (dp.length > 0) { %>
  <div class="card">
    <p class="card-title">Ders bazlı performans</p>
    <% dp.forEach(function(d) {
      var dersOrt = d.soruSayisi > 0 ? (d.toplamPuan / d.soruSayisi).toFixed(4) : '0.0000';
      var dersOrtSure = d.soruSayisi > 0 ? Math.round(d.toplamSure / d.soruSayisi) : 0;
      var renk = dersRenkleri[d.ders] || '#888';
      var maxOrt = 100;
      var barYuzde = Math.min((parseFloat(dersOrt) / maxOrt) * 100, 100).toFixed(0);

      // Bu derse göre sıralama (tüm kullanıcılardan hesaplamak zor, şimdilik gösterme)
    %>
    <div style="border:0.5px solid #eee; border-radius:8px; padding:14px; margin-bottom:10px;">
      <div style="font-size:15px; font-weight:500; color:#202124; margin-bottom:12px;"><%= d.ders %></div>
      <div style="display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:8px; margin-bottom:8px;">
        <div class="stat" style="text-align:center; padding:8px;">
          <div class="stat-label">Toplam puan</div>
          <div style="font-size:14px; font-weight:500;"><%= d.toplamPuan %></div>
        </div>
        <div class="stat" style="text-align:center; padding:8px;">
          <div class="stat-label">Çözülen soru</div>
          <div style="font-size:14px; font-weight:500;"><%= d.soruSayisi %></div>
        </div>
        <div class="stat" style="text-align:center; padding:8px;">
          <div class="stat-label">Ort. süre</div>
          <div style="font-size:14px; font-weight:500;"><%= dersOrtSure %> sn</div>
        </div>
        <div class="stat" style="text-align:center; padding:8px;">
          <div class="stat-label">Ort. puan</div>
          <div style="font-size:14px; font-weight:500;"><%= dersOrt %></div>
        </div>
      </div>
      <div style="background:#f0f2f5; border-radius:4px; height:3px; overflow:hidden;">
        <div style="height:100%; border-radius:4px; width:<%= barYuzde %>%; background:<%= renk %>;"></div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>

<% } else { %>

  <% if (!sorular.length) { %>
    <div style="text-align:center; margin-top:50px;">
      <h2>Soru bulunamadı.</h2>
      <p>Lütfen admin panelinden soru ekleyiniz.</p>
    </div>

  <% } else if (!basla) { %>
    <div style="text-align:center; margin-top:100px;">
      <h1 style="color:#1a73e8;">Hazır mısın?</h1>
      <p>Sıradaki soruyu çözmek için butona tıkla.</p>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru&basla=true" class="btn btn-success btn-lg">SORU ÇÖZMEYE BAŞLA</a>
    </div>

  <% } else {
    const soru = sorular[k.soruIndex % sorular.length];
    const zb = zorlukBilgisi(soru);
    const harfler = ['A','B','C','D'];
  %>
    <div class="soru-kart" style="display:flex; flex-direction:column; height:calc(100vh - 80px); overflow:hidden; max-width:800px; margin:auto; padding:12px 16px;">
      <div class="soru-header" style="flex-shrink:0; padding:8px 12px; margin-bottom:6px;">
        <span><b><%= k.kullaniciAdi %></b> | Puan: <%= k.puan %></span>
        <div style="color:red; font-weight:bold;">⏱️ <span id="timer">00:00</span> / 05:00 dk</div>
      </div>
      <div class="soru-etiketler" style="flex-shrink:0; margin-bottom:6px;">
        <span class="etiket" style="background:<%= zb.renk %>">Zorluk: <%= zb.etiket %></span>
        <% if (soru.sinif) { %><span class="etiket" style="background:#607d8b"><%= soru.sinif %>. Sınıf</span><% } %>
        <span class="etiket" style="background:#3498db">Ders: <%= soru.ders %></span>
        <% if (soru.unite) { %><span class="etiket" style="background:#16a085">Ünite: <%= soru.unite %></span><% } %>
        <% if (soru.konu) { %><span class="etiket" style="background:#8e44ad">Konu: <%= soru.konu %></span><% } %>
      </div>
      <div style="flex:1; overflow-y:auto; min-height:0;">
        <% if (soru.soruOnculu1Resmi) { %><div style="text-align:center; margin-bottom:8px;"><img src="<%= soru.soruOnculu1Resmi %>" style="max-width:100%; max-height:180px; border-radius:8px; object-fit:contain;"></div><% } %>
        <% if (soru.soruOnculu2) { %><div class="soru-onculu" style="margin-bottom:8px; font-size:13px;"><%- soru.soruOnculu2 %></div><% } %>
        <% if (soru.soruOnculu2Resmi) { %><div style="text-align:center; margin-bottom:8px;"><img src="<%= soru.soruOnculu2Resmi %>" style="max-width:100%; max-height:180px; border-radius:8px; object-fit:contain;"></div><% } %>
        <% if (soru.soruResmi) { %><div style="text-align:center; margin-bottom:10px;"><img src="<%= soru.soruResmi %>" style="max-width:100%; max-height:200px; border-radius:8px; object-fit:contain;"></div><% } %>
        <h2 class="soru-metni" style="font-size:17px; margin-bottom:12px;"><%- soru.soruMetni %></h2>
        <%
          var dizilim = soru.sikDizilimi || 'dikey';
          var gridCols = dizilim === 'yatay' ? '1fr 1fr 1fr 1fr' : dizilim === 'ikili' ? '1fr 1fr' : '1fr';
          var formStyle = (dizilim === 'yatay' || dizilim === 'ikili') ? 'margin:0; display:contents;' : 'margin:0;';
        %>
        <% if (soru.soruOnculu1) { %><div class="soru-onculu" style="margin-bottom:4px; font-size:13px;"><%- soru.soruOnculu1 %></div><% } %>

        <div class="secenekler" style="display:grid; grid-template-columns:<%= gridCols %>; gap:8px;">
          <% for (let i=0; i<4; i++) { %>
            <% if (soru.secenekler[i]) { %>
            <% var sikIcerigi = soru.secenekler[i].metin || ''; %>
            <% var tabloMu = sikIcerigi.indexOf('<table') !== -1; %>
            <form method="POST" action="/cevap" style="<%= formStyle %>">
              <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
              <input type="hidden" name="soruId" value="<%= soru._id %>">
              <input type="hidden" name="secilenIndex" value="<%= i %>">
              <input type="hidden" name="gecenSure" id="gs<%= i %>" value="0">
              <button type="submit" onclick="document.getElementById('gs<%= i %>').value=saniye;" class="secenek-btn" style="padding:10px 14px; font-size:13px; width:100%; text-align:left;">
                <% if (!tabloMu) { %><b><%= harfler[i] %>)</b> <% } %><%- sikIcerigi %>
                <% if (soru.secenekler[i].gorsel) { %><br><img src="<%= soru.secenekler[i].gorsel %>" style="max-width:150px; margin-top:5px;"><% } %>
              </button>
            </form>
            <% } %>
          <% } %>
        </div>
        <p style="text-align:center; color:#aaa; font-size:11px; margin-top:10px; margin-bottom:4px;">Eğitim amaçlıdır. Soruların tüm hakları MEB'e aittir.</p>
      </div>
    </div>
    <script>
    var SORU_KEY = 'lgs_soru_baslangic_<%= soru._id %>';
    var simdi = Date.now();
    var kayitli = localStorage.getItem(SORU_KEY);
    var baslangic = kayitli ? parseInt(kayitli) : simdi;
    if (!kayitli) localStorage.setItem(SORU_KEY, baslangic);
    var saniye = Math.floor((simdi - baslangic) / 1000);
    if (saniye >= 300) {
        localStorage.removeItem(SORU_KEY);
        window.location.href='/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?basla=true';
    }
    var timerInterval = setInterval(function() {
        saniye = Math.floor((Date.now() - baslangic) / 1000);
        var dk = Math.floor(saniye/60); var sn = saniye%60;
        document.getElementById('timer').innerText = (dk<10?'0'+dk:dk)+':'+(sn<10?'0'+sn:sn);
        if (saniye >= 300) {
            clearInterval(timerInterval);
            localStorage.removeItem(SORU_KEY);
            window.location.href='/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?basla=true';
        }
    }, 1000);
    document.querySelectorAll('button[type=submit]').forEach(function(btn) {
        btn.addEventListener('click', function() { localStorage.removeItem(SORU_KEY); });
    });
    </script>
  <% } %>
<% } %>

</div>
</body>
</html>
