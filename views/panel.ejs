        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#b0bcc8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <div class="sifre-profil-body">
        <form method="POST" action="/profil/sifre-degistir">
          <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">

          <div class="sf-field">
            <label class="sf-label">Mevcut şifre</label>
            <div class="sf-wrap">
              <input type="password" name="eskiSifre" required class="sf-input" placeholder="••••••••" id="sf-eski">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-eski',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
          </div>

          <hr class="sf-divider">

          <div class="sf-field">
            <label class="sf-label">Yeni şifre</label>
            <div class="sf-wrap">
              <input type="password" name="yeniSifre" required minlength="4" class="sf-input" placeholder="••••••••" id="sf-yeni" oninput="sfGuc(this.value);sfEsles();">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-yeni',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
            <div class="sf-guc-bars"><div class="sf-guc-bar" id="sfb1"></div><div class="sf-guc-bar" id="sfb2"></div><div class="sf-guc-bar" id="sfb3"></div><div class="sf-guc-bar" id="sfb4"></div></div>
            <div class="sf-guc-text" id="sfgt"></div>
          </div>

          <div class="sf-field">
            <label class="sf-label">Yeni şifre tekrar</label>
            <div class="sf-wrap">
              <input type="password" name="yeniSifreTekrar" required minlength="4" class="sf-input" placeholder="••••••••" id="sf-tekrar" oninput="sfEsles();">
              <button type="button" class="sf-eye" onclick="sfToggle('sf-tekrar',this)"><svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg></button>
            </div>
            <div class="sf-hint" id="sf-hint"></div>
          </div>

          <button type="submit" class="sf-btn">Şifreyi Güncelle</button>
        </form>
      </div>
    </div>
  </div>
  <% } %>

<% } else if (mod === 'haberler') { %>

  <!-- Haberler & Duyurular (öğretmen ve öğrenci için ortak) -->
  <div class="profil-kart-yeni" style="max-width:900px; margin:0 auto;">
    <p class="profil-kart-baslik-yeni">📰 Haberler & Duyurular</p>
    <p style="font-size:13px; color:#888; margin-bottom:14px;">Yeni özellikler, güncellemeler ve önemli bilgiler.</p>
    <div id="haberlerListesi" style="display:flex; flex-direction:column; gap:12px;">Yükleniyor…</div>
  </div>
  <script>
  (function(){
    var liste = document.getElementById('haberlerListesi');
    if (!liste) return;
    fetch('/api/haberler')
      .then(function(r){ return r.json(); })
      .then(function(d) {
        if (!d.ok) { liste.innerHTML = '<div style="color:#c0392b;">Haberler yüklenemedi.</div>'; return; }
        if (!d.haberler || d.haberler.length === 0) {
          liste.innerHTML = '<div style="background:#f8f9fa; border-radius:10px; padding:20px; text-align:center; color:#888;">Henüz haber yok.</div>';
          return;
        }
        var html = '';
        d.haberler.forEach(function(h) {
          var tarih = new Date(h.yayinTarih);
          var simdi = new Date();
          var farkGun = Math.floor((simdi - tarih) / 86400000);
          var yeniMi = farkGun < 7;
          var tarihStr = tarih.toLocaleString('tr-TR', { day:'numeric', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Europe/Istanbul' });
          html += '<div style="background:white; border:1px solid #e8eaed; border-radius:10px; padding:16px 18px;">';
          html += '<div style="display:flex; align-items:center; gap:8px; margin-bottom:8px; flex-wrap:wrap;">';
          html += '<h3 style="margin:0; font-size:16px; color:#1a73e8; font-weight:600;">' + escapeHTML(h.baslik) + '</h3>';
          if (yeniMi) html += '<span style="background:#e8f5e9; color:#2e7d32; font-size:10px; font-weight:700; padding:2px 8px; border-radius:10px;">🆕 YENİ</span>';
          html += '<span style="font-size:11px; color:#888; margin-left:auto;">' + tarihStr + '</span>';
          html += '</div>';
          html += '<div style="font-size:13px; color:#444; white-space:pre-wrap; line-height:1.6;">' + escapeHTML(h.icerik) + '</div>';
          html += '</div>';
        });
        liste.innerHTML = html;
      })
      .catch(function(){ liste.innerHTML = '<div style="color:#c0392b;">Bağlantı hatası.</div>'; });
    function escapeHTML(s) {
      return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
    }
  })();
  </script>

