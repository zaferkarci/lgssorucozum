<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LGS Hazırlık - Panel</title>
<link rel="stylesheet" href="/style.css">
<style>
.sqrt{display:inline-flex;align-items:center;}
.sqrt-sembol{font-size:1.15em;line-height:1;margin-right:1px;}
.sqrt-icerik{border-top:1.5px solid currentColor;padding:0 2px;display:inline-block;}
.math-sup{vertical-align:super;font-size:.75em;}
.math-sub{vertical-align:sub;font-size:.75em;}
.math-frac{display:inline-flex;flex-direction:column;align-items:center;vertical-align:middle;font-size:.85em;line-height:1.2;}
.math-frac-ust{border-bottom:1px solid currentColor;padding:0 2px;}
.math-frac-alt{padding:0 2px;}
</style>
<script>
window.MathJaxReady = false;
MathJax = {
  tex: { inlineMath: [['$','$']], displayMath: [['$$','$$']] },
  options: { skipHtmlTags: ['script','style','textarea','pre'] },
  startup: {
    ready() {
      // v4.1.32: MathJax otomatik typeset etmeden ÖNCE çift backslash'ları temizle.
      // Eski sorulardaki "\\le" gibi yanlış kaçışlamaları "\le" yapar.
      try {
        if (typeof ciftBackslashNormalize === 'function') {
          ciftBackslashNormalize(document.body);
        }
      } catch(e) {}
      MathJax.startup.defaultReady();
      window.MathJaxReady = true;
    }
  }
};
</script>
<script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
<script>
// v4.1.32: Bazı eski sorularda metin "\\le" gibi çift backslash ile kaydedilmiş
// (JSON kaçışlama hatası). LaTeX'te "\\" yeni satır demektir; "\le" değil.
// Bu yüzden hem MathJax hem CSS fallback render etmeden önce el içindeki
// $...$ matematik bloklarındaki çift backslash'ları tek backslash'a indirgiyoruz.
// Sadece $...$ içinde çalışır, normal metne dokunmaz.
function ciftBackslashNormalize(el) {
  if (!el) return;
  var walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
  var nodes = [];
  while (walker.nextNode()) nodes.push(walker.currentNode);
  nodes.forEach(function(node) {
    var t = node.textContent;
    if (t.indexOf('\\\\') === -1) return;          // Hiç çift backslash yoksa atla
    if (!t.match(/\$[^$]*\\\\[^$]*\$/)) return;    // Çift backslash $...$ içinde değilse atla
    var yeni = t.replace(/\$([^$]+)\$/g, function(tam, ic) {
      return '$' + ic.replace(/\\\\/g, '\\') + '$';
    });
    if (yeni !== t) node.textContent = yeni;
  });
}

function mathRenderSonra(el) {
  if (!el) return;
  ciftBackslashNormalize(el);
  if (window.MathJaxReady && window.MathJax && MathJax.typesetPromise) {
    MathJax.typesetPromise([el]).catch(function(){});
  } else if (window.MathJax && MathJax.typesetPromise) {
    setTimeout(function(){ MathJax.typesetPromise([el]).catch(function(){}); }, 500);
  } else {
    mathRenderCSS(el);
  }
}
function mathRenderCSS(el) {
  if (!el) return;
  ciftBackslashNormalize(el);
  var walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
  var nodes = [];
  while (walker.nextNode()) nodes.push(walker.currentNode);
  nodes.forEach(function(node) {
    if (!node.textContent.match(/\$[^$]+\$/)) return;
    var parent = node.parentNode;
    if (!parent || parent.tagName==='SCRIPT' || parent.tagName==='STYLE') return;
    var html = node.textContent.replace(/\$([^$]+)\$/g, function(_,l){ return latexToHtml(l); });
    if (html !== node.textContent) {
      var span = document.createElement('span');
      span.innerHTML = html;
      parent.replaceChild(span, node);
    }
  });
}
function latexToHtml(s) {
  s = s.trim();
  s = s.replace(/\\sqrt\{([^}]+)\}/g,'<span class="sqrt"><span class="sqrt-sembol">\u221a</span><span class="sqrt-icerik">$1</span></span>');
  s = s.replace(/\^{([^}]+)}/g,'<span class="math-sup">$1</span>');
  s = s.replace(/\^(\S)/g,'<span class="math-sup">$1</span>');
  s = s.replace(/_{([^}]+)}/g,'<span class="math-sub">$1</span>');
  s = s.replace(/\\frac\{([^}]+)\}\{([^}]+)\}/g,'<span class="math-frac"><span class="math-frac-ust">$1</span><span class="math-frac-alt">$2</span></span>');
  // v4.1.31: Önce çok karakterli komutları çevir (sıralama önemli — uzun olanlar önce).
  s = s.replace(/\\leq/g,'\u2264').replace(/\\geq/g,'\u2265').replace(/\\neq/g,'\u2260').replace(/\\approx/g,'\u2248').replace(/\\infty/g,'\u221e');
  // Kısa formlar (\le, \ge) — aynı sembollerin alternatif yazımı; yukarıdaki uzun
  // formlar zaten çevrildiği için artakalanları yakalar. \\le\b / \\ge\b kelime
  // sınırı ile yazıldı ki \\leq / \\geq parçaları yanlışlıkla yakalanmasın.
  s = s.replace(/\\le\b/g,'\u2264').replace(/\\ge\b/g,'\u2265');
  // Diğer yaygın komutlar
  s = s.replace(/\\cdot/g,'\u00b7').replace(/\\times/g,'\xd7').replace(/\\div/g,'\xf7').replace(/\\pm/g,'\xb1');
  s = s.replace(/\\to\b/g,'\u2192').replace(/\\rightarrow/g,'\u2192').replace(/\\leftarrow/g,'\u2190').replace(/\\Rightarrow/g,'\u21d2');
  s = s.replace(/\\circ/g,'\u00b0').replace(/\\degree/g,'\u00b0');
  s = s.replace(/\\ldots/g,'\u2026').replace(/\\cdots/g,'\u2026').replace(/\\dots/g,'\u2026');
  s = s.replace(/\\pi/g,'\u03c0').replace(/\\alpha/g,'\u03b1').replace(/\\beta/g,'\u03b2').replace(/\\theta/g,'\u03b8');
  s = s.replace(/\\[a-zA-Z]+/g,'');
  return s;
}
document.addEventListener('DOMContentLoaded', function() {
  // v4.1.32: Sayfa yüklendiğinde tüm body'deki çift backslash'ları normalize et.
  // MathJax otomatik typeset bu temizlikten sonra çalışır.
  try { ciftBackslashNormalize(document.body); } catch(e) {}
  setTimeout(function() {
    if (!window.MathJaxReady) {
      console.log('MathJax CDN yüklenmedi, CSS fallback devreye giriyor');
      mathRenderCSS(document.body);
    }
  }, 3000);
});
</script>
</head>
<body class="panel-body">

<div class="panel-topbar-yeni">
  <div class="ptopbar-sol">
    <span class="ptopbar-logo">LGS Hazırlık</span>
    <div class="ptopbar-ayrac"></div>
    <div class="ptopbar-kullanici">
      <div class="ptopbar-avatar"><%= k.kullaniciAdi.substring(0,2).toUpperCase() %></div>
      <%= k.kullaniciAdi %><% if (k.rol === 'ogretmen') { %> · 👩‍🏫 Öğretmen<% } else { %> · <%= k.puan %> puan<% } %>
    </div>
  </div>
  <div class="ptopbar-nav">
    <% if (k.rol === 'ogretmen') { %>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru" class="ptopbar-link <%= mod==='soru'?'aktif':'' %>">Örnek Soru</a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=davetEdilenler" class="ptopbar-link <%= mod==='davetEdilenler'?'aktif':'' %>">Davet Ettiklerim</a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=takip" class="ptopbar-link <%= mod==='takip'?'aktif':'' %>" id="takipNavLink" style="position:relative;">Takip<span id="bekleyenBadge" style="display:none; position:absolute; top:6px; right:4px; background:#e24b4a; color:white; font-size:9px; font-weight:700; padding:1px 5px; border-radius:8px; line-height:1.4;">0</span></a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=haberler" class="ptopbar-link <%= mod==='haberler'?'aktif':'' %>">📰 Haberler</a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="ptopbar-link <%= mod==='profil'?'aktif':'' %>">Profilim</a>
    <% } else { %>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=soru" class="ptopbar-link <%= mod==='soru'?'aktif':'' %>">Soru Çöz</a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=takip" class="ptopbar-link <%= mod==='takip'?'aktif':'' %>" id="takipNavLink" style="position:relative;">Takip<span id="bekleyenBadge" style="display:none; position:absolute; top:6px; right:4px; background:#e24b4a; color:white; font-size:9px; font-weight:700; padding:1px 5px; border-radius:8px; line-height:1.4;">0</span></a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=haberler" class="ptopbar-link <%= mod==='haberler'?'aktif':'' %>">📰 Haberler</a>
      <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="ptopbar-link <%= mod==='profil'?'aktif':'' %>">Profilim</a>
    <% } %>
    <% if (adminGorunum) { %>
      <span class="ptopbar-link" style="background:#fff3cd; color:#856404; font-weight:600; cursor:default;">👁️ ADMİN GÖRÜNÜMÜ</span>
      <a href="/admin?mod=kullanicilar" class="ptopbar-link cikis">← Admin Panele Dön</a>
    <% } else { %>
      <a href="/cikis" class="ptopbar-link cikis">Çıkış Yap</a>
    <% } %>
  </div>
</div>

<div class="panel-main">

<% if (mod === 'profil') { %>
  <%
    var dp = k.dersPuanlari || [];
    var ortTop = ortToplamHesapla(k);
    var dersRenkleri = {
      'Matematik': '#185FA5',
      'Türkçe': '#3B6D11',
      'Fen Bilimleri': '#854F0B',
      'T.C. İnkılâp Tarihi': '#993C1D',
      'İngilizce': '#534AB7',
      'Din Kültürü': '#0F6E56'
    };
    var ds = (siralamaVerisi && siralamaVerisi.dersSiralamalari) ? siralamaVerisi.dersSiralamalari : {};
  %>

  <!-- v4.1.26: Eksik bilgi uyarısı (sadece öğrenci için, profilde) -->
  <% if (eksikBilgiVar && k.rol !== 'ogretmen') { %>
    <div style="max-width:1100px; margin:0 auto 18px auto; padding:14px 20px; background:#fff8e1; border:1.5px solid #ffd54f; border-radius:12px; display:flex; align-items:center; gap:12px;">
      <span style="font-size:24px;">⚠️</span>
      <div style="flex:1; font-size:14px; color:#f57c00; line-height:1.5;">
        <b>Profilini tamamla.</b>
        <span style="color:#795548;">İl, ilçe ve okul bilgilerini girmeden okul/il sıralamasında gözükmezsin. Aşağıdaki "Konum bilgileri" kartından doldurabilirsin.</span>
      </div>
    </div>
  <% } %>

  <!-- Profil banner -->
  <div class="profil-banner">
    <div class="profil-banner-sol">
      <div class="profil-avatar-yeni"><%= k.kullaniciAdi.substring(0,2).toUpperCase() %></div>
      <div>
        <div class="profil-banner-isim"><%= k.kullaniciAdi %><% if (k.rol === 'ogretmen') { %> <span style="font-size:12px; background:#f3e5f5; color:#6a1b9a; padding:3px 10px; border-radius:10px; margin-left:8px; font-weight:600;">👩‍🏫 Öğretmen</span><% } %></div>
        <div class="profil-banner-alt"><% if (k.rol !== 'ogretmen') { %><%= k.sinif %>. Sınıf<%= k.sube ? ' / ' + k.sube + ' Şubesi' : '' %> · <% } %><%= k.okul %> · <%= k.il %> / <%= k.ilce %></div>
      </div>
    </div>
    <% if (k.rol !== 'ogretmen') { %>
    <div class="profil-banner-sag">
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= k.puan %></div>
        <div class="profil-banner-label">Toplam puan</div>
      </div>
      <div class="profil-banner-sep"></div>
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= k.soruIndex %></div>
        <div class="profil-banner-label">Çözülen soru</div>
      </div>
      <div class="profil-banner-sep"></div>
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= siralamaVerisi.okul > 0 ? '#'+siralamaVerisi.okul : '—' %></div>
        <div class="profil-banner-label">Okul sırası</div>
      </div>
    </div>
    <% } else { %>
    <div class="profil-banner-sag">
      <div class="profil-banner-stat">
        <div class="profil-banner-no"><%= davetEdilenler ? davetEdilenler.length : 0 %></div>
        <div class="profil-banner-label">Davet ettiğin</div>
      </div>
    </div>
    <% } %>
  </div>

  <!-- Sekme bar -->
  <div class="sekme-bar">
    <button class="sekme-btn aktif" onclick="sekmeAc('genel',this)">📊 Genel</button>
    <% if (k.rol !== 'ogretmen') { %>
    <button class="sekme-btn" onclick="sekmeAc('istatistik',this)">📈 Ders İstatistikleri</button>
    <% } %>
    <% if (!adminGorunum) { %>
    <button class="sekme-btn" onclick="sekmeAc('guvenlik',this)">🔒 Güvenlik</button>
    <% } %>
  </div>

  <!-- GENEL SEKMESİ -->
  <div id="sekme-genel" class="sekme-icerik aktif">
    <div style="display:grid; grid-template-columns:1fr 260px; gap:14px; align-items:start;">

      <div>
        <!-- Kişisel bilgiler -->
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Kişisel bilgiler</p>
          <div class="info-row"><span class="info-label"><%= k.rol === 'ogretmen' ? 'Görev yaptığınız okul' : 'Okul' %></span><span class="info-val"><%= k.okul %></span></div>
          <div class="info-row"><span class="info-label">İl / İlçe</span><span class="info-val"><%= k.il %> / <%= k.ilce %></span></div>
          <% if (k.rol === 'ogretmen') { %>
            <!-- Öğretmen: sınıf/şube yok, ek alan da yok -->
          <% } else if (adminGorunum) { %>
            <div class="info-row"><span class="info-label">Sınıf / Şube</span><span class="info-val"><%= k.sinif %><%= k.sube ? '/' + k.sube : '' %></span></div>
          <% } else { %>
          <form method="POST" action="/profil/sube-guncelle" style="margin-top:12px; display:flex; gap:8px; align-items:center;">
            <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
            <label style="font-size:13px; color:#666;">Şube:</label>
            <select name="sube" class="input-sm" style="flex:1;">
              <option value="">Şube yok</option>
              <% 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').forEach(function(h) { %>
                <option value="<%= h %>" <%= k.sube===h?'selected':'' %>><%= h %> Şubesi</option>
              <% }); %>
            </select>
            <button type="submit" style="background:#1a73e8; color:white; padding:7px 14px; font-size:12px; font-weight:600; border:none; border-radius:8px; cursor:pointer;">Güncelle</button>
          </form>
          <% } %>
        </div>

        <!-- v4.1.26: Konum bilgileri (öğrenci için — opsiyonel olduğundan sonradan tamamlama) -->
        <% if (k.rol !== 'ogretmen' && !adminGorunum) { %>
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Konum bilgileri <% if (eksikBilgiVar) { %><span style="color:#f57c00; font-size:12px; font-weight:600; margin-left:8px;">⚠️ Eksik</span><% } %></p>
          <p style="font-size:12px; color:#888; margin-bottom:12px; line-height:1.5;">Bu bilgiler okul/il/ilçe sıralamasında görünmen için gereklidir. Yarın 05:10'dan sonra sıralaman güncellenecektir.</p>
          <form method="POST" action="/profil/konum-guncelle">
            <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">

            <div style="margin-bottom:10px;">
              <label style="font-size:12px; color:#666; font-weight:600; display:block; margin-bottom:4px;">İl</label>
              <select name="il" id="profil-il-select" class="input-sm" style="width:100%;" onchange="profilIlDegisti()">
                <option value="">İl Seçiniz...</option>
              </select>
            </div>

            <div style="margin-bottom:10px;">
              <label style="font-size:12px; color:#666; font-weight:600; display:block; margin-bottom:4px;">İlçe</label>
              <select name="ilce" id="profil-ilce-select" class="input-sm" style="width:100%;" onchange="profilIlceDegisti()">
                <option value="">İlçe Seçiniz</option>
              </select>
            </div>

            <div style="margin-bottom:14px;">
              <label style="font-size:12px; color:#666; font-weight:600; display:block; margin-bottom:4px;">Okul</label>
              <select name="okul" id="profil-okul-select" class="input-sm" style="width:100%;">
                <option value="">Okul Seçiniz</option>
              </select>
            </div>

            <button type="submit" style="background:#1a73e8; color:white; padding:9px 16px; font-size:13px; font-weight:600; border:none; border-radius:8px; cursor:pointer; width:100%;">Bilgileri Güncelle</button>
          </form>
        </div>

        <script>
          // Profil sayfasındaki il/ilçe/okul dropdown'ları için hafif loader
          (function() {
            var mevcutIl   = <%- JSON.stringify(k.il   || '') %>;
            var mevcutIlce = <%- JSON.stringify(k.ilce || '') %>;
            var mevcutOkul = <%- JSON.stringify(k.okul || '') %>;
            var profilIlIdMap = {};

            fetch('https://api.turkiyeapi.dev/v1/provinces')
              .then(function(r) { return r.json(); })
              .then(function(data) {
                var sel = document.getElementById('profil-il-select');
                if (!sel) return;
                (data.data||[]).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(il) {
                  profilIlIdMap[il.name] = il.id;
                  var opt = document.createElement('option');
                  opt.value = il.name; opt.textContent = il.name;
                  if (il.name === mevcutIl) opt.selected = true;
                  sel.appendChild(opt);
                });
                if (mevcutIl) profilIlDegisti();
              })
              ['catch'](function() { /* sessiz */ });

            window.profilIlDegisti = function() {
              var ilAdi = document.getElementById('profil-il-select').value;
              var ilceSel = document.getElementById('profil-ilce-select');
              var okulSel = document.getElementById('profil-okul-select');
              ilceSel.innerHTML = '<option value="">İlçe Yükleniyor...</option>';
              okulSel.innerHTML = '<option value="">Okul Seçiniz</option>';
              var ilId = profilIlIdMap[ilAdi];
              if (!ilId) { ilceSel.innerHTML = '<option value="">İlçe Seçiniz</option>'; return; }
              fetch('https://api.turkiyeapi.dev/v1/provinces/' + ilId)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                  ilceSel.innerHTML = '<option value="">İlçe Seçiniz</option>';
                  ((data.data && data.data.districts) || []).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(ilce) {
                    var opt = document.createElement('option');
                    opt.value = ilce.name; opt.textContent = ilce.name;
                    if (ilce.name === mevcutIlce) opt.selected = true;
                    ilceSel.appendChild(opt);
                  });
                  if (mevcutIlce) profilIlceDegisti();
                })
                ['catch'](function() { ilceSel.innerHTML = '<option value="">İlçeler yüklenemedi</option>'; });
            };

            window.profilIlceDegisti = function() {
              var il   = document.getElementById('profil-il-select').value;
              var ilce = document.getElementById('profil-ilce-select').value;
              var okulSel = document.getElementById('profil-okul-select');
              okulSel.innerHTML = '<option value="">Okul Yükleniyor...</option>';
              if (!il || !ilce) { okulSel.innerHTML = '<option value="">Okul Seçiniz</option>'; return; }
              fetch('/api/okullar?il=' + encodeURIComponent(il) + '&ilce=' + encodeURIComponent(ilce))
                .then(function(r) { return r.json(); })
                .then(function(liste) {
                  if (!Array.isArray(liste)) liste = [];
                  liste.sort(function(a,b){ return a.localeCompare(b,'tr'); });
                  okulSel.innerHTML = '<option value="">Okul Seçiniz</option>';
                  liste.forEach(function(o) {
                    var opt = document.createElement('option');
                    opt.value = o; opt.textContent = o;
                    if (o === mevcutOkul) opt.selected = true;
                    okulSel.appendChild(opt);
                  });
                  if (mevcutOkul && !Array.from(okulSel.options).some(function(o){return o.value === mevcutOkul;})) {
                    var ek = document.createElement('option');
                    ek.value = mevcutOkul; ek.textContent = mevcutOkul + ' (mevcut)';
                    ek.selected = true;
                    okulSel.appendChild(ek);
                  }
                })
                ['catch'](function() { okulSel.innerHTML = '<option value="">Okullar yüklenemedi</option>'; });
            };
          })();
        </script>
        <% } %>

        <!-- Davet linkleri -->
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Davet linklerin</p>
          <p style="font-size:12px; color:#888; margin-bottom:12px;">Bu linklerle arkadaşlarını davet edebilirsin. Her link tek kullanımlık.</p>
          <% if (k.rol === 'ogretmen') { %>
          <div style="background:#e8f5e9; border:1px solid #a5d6a7; border-radius:8px; padding:9px 12px; margin-bottom:12px; font-size:12px; color:#2e7d32; line-height:1.5;">
            ℹ️ Linklerin <b>kullanıldıkça</b> yenisi gelir. Aktif linkin kalmazsa ertesi gün otomatik <b>2 yeni link</b> üretilir. Birikme olmaz.
          </div>
          <% } %>
          <div id="davet-link-listesi">
          <% (referansKodlari||[]).forEach(function(r) { if (r.kullanildi) return; %>
            <div class="davet-link-satir" data-kod="<%= r.kod %>" style="display:flex; align-items:center; gap:8px; margin-bottom:8px; padding:10px 12px; background:#f8f9fa; border-radius:8px; border:1px solid #e8edf2;">
              <code style="flex:1; font-size:12px; color:#1a73e8; letter-spacing:1px;"><%= baseUrl %>/kayit?ref=<%= r.kod %></code>
              <button class="kopyala-btn" onclick="kopyala('<%= baseUrl %>/kayit?ref=<%= r.kod %>', this)" style="background:#1a73e8; color:white; border:none; border-radius:6px; padding:5px 10px; font-size:11px; cursor:pointer; white-space:nowrap; <%= r.kopyalandi ? 'display:none;' : '' %>">Kopyala</button>
              <span class="kopyalandi-rozet" style="<%= r.kopyalandi ? '' : 'display:none;' %> font-size:11px; color:#639922; font-weight:500; white-space:nowrap;">✓ Kopyalandı</span>
            </div>
          <% }); %>
          </div>
          <% var aktifKodlar = (referansKodlari||[]).filter(function(r){ return !r.kullanildi; }); %>
          <% if (aktifKodlar.length === 0) { %>
            <% if (k.rol === 'ogretmen') { %>
              <p style="font-size:13px; color:#f57c00; padding:10px 12px; background:#fff8e1; border:1px solid #ffe082; border-radius:8px; margin:0;">⏰ Aktif referans kodun yok. <b>Yarın 2 yeni link otomatik üretilecek.</b></p>
            <% } else { %>
              <p style="font-size:13px; color:#aaa;">Aktif referans kodun yok.</p>
            <% } %>
          <% } %>
        </div>
      </div>

      <!-- Sağ: Sıralamalar (öğrenci için; öğretmen için davet listesi linki) -->
      <div>
        <% if (k.rol === 'ogretmen') { %>
          <div class="profil-kart-yeni" style="text-align:center;">
            <p class="profil-kart-baslik-yeni">👩‍🏫 Davet Ettiklerim</p>
            <div style="font-size:36px; font-weight:700; color:#6a1b9a; margin:14px 0 6px 0;"><%= davetEdilenler ? davetEdilenler.length : 0 %></div>
            <p style="font-size:12px; color:#888; margin-bottom:14px;">kullanıcı senin referansınla kayıt oldu.</p>
            <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=davetEdilenler" style="display:inline-block; padding:8px 18px; background:#6a1b9a; color:white; border-radius:8px; text-decoration:none; font-size:13px; font-weight:600;">Listeyi Gör →</a>
          </div>
        <% } else { %>
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni">Genel sıralama</p>
          <% if (siralamaVerisi.nitelikli === false) { %>
            <div style="background:#fff8e1; border:1px solid #ffe082; border-radius:8px; padding:10px 12px; margin-bottom:12px; font-size:12px; color:#795548; line-height:1.5;">
              ℹ️ Sıralamada yer alabilmek için <b>en az <%= siralamaVerisi.minSoru || 10 %> soru</b> çözmelisin.
              <span style="color:#1565c0; font-weight:600;">(Şu ana kadar: <%= siralamaVerisi.kullaniciSoruSayisi || 0 %>)</span>
            </div>
          <% } %>
          <% function srFmt(no) { return no > 0 ? '#'+no : '—'; } %>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Türkiye</span><div><div class="siralama-no-yeni"><%= srFmt(siralamaVerisi.turkiye) %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.toplamKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İl</span><div><div class="siralama-no-yeni"><%= srFmt(siralamaVerisi.il) %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.ilKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İlçe</span><div><div class="siralama-no-yeni"><%= srFmt(siralamaVerisi.ilce) %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.ilceKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Okul</span><div><div class="siralama-no-yeni"><%= srFmt(siralamaVerisi.okul) %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.okulKullanici %> öğrenci</div></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Sınıf<%= k.sube ? ' ('+k.sinif+'-'+k.sube+')' : '' %></span><div><div class="siralama-no-yeni"><%= srFmt(siralamaVerisi.sinif) %></div><div class="siralama-toplam-yeni">/ <%= siralamaVerisi.sinifKullanici %> öğrenci</div></div></div>
        </div>
        <% dp.forEach(function(d) {
          var sr = ds[d.ders] || {};
          var renk = dersRenkleri[d.ders] || '#888';
        %>
        <div class="profil-kart-yeni">
          <p class="profil-kart-baslik-yeni" style="color:<%= renk %>;"><%= d.ders %></p>
          <% if (sr.nitelikli === false) { %>
            <div style="background:#fff8e1; border:1px solid #ffe082; border-radius:8px; padding:8px 10px; margin-bottom:10px; font-size:11px; color:#795548; line-height:1.5;">
              ℹ️ Sıralamada yer alabilmek için bu dersten <b>en az 10 soru</b> çözmelisin.
              <span style="color:#1565c0; font-weight:600;">(Şu ana kadar: <%= sr.kullaniciSoruSayisi || 0 %>)</span>
            </div>
          <% } %>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Türkiye</span><div><div class="siralama-no-yeni"><%= srFmt(sr.turkiye) %></div><% if(sr.toplamKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.toplamKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İl</span><div><div class="siralama-no-yeni"><%= srFmt(sr.il) %></div><% if(sr.ilKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.ilKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">İlçe</span><div><div class="siralama-no-yeni"><%= srFmt(sr.ilce) %></div><% if(sr.ilceKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.ilceKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Okul</span><div><div class="siralama-no-yeni"><%= srFmt(sr.okul) %></div><% if(sr.okulKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.okulKullanici %></div><% } %></div></div>
          <div class="siralama-satir-yeni"><span class="siralama-kapsam-yeni">Sınıf<%= k.sube ? ' ('+k.sinif+'-'+k.sube+')' : '' %></span><div><div class="siralama-no-yeni"><%= srFmt(sr.sinif) %></div><% if(sr.sinifKullanici){ %><div class="siralama-toplam-yeni">/ <%= sr.sinifKullanici %></div><% } %></div></div>
        </div>
        <% }); %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- İSTATİSTİK SEKMESİ -->
  <div id="sekme-istatistik" class="sekme-icerik">
    <%
      var tumC = tumCevaplar || [];
      var genelDogru  = tumC.filter(function(c){ return c.dogruMu; }).length;
      var genelYanlis = tumC.filter(function(c){ return !c.dogruMu; }).length;
      var genelToplam = tumC.length;
      var genelOran   = genelToplam > 0 ? Math.round((genelDogru / genelToplam) * 100) : 0;
      var genelSure   = genelToplam > 0 ? Math.round(tumC.reduce(function(t,c){ return t+(c.sure||0); },0) / genelToplam) : 0;
      var genelBarRenk = genelOran >= 70 ? '#43a047' : genelOran >= 40 ? '#fb8c00' : '#e53935';
      var genelRenk    = genelOran >= 70 ? '#2e7d32' : genelOran >= 40 ? '#e65100' : '#c62828';
      var dersler = Object.keys(dersIstatMap);
    %>

    <% if (genelToplam === 0) { %>
      <div class="yakin-wrap">
        <div class="yakin-ikon">📈</div>
        <div class="yakin-baslik">Henüz istatistik yok</div>
        <div class="yakin-alt">Soru çözdükçe ders ve konu bazlı istatistiklerin burada görünecek.</div>
      </div>
    <% } else { %>

      <!-- Genel özet -->
      <div class="profil-kart-yeni" style="margin-bottom:14px;">
        <p class="profil-kart-baslik-yeni">Genel İstatistikler</p>
        <%
          // Genel ortalama: yalnızca en az 5 soru çözülmüş dersler hesaba katılır
          var GENEL_ORT_MIN_SORU = 5;
          var nitelikliDersler = (k.dersPuanlari || []).filter(function(d){ return d.soruSayisi >= GENEL_ORT_MIN_SORU; });
          var nitelikliOrtTop = nitelikliDersler.reduce(function(t, d){ return t + (d.toplamPuan / d.soruSayisi); }, 0);
          var genelOrtPuan = nitelikliDersler.length > 0 ? (nitelikliOrtTop / nitelikliDersler.length) : 0;
        %>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(115px, 1fr)); gap:10px; margin-bottom:14px;">
          <div style="background:#f3e5f5; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#6a1b9a;"><%= genelOrtPuan.toFixed(2) %></div>
            <div style="font-size:11px; color:#888; margin-top:3px;">Genel ortalama</div>
          </div>
          <div style="background:#f8f9fa; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#1a73e8;"><%= k.puan %></div>
            <div style="font-size:11px; color:#999; margin-top:3px;">Toplam puan</div>
          </div>
          <div style="background:#f8f9fa; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#202124;"><%= genelToplam %></div>
            <div style="font-size:11px; color:#999; margin-top:3px;">Çözülen soru</div>
          </div>
          <div style="background:#f8f9fa; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:<%= genelRenk %>;"><%= genelOran %>%</div>
            <div style="font-size:11px; color:#999; margin-top:3px;">Doğru oranı</div>
          </div>
          <div style="background:#e8f5e9; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#2e7d32;"><%= genelDogru %></div>
            <div style="font-size:11px; color:#66bb6a; margin-top:3px;">Doğru</div>
          </div>
          <div style="background:#ffebee; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#c62828;"><%= genelYanlis %></div>
            <div style="font-size:11px; color:#ef9a9a; margin-top:3px;">Yanlış</div>
          </div>
          <div style="background:#f8f9fa; border-radius:10px; padding:14px; text-align:center;">
            <div style="font-size:22px; font-weight:700; color:#202124;"><%= genelSure %>sn</div>
            <div style="font-size:11px; color:#999; margin-top:3px;">Ort. süre</div>
          </div>
        </div>
        <div style="height:6px; background:#f0f0f0; border-radius:3px; overflow:hidden;">
          <div style="height:100%; width:<%= genelOran %>%; background:<%= genelBarRenk %>; border-radius:3px;"></div>
        </div>
      </div>

      <!-- Tüm konular — başarı yüzdesine göre (zayıftan güçlüye) -->
      <%
        var tumKonular = [];
        dersler.forEach(function(ders) {
          var di = dersIstatMap[ders];
          Object.keys(di.konular).forEach(function(konu) {
            var kd = di.konular[konu];
            var top = kd.dogru + kd.yanlis;
            if (top > 0) {
              tumKonular.push({
                ders: ders,
                konu: konu,
                dogru: kd.dogru,
                top: top,
                oran: Math.round((kd.dogru / top) * 100)
              });
            }
          });
        });
        tumKonular.sort(function(a, b) {
          if (a.oran !== b.oran) return a.oran - b.oran;
          return b.top - a.top; // aynı oranda daha çok soru çözülen önce
        });
      %>
      <% if (tumKonular.length > 0) { %>
      <div class="profil-kart-yeni" style="margin-bottom:14px;">
        <p class="profil-kart-baslik-yeni">Konu Bazlı Başarı — Zayıftan Güçlüye</p>
        <p style="font-size:12px; color:#888; margin-bottom:12px;">Önce çalışılması gereken konular en üstte. Toplam <%= tumKonular.length %> konu listede.</p>
        <% tumKonular.forEach(function(t, idx) {
          var renk = t.oran >= 85 ? '#43a047' : t.oran >= 70 ? '#fbc02d' : t.oran >= 45 ? '#fb8c00' : '#e53935';
        %>
          <div style="display:flex; align-items:center; gap:10px; padding:8px 0; border-bottom:1px solid #f5f5f5;">
            <span style="font-size:11px; color:#bbb; min-width:24px; text-align:right;"><%= idx + 1 %>.</span>
            <div style="flex:1; min-width:0;">
              <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:4px;">
                <span style="font-size:13px; color:#333; font-weight:500; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= t.konu %></span>
                <span style="font-size:12px; font-weight:600; color:<%= renk %>; white-space:nowrap; margin-left:8px;"><%= t.oran %>%</span>
              </div>
              <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                <div style="flex:1; height:4px; background:#f0f0f0; border-radius:2px; overflow:hidden;">
                  <div style="height:100%; width:<%= t.oran %>%; background:<%= renk %>; border-radius:2px;"></div>
                </div>
                <span style="font-size:10px; color:#999; white-space:nowrap;"><%= t.ders %> · <%= t.dogru %>/<%= t.top %></span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
      <% } %>

      <!-- Ders bazlı kartlar -->
      <% dersler.forEach(function(ders) {
        var di = dersIstatMap[ders];
        var toplamSoru = di.toplamDogru + di.toplamYanlis;
        var dogruOran  = toplamSoru > 0 ? Math.round((di.toplamDogru / toplamSoru) * 100) : 0;
        var renk    = dogruOran >= 70 ? '#2e7d32' : dogruOran >= 40 ? '#e65100' : '#c62828';
        var barRenk = dogruOran >= 70 ? '#43a047' : dogruOran >= 40 ? '#fb8c00' : '#e53935';
        var konular = Object.keys(di.konular);
        var dersOrtSure = toplamSoru > 0 ? Math.round(konular.reduce(function(t,k){ return t+di.konular[k].toplamSure; },0) / toplamSoru) : 0;
      %>
      <div class="profil-kart-yeni" style="margin-bottom:14px;">
        <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px;">
          <div>
            <p style="font-size:14px; font-weight:600; color:#202124; margin:0;"><%= ders %></p>
            <p style="font-size:12px; color:#888; margin:2px 0 0;"><%= toplamSoru %> soru çözüldü</p>
          </div>
          <div style="font-size:20px; font-weight:700; color:<%= renk %>;"><%= dogruOran %>%</div>
        </div>
        <div style="height:6px; background:#f0f0f0; border-radius:3px; overflow:hidden; margin-bottom:14px;">
          <div style="height:100%; width:<%= dogruOran %>%; background:<%= barRenk %>; border-radius:3px;"></div>
        </div>
        <%
          var dToplamPuan = di.toplamPuan || 0;
          var dOrtPuan = toplamSoru > 0 ? (dToplamPuan / toplamSoru) : 0;
        %>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(95px, 1fr)); gap:8px; margin-bottom:14px;">
          <div style="background:#fff3e0; border-radius:8px; padding:10px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#e65100;"><%= dOrtPuan.toFixed(2) %></div>
            <div style="font-size:11px; color:#ffab91;">Ort. puan</div>
          </div>
          <div style="background:#e8f0fe; border-radius:8px; padding:10px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#1a73e8;"><%= dToplamPuan.toFixed(1) %></div>
            <div style="font-size:11px; color:#7baef5;">Toplam puan</div>
          </div>
          <div style="background:#f8f9fa; border-radius:8px; padding:10px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:<%= renk %>;"><%= dogruOran %>%</div>
            <div style="font-size:11px; color:#999;">Başarı yüzdesi</div>
          </div>
          <div style="background:#e8f5e9; border-radius:8px; padding:10px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#2e7d32;"><%= di.toplamDogru %></div>
            <div style="font-size:11px; color:#66bb6a;">Doğru</div>
          </div>
          <div style="background:#ffebee; border-radius:8px; padding:10px; text-align:center;">
            <div style="font-size:18px; font-weight:600; color:#c62828;"><%= di.toplamYanlis %></div>
            <div style="font-size:11px; color:#ef9a9a;">Yanlış</div>
          </div>
        </div>
        <% if (konular.length > 0) { %>
        <p style="font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; color:#b0bcc8; margin-bottom:10px;">Konu Detayı</p>
        <% var konularSirali = konular.slice().sort(function(a, b) {
          var ka = di.konular[a], kb = di.konular[b];
          var taop = ka.dogru + ka.yanlis, tbop = kb.dogru + kb.yanlis;
          var oa = taop > 0 ? (ka.dogru / taop) : 1;
          var ob = tbop > 0 ? (kb.dogru / tbop) : 1;
          if (oa !== ob) return oa - ob;
          return tbop - taop;
        }); %>
        <% konularSirali.forEach(function(konu) {
          var kd = di.konular[konu];
          var kTop  = kd.dogru + kd.yanlis;
          var kOran = kTop > 0 ? Math.round((kd.dogru / kTop) * 100) : 0;
          var kRenk = kOran >= 70 ? '#43a047' : kOran >= 40 ? '#fb8c00' : '#e53935';
          var kSure = kTop > 0 ? Math.round(kd.toplamSure / kTop) : 0;
        %>
          <div style="padding:10px 0; border-bottom:1px solid #f5f5f5;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:5px;">
              <span style="font-size:13px; color:#333; font-weight:500;"><%= konu %></span>
              <div style="display:flex; align-items:center; gap:12px;">
                <span style="font-size:11px; color:#aaa;">⏱ ort. <%= kSure %>sn</span>
                <span style="font-size:12px; font-weight:600; color:<%= kRenk %>;"><%= kd.dogru %>/<%= kTop %> — <%= kOran %>%</span>
              </div>
            </div>
            <div style="height:4px; background:#f0f0f0; border-radius:2px; overflow:hidden;">
              <div style="height:100%; width:<%= kOran %>%; background:<%= kRenk %>; border-radius:2px;"></div>
            </div>
          </div>
        <% }); %>
        <% } %>
      </div>
      <% }); %>

      <!-- Son çözülen sorular -->
      <div class="profil-kart-yeni">
        <p class="profil-kart-baslik-yeni">Son Çözülen Sorular (<%= Math.min(tumC.length, 50) %>)</p>
        <div style="overflow-x:auto;">
          <table style="width:100%; border-collapse:collapse; font-size:12px;">
            <thead>
              <tr>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">#</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Ders</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Konu</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Süre</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Puan</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Sonuç</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;">Tarih</th>
                <th style="background:#f8f9fa; padding:8px 10px; text-align:left; font-weight:600; color:#666; border-bottom:1px solid #e8edf2;"></th>
              </tr>
            </thead>
            <tbody>
              <% tumC.slice(0, 50).forEach(function(c, i) {
                var sb = (soruBilgiMap && soruBilgiMap[String(c.soruId)]) || {};
              %>
              <tr>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#aaa;"><%= i+1 %></td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#444;"><%= sb.ders||'-' %></td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#444; max-width:160px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= sb.konu||'-' %></td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#444;"><%= c.sure||0 %>sn</td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#1a73e8; font-weight:600;"><%= (c.kazanilanPuan||0).toFixed ? Number(c.kazanilanPuan||0).toFixed(1) : (c.kazanilanPuan||0) %></td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5;">
                  <span style="display:inline-flex; align-items:center; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:600; background:<%= c.dogruMu ? '#e8f5e9' : '#ffebee' %>; color:<%= c.dogruMu ? '#2e7d32' : '#c62828' %>;">
                    <%= c.dogruMu ? '✓ Doğru' : '✗ Yanlış' %>
                  </span>
                </td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5; color:#aaa;"><%= c.tarih ? new Date(c.tarih).toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' }) : '-' %></td>
                <td style="padding:7px 10px; border-bottom:1px solid #f5f5f5;">
                  <% if (!c.dogruMu && sb.soruMetni) { %>
                    <button onclick="soruGoster('<%= String(c.soruId) %>')"
                      style="background:#e8f0fe; color:#1a73e8; border:none; border-radius:6px; padding:4px 10px; font-size:11px; font-weight:600; cursor:pointer; white-space:nowrap;">
                      Soruyu Gör
                    </button>
                  <% } %>
                  <a href="/iletisim?hata=1&sinif=<%= encodeURIComponent(sb.sinif||'') %>&ders=<%= encodeURIComponent(sb.ders||'') %>&konu=<%= encodeURIComponent(sb.konu||'') %>&soruNo=<%= encodeURIComponent(sb.soruNo||'') %>" target="_blank"
                    style="background:#ffebee; color:#c62828; border:none; border-radius:6px; padding:4px 10px; font-size:11px; font-weight:600; text-decoration:none; white-space:nowrap; display:inline-block; margin-left:4px;"
                    title="Bu soruda hata varsa bildir">
                    ⚠️ Hatalı
                  </a>
                </td>
              </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Soru Gör Modalı -->
      <div id="soruGorModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center; padding:20px;">
        <div style="background:white; border-radius:16px; max-width:680px; width:100%; max-height:90vh; overflow-y:auto; position:relative;">
          <div style="padding:16px 20px; border-bottom:1px solid #f0f0f0; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; background:white; z-index:1; border-radius:16px 16px 0 0;">
            <span style="font-size:14px; font-weight:600; color:#202124;">Soru İnceleme</span>
            <button onclick="soruKapat()" style="background:#f5f5f5; border:none; border-radius:50%; width:30px; height:30px; cursor:pointer; font-size:16px; display:flex; align-items:center; justify-content:center;">✕</button>
          </div>
          <div id="soruGorIcerik" style="padding:20px 24px;"></div>
        </div>
      </div>

      <!-- Soru verisi JS'e gömülüyor -->
      <script>
      var soruVerileri = {};
      <% tumC.forEach(function(c) {
        if (!c.dogruMu) {
          var sb = (soruBilgiMap && soruBilgiMap[String(c.soruId)]);
          if (sb && sb.soruMetni) { %>
      soruVerileri['<%= String(c.soruId) %>'] = <%- JSON.stringify({
        soruMetni: sb.soruMetni,
        soruOnculu1: sb.soruOnculu1||'',
        soruOnculu1Resmi: sb.soruOnculu1Resmi||'',
        soruOnculu2: sb.soruOnculu2||'',
        soruOnculu2Resmi: sb.soruOnculu2Resmi||'',
        soruOnculu3: sb.soruOnculu3||'',
        soruOnculu3Resmi: sb.soruOnculu3Resmi||'',
        soruResmi: sb.soruResmi||'',
        secenekler: sb.secenekler||[],
        dogruCevapIndex: sb.dogruCevapIndex,
        tabloBaslik: sb.tabloBaslik||[],
        sikDizilimi: sb.sikDizilimi||'dikey',
        ders: sb.ders||'',
        konu: sb.konu||''
      }) %>;
      <% } } }); %>

      var harfler = ['A','B','C','D'];

      function gorselHtml(url) {
        if (!url || url === '[GÖRSEL VAR]') return '';
        return '<div style="text-align:center; margin-bottom:8px;"><img src="' + url + '" style="max-width:100%; max-height:220px; border-radius:8px; object-fit:contain;"></div>';
      }

      function htmlDuzelt(metin) {
        if (!metin) return '';
        // HTML entity karekök → direkt sembol
        return metin.replace(/&#8730;/g, '√').replace(/&radic;/g, '√');
      }

      function oncul(metin, resim) {
        var html = '';
        if (metin) html += '<div style="background:transparent; border-left:3px solid #1a73e8; border-radius:0 8px 8px 0; padding:12px 16px; font-size:13px; line-height:1.6; color:#555; margin-bottom:8px;">' + htmlDuzelt(metin) + '</div>';
        if (resim) html += gorselHtml(resim);
        return html;
      }

      function soruGoster(id) {
        var s = soruVerileri[id];
        if (!s) return;
        var html = '';

        // Etiketler
        html += '<div style="display:flex; gap:6px; flex-wrap:wrap; margin-bottom:14px;">';
        if (s.ders) html += '<span style="background:#e3f2fd; color:#1565c0; font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px;">' + s.ders + '</span>';
        if (s.konu) html += '<span style="background:#f3e5f5; color:#6a1b9a; font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px;">' + s.konu + '</span>';
        html += '</div>';

        // Öncüller — metin + görsel çifti olarak
        html += oncul(s.soruOnculu1, s.soruOnculu1Resmi);
        html += oncul(s.soruOnculu2, s.soruOnculu2Resmi);
        html += oncul(s.soruOnculu3, s.soruOnculu3Resmi);

        // Soru metni
        html += '<div style="font-size:16px; font-weight:500; color:#202124; line-height:1.6; margin-bottom:12px;">' + s.soruMetni + '</div>';

        // Soru görseli
        if (s.soruResmi) html += gorselHtml(s.soruResmi);

        // Tablo başlığı
        if (s.tabloBaslik && s.tabloBaslik.length > 0) {
          html += '<div style="margin-bottom:4px;"><table style="border-collapse:collapse; font-size:13px; table-layout:fixed;"><tr><td style="padding:3px 0; width:48px;"></td>';
          s.tabloBaslik.forEach(function(b) {
            html += '<td style="padding:3px 0; width:90px; border-bottom:1px solid #999; font-weight:500; text-align:center;">' + b + '</td>';
          });
          html += '</tr></table></div>';
        }

        // Şıklar
        var gridCols = s.sikDizilimi === 'yatay' ? 'repeat(4,1fr)' : s.sikDizilimi === 'ikili' ? 'repeat(2,1fr)' : '1fr';
        html += '<div style="display:grid; grid-template-columns:' + gridCols + '; gap:8px; margin-bottom:20px;">';
        (s.secenekler || []).forEach(function(sik, i) {
          var dogru = i === s.dogruCevapIndex;
          var tabloMu = sik.metin && sik.metin.indexOf('<table') !== -1;
          html += '<div style="display:flex; align-items:center; gap:10px; padding:12px 14px; border-radius:10px; border:1.5px solid ' + (dogru ? '#43a047' : '#f0f0f0') + '; background:' + (dogru ? '#f1f8e9' : 'white') + '; cursor:default;">';
          html += '<span style="width:28px; height:28px; border-radius:8px; background:' + (dogru ? '#43a047' : '#f0f2f5') + '; color:' + (dogru ? 'white' : '#666') + '; display:inline-flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; flex-shrink:0;">' + harfler[i] + '</span>';
          var sikMetin = (sik.metin||'').trim();
          if (sikMetin) html += '<span style="font-size:13px; color:' + (dogru ? '#2e7d32' : '#444') + '; flex:1;">' + sikMetin + '</span>';
          if (sik.gorsel) html += '<img src="' + sik.gorsel + '" style="max-width:100px; max-height:60px; object-fit:contain; ' + (sikMetin ? 'margin-left:8px;' : 'flex:1;') + '">';
          if (dogru) html += '<span style="margin-left:auto; font-size:11px; color:#43a047; font-weight:700; white-space:nowrap; flex-shrink:0;">✓ Doğru</span>';
          html += '</div>';
        });
        html += '</div>';

        // Doğru cevap özet satırı
        var dogCevap = s.secenekler && s.secenekler[s.dogruCevapIndex];
        html += '<div style="background:#e8f5e9; border:1px solid #a5d6a7; border-radius:10px; padding:10px 14px; font-size:13px; color:#2e7d32; font-weight:500;">✓ Doğru cevap: <b>' + harfler[s.dogruCevapIndex] + '</b> şıkkı</div>';

        document.getElementById('soruGorIcerik').innerHTML = html;
        mathRenderSonra(document.getElementById('soruGorIcerik'));
        if (window.MathJax) MathJax.typesetPromise([document.getElementById('soruGorIcerik')]);
        var modal = document.getElementById('soruGorModal');
        modal.style.display = 'flex';
        document.body.style.overflow = 'hidden';
      }

      function soruKapat() {
        document.getElementById('soruGorModal').style.display = 'none';
        document.body.style.overflow = '';
      }

      document.getElementById('soruGorModal').addEventListener('click', function(e) {
        if (e.target === this) soruKapat();
      });
      </script>

    <% } %>
  </div>

  <!-- GÜVENLİK SEKMESİ -->
  <% if (!adminGorunum) { %>
  <div id="sekme-guvenlik" class="sekme-icerik">
    <div class="sifre-kart-profil">
      <div class="sifre-profil-header">
        <div>
          <div class="sifre-profil-baslik">Şifre Değiştir</div>
