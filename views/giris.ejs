<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LGS Hazırlık - Giriş</title>
<link rel="stylesheet" href="/style.css">
</head>
<body class="auth-body">
<div class="auth-card">
  <h2 class="auth-title">LGS Hazırlık</h2>
  <form action="/giris" method="POST">
    <input name="kullaniciAdi" placeholder="Kullanıcı Adı" required class="input">
    <input type="password" name="sifre" placeholder="Şifre" required class="input">
    <button type="submit" class="btn btn-primary">GİRİŞ YAP</button>
  </form>
  <p class="auth-link">Hesabınız yok mu? <a href="/kayit">Kayıt Ol</a></p>
</div>
</body>
</html>
