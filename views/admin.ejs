      <div class="admin-soru-item">
        <div class="admin-soru-sol">
          <code style="font-size:13px; letter-spacing:2px; color:#aaa; font-weight:600;"><%= r.kod %></code>
          <span style="font-size:11px; color:#aaa; margin-left:8px;">Oluşturan: <b><%= r.olusturan %></b></span>
          <span style="font-size:11px; color:#639922; margin-left:8px;">→ <b><%= r.kullanan %></b></span>
          <span style="font-size:11px; color:#aaa; margin-left:8px;"><%= r.kullanimTarih ? new Date(r.kullanimTarih).toLocaleDateString('tr-TR') : '' %></span>
        </div>
      </div>
    <% }); %>
  </div>
  <% } %>

  <% if (kullanilanlar.length > 0) { %>
  <div class="admin-card">
    <div class="admin-card-title">🌳 Referans Zinciri</div>
    <% kullanilanlar.forEach(function(r) { %>
      <div style="display:flex; align-items:center; gap:8px; padding:6px 0; border-bottom:1px solid #f5f5f5; font-size:13px;">
        <span style="background:#fff3e0; color:#e65100; padding:2px 10px; border-radius:20px; font-size:12px; font-weight:600;"><%= r.olusturan %></span>
        <span style="color:#ccc; font-size:16px;">→</span>
        <span style="background:#e3f2fd; color:#1a73e8; padding:2px 10px; border-radius:20px; font-size:12px; font-weight:600;"><%= r.kullanan %></span>
        <span style="font-size:11px; color:#bbb; margin-left:auto;"><%= r.kullanimTarih ? new Date(r.kullanimTarih).toLocaleDateString('tr-TR') : '' %></span>
      </div>
    <% }); %>
  </div>
  <% } %>

  <script>
  function adminKopyala(kod, btn) {
    var metin = btn.getAttribute('data-link');
    var key = 'kopyalandi_' + kod;
    var oncekiZaman = localStorage.getItem(key);
    if (oncekiZaman) {
      var tarih = new Date(parseInt(oncekiZaman)).toLocaleString('tr-TR');
      if (!confirm('⚠️ Bu link daha önce kopyalandı!\n\nKopyalanma zamanı: ' + tarih + '\n\nYine de kopyalamak istiyor musun?')) return;
    }
    navigator.clipboard.writeText(metin).then(function() {
      localStorage.setItem(key, Date.now().toString());
      var eski = btn.innerText;
      btn.innerText = '✓ Kopyalandı';
      setTimeout(function() { btn.innerText = eski; }, 2000);
    });
  }
  </script>

<% } else if (mod === 'soruListesi') { %>
  <div class="admin-card">
    <div class="admin-card-title">
      Soru Filtrele
    </div>
    <form method="GET" action="/admin" style="display:flex; flex-wrap:wrap; gap:10px; align-items:flex-end;">
      <input type="hidden" name="mod" value="soruListesi">
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Sınıf</label>
        <select name="filSinif" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:90px;">
          <option value="">Tümü</option>
          <% tumSoruSiniflar.forEach(function(s) { %>
            <option value="<%= s %>" <%= filSinif==s?'selected':'' %>><%= s %>. Sınıf</option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ders</label>
        <select name="filDers" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruDersler.forEach(function(d) { %>
            <option value="<%= d %>" <%= filDers==d?'selected':'' %>><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ünite</label>
        <select name="filUnite" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruUniteler.forEach(function(u) { %>
            <option value="<%= u %>" <%= filUnite==u?'selected':'' %>><%= u %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Konu</label>
        <select name="filKonu" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:160px;">
          <option value="">Tümü</option>
          <% tumSoruKonular.forEach(function(k) { %>
            <option value="<%= k %>" <%= filKonu==k?'selected':'' %>><%= k %></option>
          <% }); %>
        </select>
      </div>
      <% if (filSinif || filDers || filUnite || filKonu) { %>
        <a href="/admin?mod=soruListesi" style="padding:7px 14px; background:#ffebee; color:#c62828; border-radius:8px; font-size:12px; font-weight:600; text-decoration:none; align-self:flex-end;">✕ Filtreyi Temizle</a>
      <% } %>
      <div style="margin-left:auto; align-self:flex-end; font-size:13px; color:#888;">
        <b style="color:#1a73e8;"><%= tumSorular.length %></b> soru listeleniyor
      </div>
    </form>
  </div>

  <div class="admin-card">
    <div class="admin-card-title">Sorular</div>

    <%
      var taslaklar = tumSorular.filter(function(s){ return !s.durum || s.durum === 'taslak'; })
        .sort(function(a,b){ return a._id.toString().localeCompare(b._id.toString()); });
      var yayindalar = tumSorular.filter(function(s){ return s.durum === 'yayinda'; })
        .sort(function(a,b){
          var ta = b.yayinTarih ? new Date(b.yayinTarih) : new Date(0);
          var tb = a.yayinTarih ? new Date(a.yayinTarih) : new Date(0);
          return ta - tb;
        });
      var duraklatilanlar = tumSorular.filter(function(s){ return s.durum === 'duraklat'; });
    %>

    <% if (taslaklar.length > 0) { %>
    <div class="soru-grup-baslik soru-grup-taslak">🟡 Taslak — <%= taslaklar.length %> soru</div>
    <% taslaklar.forEach(function(s, i) { %>
      <div class="admin-soru-item">
        <div class="admin-soru-sol">
          <div class="admin-soru-no" title="Soru No">#<%= s.soruNo || '—' %></div>
          <div>
            <div class="admin-soru-metin">[<%= s.sinif %>. Sınıf - <%= s.ders %><% if(s.unite){%> - <%= s.unite %><% } %><% if(s.konu){%> - <%= s.konu %><% } %>] <%= s.soruMetni.substring(0,50) %>...</div>
            <div class="admin-soru-istat">Z: <%= (s.zorlukKatsayisi||3).toFixed(1) %> | HP: <%= s.hamPuan !== null && s.hamPuan !== undefined ? Number(s.hamPuan).toFixed(1) : '-' %></div>
          </div>
        </div>
        <div class="admin-soru-sag">
          <button type="button" onclick="soruOnizle('<%= s._id %>')" class="admin-btn admin-btn-onizle">ÖNİZLE</button>
          <a href="/admin?duzenle=<%= s._id %>&mod=soruEkle" class="admin-btn admin-btn-duzenle">DÜZENLE</a>
          <form action="/soru-sil" method="POST" style="display:inline;">
            <input type="hidden" name="id" value="<%= s._id %>">
            <button class="admin-btn admin-btn-sil">SİL</button>
          </form>
        </div>
      </div>
    <% }); %>
    <% } %>

    <% if (yayindalar.length > 0) { %>
    <div class="soru-grup-baslik soru-grup-yayinda">🟢 Yayında — <%= yayindalar.length %> soru</div>
    <% yayindalar.forEach(function(s, i) { %>
      <div class="admin-soru-item">
        <div class="admin-soru-sol">
          <div class="admin-soru-no" title="Soru No">#<%= s.soruNo || '—' %></div>
          <div>
            <div class="admin-soru-metin">[<%= s.sinif %>. Sınıf - <%= s.ders %><% if(s.unite){%> - <%= s.unite %><% } %><% if(s.konu){%> - <%= s.konu %><% } %>] <%= s.soruMetni.substring(0,50) %>...</div>
            <div class="admin-soru-istat">Z: <%= (s.zorlukKatsayisi||3).toFixed(1) %> | HP: <%= s.hamPuan !== null && s.hamPuan !== undefined ? Number(s.hamPuan).toFixed(1) : '-' %></div>
          </div>
        </div>
        <div class="admin-soru-sag">
          <button type="button" onclick="soruOnizle('<%= s._id %>')" class="admin-btn admin-btn-onizle">ÖNİZLE</button>
          <a href="/admin?duzenle=<%= s._id %>&mod=soruEkle" class="admin-btn admin-btn-duzenle">DÜZENLE</a>
          <form action="/soru-sil" method="POST" style="display:inline;">
            <input type="hidden" name="id" value="<%= s._id %>">
            <button class="admin-btn admin-btn-sil">SİL</button>
          </form>
        </div>
      </div>
    <% }); %>
    <% } %>

    <% if (duraklatilanlar.length > 0) { %>
    <div class="soru-grup-baslik soru-grup-duraklat">⏸️ Duraklatıldı — <%= duraklatilanlar.length %> soru</div>
    <% duraklatilanlar.forEach(function(s, i) { %>
      <div class="admin-soru-item">
        <div class="admin-soru-sol">
          <div class="admin-soru-no" title="Soru No">#<%= s.soruNo || '—' %></div>
          <div>
            <div class="admin-soru-metin">[<%= s.sinif %>. Sınıf - <%= s.ders %><% if(s.unite){%> - <%= s.unite %><% } %><% if(s.konu){%> - <%= s.konu %><% } %>] <%= s.soruMetni.substring(0,50) %>...</div>
            <div class="admin-soru-istat">Z: <%= (s.zorlukKatsayisi||3).toFixed(1) %> | HP: <%= s.hamPuan !== null && s.hamPuan !== undefined ? Number(s.hamPuan).toFixed(1) : '-' %></div>
          </div>
        </div>
        <div class="admin-soru-sag">
          <button type="button" onclick="soruOnizle('<%= s._id %>')" class="admin-btn admin-btn-onizle">ÖNİZLE</button>
          <a href="/admin?duzenle=<%= s._id %>&mod=soruEkle" class="admin-btn admin-btn-duzenle">DÜZENLE</a>
          <form action="/soru-sil" method="POST" style="display:inline;">
            <input type="hidden" name="id" value="<%= s._id %>">
            <button class="admin-btn admin-btn-sil">SİL</button>
          </form>
        </div>
      </div>
    <% }); %>
    <% } %>

    <% if (tumSorular.length === 0) { %>
      <p style="color:#aab4c4; text-align:center; padding:20px;">Filtreyle eşleşen soru bulunamadı.</p>
    <% } %>

  </div>

  <!-- Soru Önizleme Modal -->
  <div id="soruOnizlemeModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.7); z-index:2000; align-items:center; justify-content:center;">
    <div style="background:white; border-radius:12px; padding:20px; width:800px; max-width:95vw; max-height:90vh; overflow-y:auto; position:relative;">
      <button onclick="document.getElementById('soruOnizlemeModal').style.display='none'" style="position:absolute; top:10px; right:10px; background:#e74c3c; color:white; border:none; width:30px; height:30px; border-radius:50%; cursor:pointer; font-size:16px;">✕</button>
      <h3 style="margin:0 0 16px;">🔍 Soru Önizleme</h3>
      <div id="soruOnizlemeIcerik" style="min-height:300px;">Yükleniyor...</div>
    </div>
  </div>

  <script>
  function soruOnizle(id) {
    var icerik = document.getElementById('soruOnizlemeIcerik');
    var modal = document.getElementById('soruOnizlemeModal');
    icerik.innerHTML = 'Yükleniyor...';
    modal.style.display = 'flex';
    fetch('/api/soru/' + id, { headers: { 'Authorization': 'Basic <%- adminToken %>' } })
      .then(function(r){ return r.json(); })
      .then(function(s){
        var harfler = ['A','B','C','D'];
        var html = '';
        if (s.soruOnculu1) html += '<div style="background:#f5f5f5; padding:10px; border-radius:6px; margin-bottom:8px; font-size:14px;">' + s.soruOnculu1 + '</div>';
        if (s.soruOnculu1Resmi) html += '<div style="text-align:center; margin-bottom:8px;"><img src="' + s.soruOnculu1Resmi + '" style="max-width:100%; max-height:200px; border-radius:8px;"></div>';
        if (s.soruOnculu2) html += '<div style="background:#f5f5f5; padding:10px; border-radius:6px; margin-bottom:8px; font-size:14px;">' + s.soruOnculu2 + '</div>';
        if (s.soruOnculu2Resmi) html += '<div style="text-align:center; margin-bottom:8px;"><img src="' + s.soruOnculu2Resmi + '" style="max-width:100%; max-height:200px; border-radius:8px;"></div>';
        if (s.soruOnculu3) html += '<div style="background:#f5f5f5; padding:10px; border-radius:6px; margin-bottom:8px; font-size:14px;">' + s.soruOnculu3 + '</div>';
        if (s.soruOnculu3Resmi) html += '<div style="text-align:center; margin-bottom:10px;"><img src="' + s.soruOnculu3Resmi + '" style="max-width:100%; max-height:250px; border-radius:8px;"></div>';
        html += '<h3 style="font-size:17px; margin:12px 0;">' + s.soruMetni + '</h3>';
        if (s.tabloBaslik && s.tabloBaslik.length > 0) {
          html += '<div style="margin-bottom:4px;"><table style="border-collapse:collapse; font-size:13px; table-layout:fixed;"><tr><td style="padding:3px 0; width:48px;"></td>';
          for (var tb = 0; tb < s.tabloBaslik.length; tb++) {
            html += '<td style="padding:3px 0; width:90px; border-bottom:1px solid #999; font-weight:500; text-align:center;">' + s.tabloBaslik[tb] + '</td>';
          }
          html += '</tr></table></div>';
        }
        var dizilim = s.sikDizilimi || 'dikey';
        var gridCols = dizilim === 'yatay' ? '1fr 1fr 1fr 1fr' : dizilim === 'ikili' ? '1fr 1fr' : '1fr';
        html += '<div style="display:grid; grid-template-columns:' + gridCols + '; gap:8px;">';
        for (var i = 0; i < 4; i++) {
          if (!s.secenekler[i]) continue;
          var sikMetin = s.secenekler[i].metin || '';
          var tabloMu = sikMetin.indexOf('<table') !== -1;
          var dogruMu = s.dogruCevapIndex === i;
          var bgRenk = dogruMu ? '#d4edda' : 'white';
          var border = dogruMu ? '2px solid #28a745' : '2px solid #ddd';
          html += '<div style="padding:10px 14px; border:' + border + '; border-radius:8px; background:' + bgRenk + '; text-align:left;">';
          if (!tabloMu) html += '<b>' + harfler[i] + ')</b> ';
          html += sikMetin;
          if (s.secenekler[i].gorsel) html += '<br><img src="' + s.secenekler[i].gorsel + '" style="max-width:150px; margin-top:5px;">';
          html += '</div>';
        }
        html += '</div>';
        html += '<p style="margin-top:12px; font-size:12px; color:#28a745;"><b>Doğru Cevap:</b> ' + harfler[s.dogruCevapIndex] + '</p>';
        icerik.innerHTML = html;
        if (window.MathJax) MathJax.typesetPromise([icerik]);
      })
      .catch(function(e){ icerik.innerHTML = '<p style="color:red;">Hata: ' + e.message + '</p>'; });
  }
  </script>
<% } %>

</div>
</body>
</html>
