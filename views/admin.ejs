<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LGS Hazırlık - Admin</title>
<link rel="stylesheet" href="/style.css">
<style>
.sqrt{display:inline-flex;align-items:center;}
.sqrt-sembol{font-size:1.15em;line-height:1;margin-right:1px;}
.sqrt-icerik{border-top:1.5px solid currentColor;padding:0 2px;display:inline-block;}
.math-sup{vertical-align:super;font-size:.75em;}
.math-sub{vertical-align:sub;font-size:.75em;}
.math-frac{display:inline-flex;flex-direction:column;align-items:center;vertical-align:middle;font-size:.85em;line-height:1.2;}
.math-frac-ust{border-bottom:1px solid currentColor;padding:0 2px;}
.math-frac-alt{padding:0 2px;}
/* v4.2.4: MathJax inline matematiği biraz büyüt — şıklarda $\hat{A}$ gibi gösterimler küçük kalmasın */
mjx-container[jax="CHTML"][display="false"] { font-size: 1.08em !important; }
mjx-container[jax="CHTML"] { line-height: 1.5; }
</style>
<script>
window.MathJaxReady = false;
MathJax = {
  tex: { inlineMath: [['$','$']], displayMath: [['$$','$$']] },
  options: { skipHtmlTags: ['script','style','textarea','pre'] },
  startup: {
    ready() {
      // v4.1.33: Eski sorularda "\\le" gibi çift backslash ile kaydedilmiş matematik
      // metinleri MathJax otomatik typeset etmeden ÖNCE normalize et.
      try {
        if (typeof ciftBackslashNormalize === 'function') {
          ciftBackslashNormalize(document.body);
        }
      } catch(e) {}
      MathJax.startup.defaultReady();
      window.MathJaxReady = true;
    }
  }
};
</script>
<script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js" async></script>
<script>
// v4.1.33: Bazı eski sorularda metin "\\le" gibi çift backslash ile kaydedilmiş.
// LaTeX'te "\\" yeni satır demektir, "\le" değil. Render etmeden önce sadece
// $...$ matematik blokları içindeki çift backslash'ları tek backslash'a indirgiyoruz.
function ciftBackslashNormalize(el) {
  if (!el) return;
  var walker = document.createTreeWalker(el, NodeFilter.SHOW_TEXT, null);
  var nodes = [];
  while (walker.nextNode()) nodes.push(walker.currentNode);
  nodes.forEach(function(node) {
    var t = node.textContent;
    if (t.indexOf('\\\\') === -1) return;
    if (!t.match(/\$[^$]*\\\\[^$]*\$/)) return;
    var yeni = t.replace(/\$([^$]+)\$/g, function(tam, ic) {
      return '$' + ic.replace(/\\\\/g, '\\') + '$';
    });
    if (yeni !== t) node.textContent = yeni;
  });
}
function mathRenderSonra(el) {
  if (!el) return;
  ciftBackslashNormalize(el);
  if (window.MathJaxReady && window.MathJax && MathJax.typesetPromise) {
    MathJax.typesetPromise([el]).catch(function(){});
  } else if (window.MathJax && MathJax.typesetPromise) {
    setTimeout(function(){ MathJax.typesetPromise([el]).catch(function(){}); }, 500);
  }
}
document.addEventListener('DOMContentLoaded', function() {
  try { ciftBackslashNormalize(document.body); } catch(e) {}
  if (window.MathJax && MathJax.typesetPromise) {
    MathJax.typesetPromise([document.body]).catch(function(){});
  }
});
</script>
</head>
<body class="panel-body">

<div class="admin-topbar">
  <a href="/admin" class="admin-logo-wrap">
    <div class="admin-logo-badge">LGS</div>
    <div>
      <div class="admin-logo-text">LGS Hazırlık</div>
      <div class="admin-logo-sub">Admin Paneli</div>
    </div>
  </a>

  <%
    // v4.2.2: Admin nav iki seviyeli gruplandırma.
    // Her grup, içindeki mod'lara göre aktiflik durumu hesaplar.
    var icerikModlari      = ['soruListesi', 'zorlukRapor', 'soruEkle', 'pdfYukle', 'uniteler', 'konuIzinleri', 'soruDagilim'];
    var kullaniciModlari   = ['kullanicilar', 'referans', 'okullar'];
    var iletisimModlari    = ['haberler', 'mesajlar'];
    var sistemModlari      = ['sifirla'];

    var aktifGrup = 'icerik';
    if (kullaniciModlari.indexOf(mod) !== -1) aktifGrup = 'kullanicilar';
    else if (iletisimModlari.indexOf(mod) !== -1) aktifGrup = 'iletisim';
    else if (sistemModlari.indexOf(mod) !== -1) aktifGrup = 'sistem';
  %>

  <div class="admin-nav-grup">
    <a href="/admin?mod=soruListesi" class="admin-grup-btn <%= aktifGrup==='icerik'?'active':'' %>">📚 İçerik</a>
    <a href="/admin?mod=kullanicilar" class="admin-grup-btn <%= aktifGrup==='kullanicilar'?'active':'' %>">👥 Kullanıcılar</a>
    <a href="/admin?mod=haberler" class="admin-grup-btn <%= aktifGrup==='iletisim'?'active':'' %>" style="position:relative;">
      📢 İletişim
      <% if (okunmamisMesajSayisi > 0) { %>
        <span style="position:absolute; top:-3px; right:-6px; background:#e24b4a; color:white; font-size:10px; font-weight:700; padding:2px 6px; border-radius:9px; line-height:1.2; min-width:14px; text-align:center;"><%= okunmamisMesajSayisi %></span>
      <% } %>
    </a>
    <a href="/admin?mod=sifirla" class="admin-grup-btn <%= aktifGrup==='sistem'?'active':'' %>">⚙️ Sistem</a>
    <div class="admin-nav-right">
      <!-- v4.2.3: Hesaplama butonu üst sağa taşındı — her sayfadan tek tıkla erişim -->
      <button type="button" onclick="adminHesaplaTetikle(event)" id="adminHesaplaBtn" title="Günlük hesaplamayı şimdi çalıştır" style="background:#e8f0fe; color:#1a73e8; border:1px solid #1a73e8; border-radius:6px; padding:6px 14px; font-size:12px; font-weight:600; cursor:pointer; margin-right:14px; white-space:nowrap; transition:background 0.15s;"
        onmouseover="this.style.background='#d2e3fc'" onmouseout="this.style.background='#e8f0fe'">
        ⏰ Hesapla
      </button>
      Merhaba <span class="admin-user-badge"><%= process.env.ADMIN_USER||'admin' %></span> · <a href="#" onclick="adminCikisYap(event)" class="admin-nav-link" style="color:#999; font-size:12px;">Çıkış</a>
    </div>
  </div>
</div>

<!-- v4.2.2: Alt sekme satırı — aktif gruba göre o grubun sekmeleri -->
<!-- v4.2.3: Sol başında grup etiketi (örn. "İÇERİK") — hangi grupta olduğunu netleştirir -->
<%
  var grupAdiMap = {
    'icerik':       'İÇERİK',
    'kullanicilar': 'KULLANICILAR',
    'iletisim':     'İLETİŞİM',
    'sistem':       'SİSTEM'
  };
  var grupAdi = grupAdiMap[aktifGrup] || '';
%>
<div class="admin-alt-nav">
  <span class="admin-grup-etiket"><%= grupAdi %></span>
  <% if (aktifGrup === 'icerik') { %>
    <a href="/admin?mod=soruListesi" class="admin-alt-link <%= mod==='soruListesi'?'active':'' %>">📋 Sorular</a>
    <a href="/admin?mod=zorlukRapor" class="admin-alt-link <%= mod==='zorlukRapor'?'active':'' %>">📊 Zorluk Raporu</a>
    <a href="/admin/soru-puan-detay" class="admin-alt-link">🔬 Soru Puan Detayı</a>
    <a href="/admin/duplicate-sorular" class="admin-alt-link">🔍 Tekrar Eden Sorular</a>
    <a href="/admin?mod=soruEkle" class="admin-alt-link <%= mod==='soruEkle'?'active':'' %>">➕ Yeni Soru</a>
    <a href="/admin?mod=pdfYukle" class="admin-alt-link <%= mod==='pdfYukle'?'active':'' %>">📄 PDF Yükle</a>
    <a href="/admin/gorselli-pdf-yukle" class="admin-alt-link">🖼️ Görselli PDF Yükle</a>
    <a href="/admin?mod=uniteler" class="admin-alt-link <%= mod==='uniteler'?'active':'' %>">📚 Üniteler</a>
    <a href="/admin?mod=konuIzinleri" class="admin-alt-link <%= mod==='konuIzinleri'?'active':'' %>">🔓 Konu İzinleri</a>
    <a href="/admin?mod=soruDagilim" class="admin-alt-link <%= mod==='soruDagilim'?'active':'' %>">📊 Soru Dağılımı</a>
    <a href="/oyun" class="admin-alt-link">🪐 Oyun (Önizleme)</a>
  <% } else if (aktifGrup === 'kullanicilar') { %>
    <a href="/admin?mod=kullanicilar" class="admin-alt-link <%= mod==='kullanicilar'?'active':'' %>">👥 Kullanıcılar</a>
    <a href="/admin?mod=referans" class="admin-alt-link <%= mod==='referans'?'active':'' %>">🔗 Referans</a>
    <a href="/admin?mod=okullar" class="admin-alt-link <%= mod==='okullar'?'active':'' %>">🏫 Okullar</a>
  <% } else if (aktifGrup === 'iletisim') { %>
    <a href="/admin?mod=haberler" class="admin-alt-link <%= mod==='haberler'?'active':'' %>">📰 Haberler</a>
    <a href="/admin?mod=mesajlar" class="admin-alt-link <%= mod==='mesajlar'?'active':'' %>" style="position:relative;">
      💬 Mesajlar
      <% if (okunmamisMesajSayisi > 0) { %>
        <span style="position:absolute; top:-3px; right:-6px; background:#e24b4a; color:white; font-size:10px; font-weight:700; padding:2px 6px; border-radius:9px; line-height:1.2; min-width:14px; text-align:center;"><%= okunmamisMesajSayisi %></span>
      <% } %>
    </a>
  <% } else if (aktifGrup === 'sistem') { %>
    <a href="/admin/puan-simulasyon" class="admin-alt-link <%= mod==='puanSimulasyon'?'active':'' %>">📊 Puan Simülasyonu</a>
    <a href="/admin?mod=sifirla" class="admin-alt-link danger <%= mod==='sifirla'?'active':'' %>">🗑️ Sıfırla</a>
  <% } %>
</div>

<style>
  /* v4.2.2: İki seviyeli admin nav */
  /* v4.2.3: Renk paleti beyaz header için düzeltildi — eskiden header'ı mavi
     varsayıp beyaz metin koymuştum, ama header beyaz olduğu için metin
     görünmüyordu. Mevcut .admin-nav-link gri-mavi paletine uyumlu. */
