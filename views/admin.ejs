  function haberDuzenleKapat(id) {
    var f = document.getElementById('duzenle-' + id);
    if (f) f.style.display = 'none';
    var btn = f && f.parentNode.querySelector('button[onclick*="haberDuzenleAc"]');
    if (btn) btn.style.display = '';
  }
  </script>

