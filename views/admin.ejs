      </div>
      <div>
        <button type="submit" class="ekle-btn" style="background:#1a73e8; color:white;">+ Yayınla</button>
        <span style="font-size:11px; color:#888; margin-left:10px;">Yayınlanma tarihi otomatik olarak şimdi atanır.</span>
      </div>
    </form>
  </div>

  <div class="admin-card" style="margin-top:14px;">
    <div class="admin-card-title">📋 Yayında Olanlar (<%= tumHaberler.length %>)</div>
    <% if (tumHaberler.length === 0) { %>
      <div style="padding:24px; text-align:center; color:#888;">Henüz haber yok.</div>
    <% } else { %>
      <% tumHaberler.forEach(function(h) {
           var tarih = new Date(h.yayinTarih);
           var simdi = new Date();
           var farkGun = Math.floor((simdi - tarih) / 86400000);
           var yeniMi = farkGun < 7;
           var tarihStr = tarih.toLocaleString('tr-TR', { day:'numeric', month:'long', year:'numeric', hour:'2-digit', minute:'2-digit', timeZone:'Europe/Istanbul' });
      %>
        <div style="padding:14px 16px; border-bottom:1px solid #f0f0f0; display:flex; gap:14px; align-items:flex-start;">
          <div style="flex:1; min-width:0;">
            <div style="display:flex; align-items:center; gap:8px; margin-bottom:6px; flex-wrap:wrap;">
              <span style="font-weight:600; font-size:14px; color:#222;"><%= h.baslik %></span>
              <% if (yeniMi) { %><span style="background:#e8f5e9; color:#2e7d32; font-size:10px; font-weight:700; padding:2px 7px; border-radius:8px;">🆕 YENİ</span><% } %>
              <span style="font-size:11px; color:#888;"><%= tarihStr %></span>
            </div>
            <div style="font-size:13px; color:#444; white-space:pre-wrap; line-height:1.5;"><%= h.icerik %></div>
          </div>
          <div style="display:flex; flex-direction:column; gap:4px;">
            <button onclick="haberDuzenleAc('<%= h._id %>', this)" style="background:#fff3cd; color:#856404; padding:6px 10px; border:1px solid #ffe082; border-radius:6px; font-size:11px; cursor:pointer; font-weight:600; white-space:nowrap;">✎ Düzenle</button>
            <form action="/haber-sil" method="POST" onsubmit="return confirm('Bu haberi silmek istediğine emin misin?');" style="margin:0;">
              <input type="hidden" name="id" value="<%= h._id %>">
