    <form action="/sifirla" method="POST" onsubmit="return sifirlaOnay(this, 'TÜM VERİLERİ SIFIRLA');" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <input type="text" placeholder="onaylamak için 'sifirla' yaz" autocomplete="off"
        oninput="sifirlaInputDegisti(this)"
        style="padding:8px 12px; border:1px solid #ccc; border-radius:6px; font-size:13px; min-width:240px; font-family:monospace;">
      <button type="submit" disabled class="btn btn-danger" style="opacity:0.45; cursor:not-allowed;">SIFIRLA</button>
    </form>
  </div>

  <div class="card" style="margin-top:16px;">
    <h3 style="color:#e65100;">📊 Soru İstatistiklerini Sıfırla</h3>
    <p>Bu işlem soruların çözülme sayısı, doğru sayısı, ortalama süre ve zorluk katsayısı gibi istatistiklerini sıfırlar.</p>
    <p>Kullanıcı verileri, soru içerikleri ve öğrenci puanları <b>etkilenmez</b>.</p>
    <p><b>Bu işlem geri alınamaz!</b></p>
    <form action="/soru-istatistik-sifirla" method="POST" onsubmit="return sifirlaOnay(this, 'SORU İSTATİSTİKLERİNİ SIFIRLA');" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <input type="text" placeholder="onaylamak için 'sifirla' yaz" autocomplete="off"
        oninput="sifirlaInputDegisti(this)"
        style="padding:8px 12px; border:1px solid #ccc; border-radius:6px; font-size:13px; min-width:240px; font-family:monospace;">
      <button type="submit" disabled class="btn" style="background:#e65100; color:white; opacity:0.45; cursor:not-allowed;">📊 SORU İSTATİSTİKLERİNİ SIFIRLA</button>
    </form>
  </div>

  <script>
    // v4.2.3: "sifirla" yazma zorunluluğu — kazara tıklamayı önlemek için
    function sifirlaInputDegisti(inp) {
      var btn = inp.parentElement.querySelector('button[type="submit"]');
      if (!btn) return;
      var dogru = (inp.value.trim().toLowerCase() === 'sifirla');
      btn.disabled = !dogru;
      btn.style.opacity = dogru ? '1' : '0.45';
      btn.style.cursor = dogru ? 'pointer' : 'not-allowed';
    }
    function sifirlaOnay(form, etiket) {
      return confirm(etiket + ' işlemi başlatılsın mı?\n\nBu işlem GERİ ALINAMAZ. Emin misin?');
    }
  </script>

<% } else if (mod === 'referans') { %>
  <%
    var baseUrlAdmin = (process.env.SITE_URL || 'https://lgssorucozum-4.onrender.com').replace(/\/$/, '');
    var bekleyenler = tumReferanslar.filter(function(r){ return !r.kullanildi; });
    // v4.3.52: 4 kademeli sıralama
    //   1) admin + kopyalanmamış   (yeni → eski)
    //   2) kullanıcı + kopyalanmamış
    //   3) admin + kopyalanmış
    //   4) kullanıcı + kopyalanmış
    bekleyenler.sort(function(a, b) {
      var aKademe = (a.olusturan === 'admin' ? 0 : 1) + (a.kopyalandi ? 2 : 0);
      var bKademe = (b.olusturan === 'admin' ? 0 : 1) + (b.kopyalandi ? 2 : 0);
      if (aKademe !== bKademe) return aKademe - bKademe;
      // Kademe aynıysa yeni → eski (azalan tarih)
      return new Date(b.olusturmaTarih) - new Date(a.olusturmaTarih);
    });
    var kullanilanlar = tumReferanslar.filter(function(r){ return r.kullanildi; });
    // Kullanılanlar: admin önce, içlerinde yeni → eski
    kullanilanlar.sort(function(a, b) {
      var aA = a.olusturan === 'admin' ? 0 : 1;
      var bA = b.olusturan === 'admin' ? 0 : 1;
      if (aA !== bA) return aA - bA;
      return new Date(b.olusturmaTarih) - new Date(a.olusturmaTarih);
    });
  %>

  <div class="admin-card">
    <div class="admin-card-title">
      Referans Kodu Üret
      <span style="font-size:12px; color:#888;">Toplam: <%= tumReferanslar.length %> | Bekleyen: <%= bekleyenler.length %> | Kullanılan: <%= kullanilanlar.length %></span>
    </div>
    <form action="/referans-uret" method="POST" style="display:flex; gap:10px; align-items:center; flex-wrap:wrap;">
      <input type="number" name="adet" value="10" min="1" max="500" style="width:90px; padding:8px 12px; border:1px solid #e2e8f0; border-radius:8px; font-size:13px;">
      <select name="tip" style="padding:8px 12px; border:1px solid #e2e8f0; border-radius:8px; font-size:13px; background:white;">
        <option value="ogrenci">👨‍🎓 Öğrenci linki</option>
        <option value="ogretmen">👩‍🏫 Öğretmen linki</option>
        <option value="kurumsal">🏛️ Kurumsal linki</option>
        <option value="veli">👪 Veli linki</option>
        <option value="demo">🧪 Demo linki (etkisiz öğrenci hesabı)</option>
      </select>
      <button class="ekle-btn">Kod Üret</button>
      <span style="font-size:12px; color:#888;">adet (max 500)</span>
    </form>
    <% if (bekleyenler.length > 0) { %>
    <form action="/referans-toplu-sil" method="POST" style="margin-top:10px;">
      <button onclick="return confirm('Tüm bekleyen kodlar silinsin mi?')" style="background:#fbeaea; color:#a32d2d; border:1px solid #f5c6c6; border-radius:6px; padding:6px 14px; font-size:12px; cursor:pointer;">🗑 Tüm Bekleyenleri Sil (<%= bekleyenler.length %>)</button>
    </form>
    <% } %>
  </div>

  <% if (bekleyenler.length > 0) { %>
  <div class="admin-card">
    <div class="admin-card-title">🟡 Bekleyen Kodlar — <%= bekleyenler.length %></div>
    <% bekleyenler.forEach(function(r) { %>
      <div class="admin-soru-item admin-referans-satir" data-kod="<%= r.kod %>">
        <div class="admin-soru-sol">
          <code style="font-size:13px; letter-spacing:2px; color:<%= r.kopyalandi ? '#aaa' : '#1a73e8' %>; font-weight:600;"><%= r.kod %></code>
          <% var refGTip = r.gercekTip || r.tip; %>
          <% if (refGTip === 'kurumsal') { %>
            <span style="font-size:10px; background:#e0f2f1; color:#00695c; padding:2px 8px; border-radius:10px; margin-left:6px; font-weight:600;">🏛️ KURUMSAL</span>
          <% } else if (refGTip === 'ogretmen') { %>
            <span style="font-size:10px; background:#e1bee7; color:#6a1b9a; padding:2px 8px; border-radius:10px; margin-left:6px; font-weight:600;">👩‍🏫 ÖĞRETMEN</span>
          <% } else if (refGTip === 'veli') { %>
            <span style="font-size:10px; background:#fff3e0; color:#e65100; padding:2px 8px; border-radius:10px; margin-left:6px; font-weight:600;">👪 VELİ</span>
          <% } else if (refGTip === 'demo') { %>
            <span style="font-size:10px; background:#ede7f6; color:#5e35b1; padding:2px 8px; border-radius:10px; margin-left:6px; font-weight:600;">🧪 DEMO</span>
          <% } else { %>
            <span style="font-size:10px; background:#e3f2fd; color:#1565c0; padding:2px 8px; border-radius:10px; margin-left:6px; font-weight:600;">👨‍🎓 ÖĞRENCİ</span>
          <% } %>
          <span style="font-size:11px; color:#aaa; margin-left:8px;">Oluşturan: <b><%= r.olusturan %></b></span>
          <span style="font-size:11px; color:#aaa; margin-left:8px;"><%= new Date(r.olusturmaTarih).toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' }) %></span>
          <% if (r.kopyalandi) { %>
            <span class="admin-kopyalandi-rozet" style="font-size:11px; color:#639922; font-weight:500; margin-left:8px;">✓ Kopyalandı<%= r.kopyalanmaTarih ? ' (' + new Date(r.kopyalanmaTarih).toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' }) + ')' : '' %></span>
          <% } else { %>
            <span class="admin-kopyalandi-rozet" style="display:none; font-size:11px; color:#639922; font-weight:500; margin-left:8px;">✓ Kopyalandı</span>
          <% } %>
        </div>
        <div class="admin-soru-sag">
          <button onclick="adminKopyala('<%= r.kod %>', this)" data-link="<%= baseUrlAdmin %>/kayit?ref=<%= r.kod %>" class="admin-btn admin-btn-duzenle"><%= r.kopyalandi ? '🔁 Tekrar Kopyala' : '🔗 Linki Kopyala' %></button>
          <form action="/referans-sil" method="POST" style="display:inline;">
            <input type="hidden" name="id" value="<%= r._id %>">
            <button class="admin-btn admin-btn-sil">Sil</button>
          </form>
        </div>
      </div>
    <% }); %>
  </div>
  <% } %>

  <% if (kullanilanlar.length > 0) { %>
  <div class="admin-card">
    <div class="admin-card-title">✅ Kullanılan Kodlar — <%= kullanilanlar.length %></div>
    <% kullanilanlar.forEach(function(r) { %>
      <div class="admin-soru-item">
        <div class="admin-soru-sol">
          <code style="font-size:13px; letter-spacing:2px; color:#aaa; font-weight:600;"><%= r.kod %></code>
          <span style="font-size:11px; color:#aaa; margin-left:8px;">Oluşturan: <b><%= r.olusturan %></b></span>
          <span style="font-size:11px; color:#639922; margin-left:8px;">→ <b><%= r.kullanan %></b></span>
          <span style="font-size:11px; color:#aaa; margin-left:8px;"><%= r.kullanimTarih ? new Date(r.kullanimTarih).toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' }) : '' %></span>
        </div>
      </div>
    <% }); %>
  </div>
  <% } %>

  <% if (kullanilanlar.length > 0) { %>
  <div class="admin-card">
    <div class="admin-card-title">🌳 Referans Zinciri</div>
    <% kullanilanlar.forEach(function(r) { %>
      <div style="display:flex; align-items:center; gap:8px; padding:6px 0; border-bottom:1px solid #f5f5f5; font-size:13px;">
        <span style="background:#fff3e0; color:#e65100; padding:2px 10px; border-radius:20px; font-size:12px; font-weight:600;"><%= r.olusturan %></span>
        <span style="color:#ccc; font-size:16px;">→</span>
        <span style="background:#e3f2fd; color:#1a73e8; padding:2px 10px; border-radius:20px; font-size:12px; font-weight:600;"><%= r.kullanan %></span>
        <span style="font-size:11px; color:#bbb; margin-left:auto;"><%= r.kullanimTarih ? new Date(r.kullanimTarih).toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' }) : '' %></span>
      </div>
    <% }); %>
  </div>
  <% } %>

  <script>
  function adminKopyala(kod, btn) {
    var link = btn.getAttribute('data-link');
    // v4.1.29: "Siyah ekran" uyarısı kaldırıldı — sadece linkin kendisi kopyalansın.
    var metin = link;
    navigator.clipboard.writeText(metin).then(function() {
      // 1) Sunucuya bildir (kalıcı işaretle)
      fetch('/admin-referans-kopyalandi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Authorization': 'Basic <%= adminToken %>' },
        body: 'kod=' + encodeURIComponent(kod)
      }).then(function(r){
        if (!r.ok) console.warn('admin-referans-kopyalandi sunucu hatası:', r.status);
      }).catch(function(e){
        console.warn('admin-referans-kopyalandi bildirimi başarısız:', e);
      });
      // 2) UI güncelle: rozeti aç, kodu griye çevir, butonu "Tekrar Kopyala" yap, satırı en alta gönder
      var satir = btn.closest('.admin-referans-satir');
      if (satir) {
        var kodEl = satir.querySelector('code');
        if (kodEl) kodEl.style.color = '#aaa';
        var rozet = satir.querySelector('.admin-kopyalandi-rozet');
        if (rozet) {
          rozet.style.display = 'inline';
          var bugun = new Date().toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul' });
          rozet.innerText = '✓ Kopyalandı (' + bugun + ')';
        }
        btn.innerText = '🔁 Tekrar Kopyala';
        // Satırı bekleyen kodlar listesinin en altına gönder
        var konteyner = satir.parentElement;
        if (konteyner) konteyner.appendChild(satir);
      } else {
        var eski = btn.innerText;
        btn.innerText = '✓ Kopyalandı';
        setTimeout(function() { btn.innerText = eski; }, 2000);
      }
    }).catch(function(e){
      console.warn('Pano (clipboard) yazma hatası:', e);
    });
  }
  </script>

<% } else if (mod === 'zorlukRapor') { %>
  <!-- v4.1.36: Zorluk Raporu — soruları zorluk katsayısına göre listeler -->
  <div class="admin-card">
    <div class="admin-card-title">📊 Zorluk Raporu</div>
    <p style="font-size:13px; color:#666; line-height:1.6; margin:6px 0 14px;">
      Tüm soruların zorluk katsayıları. Default kolaydan zora sıralı. Sütun başlığına tıklayarak sıralamayı değiştirebilirsin (aynı başlığa ikinci tıklamada yön değişir).
      Zorluk katsayısı her gün <b>05:10</b>'da çözüm verilerine göre yeniden hesaplanır. Hiç çözülmemiş sorularda default <b>3.0</b> görünür.
    </p>

    <%
      // Zorluk dağılımı özeti
      const zSay = { cokKolay:0, kolay:0, orta:0, zor:0, cokZor:0 };
      tumSorular.forEach(function(s) {
        const z = s.zorlukKatsayisi != null ? s.zorlukKatsayisi : 3;
        if (z < 1.5) zSay.cokKolay++;
        else if (z < 2.5) zSay.kolay++;
        else if (z < 3.5) zSay.orta++;
        else if (z < 4.5) zSay.zor++;
        else zSay.cokZor++;
      });
    %>

    <!-- Özet kartları -->
    <div class="mobil-ikikolon" style="display:grid; grid-template-columns:repeat(5, 1fr); gap:8px; margin-bottom:16px;">
      <div style="background:#e8f5e9; border:1px solid #a5d6a7; border-radius:8px; padding:10px; text-align:center;">
        <div style="font-size:11px; color:#2e7d32; font-weight:600;">ÇOK KOLAY</div>
        <div style="font-size:22px; font-weight:700; color:#27ae60;"><%= zSay.cokKolay %></div>
        <div style="font-size:10px; color:#888;">Z: 1.0 — 1.4</div>
      </div>
      <div style="background:#f1f8e9; border:1px solid #c5e1a5; border-radius:8px; padding:10px; text-align:center;">
        <div style="font-size:11px; color:#558b2f; font-weight:600;">KOLAY</div>
        <div style="font-size:22px; font-weight:700; color:#2ecc71;"><%= zSay.kolay %></div>
        <div style="font-size:10px; color:#888;">Z: 1.5 — 2.4</div>
      </div>
      <div style="background:#fff8e1; border:1px solid #ffe082; border-radius:8px; padding:10px; text-align:center;">
        <div style="font-size:11px; color:#f57c00; font-weight:600;">ORTA</div>
        <div style="font-size:22px; font-weight:700; color:#f39c12;"><%= zSay.orta %></div>
        <div style="font-size:10px; color:#888;">Z: 2.5 — 3.4</div>
      </div>
      <div style="background:#ffe0b2; border:1px solid #ffb74d; border-radius:8px; padding:10px; text-align:center;">
        <div style="font-size:11px; color:#e65100; font-weight:600;">ZOR</div>
        <div style="font-size:22px; font-weight:700; color:#e67e22;"><%= zSay.zor %></div>
        <div style="font-size:10px; color:#888;">Z: 3.5 — 4.4</div>
      </div>
      <div style="background:#ffebee; border:1px solid #ef9a9a; border-radius:8px; padding:10px; text-align:center;">
        <div style="font-size:11px; color:#c62828; font-weight:600;">ÇOK ZOR</div>
        <div style="font-size:22px; font-weight:700; color:#c0392b;"><%= zSay.cokZor %></div>
        <div style="font-size:10px; color:#888;">Z: 4.5 — 5.0</div>
      </div>
    </div>

    <!-- v4.3.29: Zorluk raporu filtre formu — sınıf/ders/ünite/konu (ünitelerden) -->
    <form method="GET" action="/admin" style="display:flex; flex-wrap:wrap; gap:10px; align-items:flex-end; margin-bottom:14px; padding:12px; background:#f8f9fb; border:1px solid #eaecf0; border-radius:10px;">
      <input type="hidden" name="mod" value="zorlukRapor">
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Sınıf</label>
        <select name="filSinif" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fff; min-width:90px;">
          <option value="">Tümü</option>
          <% tumSoruSiniflar.forEach(function(s) { %>
            <option value="<%= s %>" <%= filSinif==s?'selected':'' %>><%= s %>. Sınıf</option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ders</label>
        <select name="filDers" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fff; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruDersler.forEach(function(d) { %>
            <option value="<%= d %>" <%= filDers==d?'selected':'' %>><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ünite</label>
        <select name="filUnite" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fff; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruUniteler.forEach(function(u) { %>
            <option value="<%= u %>" <%= filUnite==u?'selected':'' %>><%= u %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Konu</label>
        <select name="filKonu" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fff; min-width:160px;">
          <option value="">Tümü</option>
          <% tumSoruKonular.forEach(function(k) { %>
            <option value="<%= k %>" <%= filKonu==k?'selected':'' %>><%= k %></option>
          <% }); %>
        </select>
      </div>
      <% if (filSinif || filDers || filUnite || filKonu) { %>
        <a href="/admin?mod=zorlukRapor" style="padding:7px 14px; background:#ffebee; color:#c62828; border-radius:8px; font-size:12px; font-weight:600; text-decoration:none; align-self:flex-end;">✕ Filtreyi Temizle</a>
      <% } %>
    </form>

    <!-- Toplam -->
    <p style="font-size:12px; color:#666; margin-bottom:10px;">Toplam <b><%= tumSorular.length %></b> soru gösteriliyor.
      <% if (filSinif || filDers || filUnite || filKonu) { %>
        <span style="color:#1565c0;">Aktif filtre: <%= [filSinif&&(filSinif+'. Sınıf'), filDers, filUnite, filKonu].filter(Boolean).join(' / ') %></span>
      <% } %>
    </p>

    <!-- Sıralanabilir tablo -->
    <div style="overflow-x:auto; border:1px solid #e0e7ff; border-radius:10px;">
      <table id="zorlukTablo" style="width:100%; border-collapse:collapse; font-size:13px;">
        <thead style="background:#f5f7fa; user-select:none;">
          <tr>
            <th data-sort="soruNo"  data-tip="num" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Soru No <span class="sort-icon"></span></th>
            <th data-sort="sinif"   data-tip="num" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Sınıf <span class="sort-icon"></span></th>
            <th data-sort="ders"    data-tip="str" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Ders <span class="sort-icon"></span></th>
            <th data-sort="unite"   data-tip="str" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Ünite <span class="sort-icon"></span></th>
            <th data-sort="konu"    data-tip="str" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Konu <span class="sort-icon"></span></th>
            <th data-sort="zorluk"  data-tip="num" data-aktif="1" data-yon="asc" style="padding:10px 8px; text-align:right; cursor:pointer; border-bottom:2px solid #e0e7ff; background:#e3f2fd;">Z (Zorluk) <span class="sort-icon">▲</span></th>
            <th data-sort="hp"      data-tip="num" style="padding:10px 8px; text-align:right; cursor:pointer; border-bottom:2px solid #e0e7ff;">HP <span class="sort-icon"></span></th>
            <th data-sort="cozulme" data-tip="num" style="padding:10px 8px; text-align:right; cursor:pointer; border-bottom:2px solid #e0e7ff;">Çözülme <span class="sort-icon"></span></th>
            <th data-sort="dogruluk" data-tip="num" style="padding:10px 8px; text-align:right; cursor:pointer; border-bottom:2px solid #e0e7ff;">Doğruluk <span class="sort-icon"></span></th>
            <th data-sort="ortSure" data-tip="num" style="padding:10px 8px; text-align:right; cursor:pointer; border-bottom:2px solid #e0e7ff;">Ort. Süre <span class="sort-icon"></span></th>
            <th data-sort="durum"   data-tip="str" style="padding:10px 8px; text-align:left; cursor:pointer; border-bottom:2px solid #e0e7ff;">Durum <span class="sort-icon"></span></th>
            <th style="padding:10px 8px; text-align:center; border-bottom:2px solid #e0e7ff;">İşlem</th>
          </tr>
        </thead>
        <tbody>
          <%
            // Önce kolaydan zora sırala (default)
            var siraliSorular = (tumSorular || []).slice().sort(function(a, b) {
              var za = a.zorlukKatsayisi != null ? a.zorlukKatsayisi : 3;
              var zb = b.zorlukKatsayisi != null ? b.zorlukKatsayisi : 3;
              return za - zb;
            });
          %>
          <% siraliSorular.forEach(function(s) {
            var z = s.zorlukKatsayisi != null ? s.zorlukKatsayisi : 3;
            var zEt = z < 1.5 ? 'Çok Kolay' : z < 2.5 ? 'Kolay' : z < 3.5 ? 'Orta' : z < 4.5 ? 'Zor' : 'Çok Zor';
            var zRenk = z < 1.5 ? '#27ae60' : z < 2.5 ? '#2ecc71' : z < 3.5 ? '#f39c12' : z < 4.5 ? '#e67e22' : '#c0392b';
            var dogruluk = (s.cozulmeSayisi||0) > 0 ? Math.round((s.dogruSayisi||0) / s.cozulmeSayisi * 100) : null;
            var hp = s.hamPuan != null ? Number(s.hamPuan).toFixed(1) : null;
            var ortSure = s.ortalamaSure ? Math.round(s.ortalamaSure) : null;
            var durumRenk = s.durum === 'yayinda' ? '#2e7d32' : s.durum === 'taslak' ? '#888' : '#c62828';
          %>
          <tr style="border-bottom:1px solid #f0f3f7;"
              data-soruno="<%= s.soruNo||0 %>"
              data-sinif="<%= s.sinif||0 %>"
              data-ders="<%= s.ders||'' %>"
              data-unite="<%= s.unite||'' %>"
              data-konu="<%= s.konu||'' %>"
              data-zorluk="<%= z %>"
              data-hp="<%= hp != null ? hp : -1 %>"
              data-cozulme="<%= s.cozulmeSayisi||0 %>"
              data-dogruluk="<%= dogruluk != null ? dogruluk : -1 %>"
              data-ortsure="<%= ortSure != null ? ortSure : -1 %>"
              data-durum="<%= s.durum||'' %>">
            <td style="padding:8px;"><%= s.soruNo||'-' %></td>
            <td style="padding:8px;"><%= s.sinif||'-' %></td>
            <td style="padding:8px;"><%= s.ders||'-' %></td>
            <td style="padding:8px; max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= s.unite||'' %>"><%= s.unite||'-' %></td>
            <td style="padding:8px; max-width:160px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= s.konu||'' %>"><%= s.konu||'-' %></td>
            <td style="padding:8px; text-align:right;">
              <span style="display:inline-block; padding:2px 8px; background:<%= zRenk %>; color:white; border-radius:10px; font-size:11px; font-weight:600;"><%= z.toFixed(1) %></span>
              <div style="font-size:10px; color:<%= zRenk %>; margin-top:2px;"><%= zEt %></div>
            </td>
            <td style="padding:8px; text-align:right;"><%= hp != null ? hp : '—' %></td>
            <td style="padding:8px; text-align:right;"><%= s.cozulmeSayisi||0 %></td>
            <td style="padding:8px; text-align:right;"><%= dogruluk != null ? '%'+dogruluk : '—' %></td>
            <td style="padding:8px; text-align:right;"><%= ortSure != null ? ortSure+'sn' : '—' %></td>
            <td style="padding:8px; color:<%= durumRenk %>;"><%= s.durum||'-' %></td>
            <td style="padding:8px; text-align:center; white-space:nowrap;">
              <button type="button" onclick="soruOnizle('<%= s._id %>')" class="admin-btn admin-btn-onizle" style="font-size:10px; padding:3px 8px;">ÖNİZLE</button>
              <a href="/admin?duzenle=<%= s._id %>" class="admin-btn" style="font-size:10px; padding:3px 8px; background:#1a73e8; color:white; text-decoration:none;">DÜZENLE</a>
              <%# v4.5.3: "Çözenler" butonu — alttaki gizli satırı aç/kapat %>
              <button type="button" onclick="cozumlerAcKapa('<%= s._id %>', this)" class="admin-btn" style="font-size:10px; padding:3px 8px; background:#43a047; color:white;">▼ ÇÖZENLER</button>
            </td>
          </tr>
          <%# v4.5.3: Açılır iç tablo — varsayılan gizli, JS ile yüklenir %>
          <tr id="cozenler-row-<%= s._id %>" style="display:none; background:#f0f7ff;">
            <td colspan="12" style="padding:0;">
              <div id="cozenler-icerik-<%= s._id %>" style="padding:12px 20px; font-size:12px;">
                <span style="color:#888; font-style:italic;">Yükleniyor...</span>
              </div>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>

    <% if (!tumSorular.length) { %>
      <p style="text-align:center; color:#888; padding:30px;">Hiç soru yok.</p>
    <% } %>
  </div>

  <script>
    // v4.5.3: Sorunun çözüm detaylarını aç/kapat
    var cozumlerYuklendi = {}; // {soruId: true} → bir kez yüklendi
    function cozumlerAcKapa(soruId, btn) {
      var satir = document.getElementById('cozenler-row-' + soruId);
      var icerik = document.getElementById('cozenler-icerik-' + soruId);
      if (!satir || !icerik) return;
      var acik = satir.style.display !== 'none';
      if (acik) {
        satir.style.display = 'none';
        if (btn) btn.innerHTML = '▼ ÇÖZENLER';
        return;
      }
      satir.style.display = '';
      if (btn) btn.innerHTML = '▲ KAPAT';
      if (cozumlerYuklendi[soruId]) return; // tekrar fetch etme
      fetch('/admin/soru-cozumler/' + encodeURIComponent(soruId), { credentials: 'same-origin' })
        .then(r => r.json())
        .then(d => {
          if (!d || !d.ok) {
            icerik.innerHTML = '<span style="color:#c62828;">Hata: ' + ((d && d.hata) || 'veri yüklenemedi') + '</span>';
            return;
          }
          if (d.cozumSayisi === 0) {
            icerik.innerHTML = '<p style="color:#888; font-style:italic; margin:0;">Bu soruyu henüz kimse doğru çözmedi.</p>';
            cozumlerYuklendi[soruId] = true;
            return;
          }
          var ortSure = d.soru.ortalamaSure ? Math.round(d.soru.ortalamaSure) + 'sn' : '—';
          var html = '<div style="display:flex; align-items:center; gap:14px; margin-bottom:10px; flex-wrap:wrap; padding-bottom:8px; border-bottom:1px solid #d0e3ff;">' +
            '<b style="color:#1a73e8;">' + d.cozumSayisi + ' doğru çözüm</b>' +
            '<span style="color:#666;">Ortalama süre: <b>' + ortSure + '</b></span>' +
            '<span style="color:#666;">Z: <b>' + (d.soru.zorlukKatsayisi||0).toFixed(2) + '</b></span>' +
            '</div>';
          html += '<table style="width:100%; border-collapse:collapse; font-size:12px;"><thead><tr style="background:#e8f0fe;">' +
            '<th style="text-align:left; padding:6px 8px;">#</th>' +
            '<th style="text-align:left; padding:6px 8px;">Kullanıcı</th>' +
            '<th style="text-align:center; padding:6px 8px;">Sınıf</th>' +
            '<th style="text-align:left; padding:6px 8px;">Okul</th>' +
            '<th style="text-align:center; padding:6px 8px;">Süre</th>' +
            '<th style="text-align:center; padding:6px 8px;">Puan</th>' +
            '<th style="text-align:center; padding:6px 8px;">Tarih</th>' +
            '<th style="text-align:center; padding:6px 8px;">Not</th>' +
            '</tr></thead><tbody>';
          d.cozumler.forEach(function(c, i) {
            var t = c.tarih ? new Date(c.tarih).toLocaleDateString('tr-TR', { day:'numeric', month:'short', year:'numeric', timeZone:'Europe/Istanbul' }) : '—';
            var puan = (Math.round((c.kazanilanPuan||0) * 10000) / 10000);
            var not = c.ikinciKezMi ? '<span style="color:#e65100; font-size:10px;">2.kez (1/5^n)</span>' : '';
            html += '<tr style="border-bottom:1px solid #e0e6ec;">' +
              '<td style="padding:5px 8px; color:#999;">' + (i+1) + '</td>' +
              '<td style="padding:5px 8px;"><a href="/kullanici-detay?kullaniciAdi=' + encodeURIComponent(c.kullaniciAdi) + '" style="color:#1a73e8; text-decoration:none;">' + c.kullaniciAdi + '</a></td>' +
              '<td style="padding:5px 8px; text-align:center;">' + c.sinif + (c.sube ? '/'+c.sube : '') + '</td>' +
              '<td style="padding:5px 8px; color:#666; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">' + (c.okul || '—') + '</td>' +
              '<td style="padding:5px 8px; text-align:center; font-weight:600; color:#1a73e8;">' + c.sure + 'sn</td>' +
              '<td style="padding:5px 8px; text-align:center;">' + puan + '</td>' +
              '<td style="padding:5px 8px; text-align:center; color:#666;">' + t + '</td>' +
              '<td style="padding:5px 8px; text-align:center;">' + not + '</td>' +
              '</tr>';
          });
          html += '</tbody></table>';
          icerik.innerHTML = html;
          cozumlerYuklendi[soruId] = true;
        })
        .catch(e => {
          icerik.innerHTML = '<span style="color:#c62828;">İstek hatası: ' + e.message + '</span>';
        });
    }

    // v4.1.36: Tablo sıralaması — başlığa tıkla, aynı başlığa tekrar tıklarsan yön değişir
    (function() {
      var tablo = document.getElementById('zorlukTablo');
      if (!tablo) return;
      var thead = tablo.querySelector('thead');
      var tbody = tablo.querySelector('tbody');

      thead.addEventListener('click', function(e) {
        var th = e.target.closest('th[data-sort]');
        if (!th) return;
        var alan = th.getAttribute('data-sort');
        var tip = th.getAttribute('data-tip');
        var aktifTh = thead.querySelector('th[data-aktif="1"]');
        var yon = 'asc';
        if (aktifTh === th) {
          // Aynı başlık — yön değiştir
          yon = th.getAttribute('data-yon') === 'asc' ? 'desc' : 'asc';
        }
        // Tüm başlıkların aktif/yön bayraklarını sıfırla
        thead.querySelectorAll('th[data-sort]').forEach(function(x) {
          x.removeAttribute('data-aktif');
          x.removeAttribute('data-yon');
          x.style.background = '';
          var ic = x.querySelector('.sort-icon');
          if (ic) ic.textContent = '';
        });
        th.setAttribute('data-aktif', '1');
        th.setAttribute('data-yon', yon);
        th.style.background = '#e3f2fd';
        var ic = th.querySelector('.sort-icon');
        if (ic) ic.textContent = yon === 'asc' ? '▲' : '▼';

        // Satırları sırala — v4.5.3: yalnızca ana soru satırları (data-soruno olanlar)
        // sıralanır; "çözenler" alt satırları parent satırın HEMEN ARDINDA
        // tutulur.
        var anaSatirlar = Array.from(tbody.querySelectorAll('tr[data-soruno]'));
        anaSatirlar.sort(function(a, b) {
          var av = a.getAttribute('data-' + alan.toLowerCase());
          var bv = b.getAttribute('data-' + alan.toLowerCase());
          if (tip === 'num') {
            av = parseFloat(av); if (isNaN(av)) av = -1;
            bv = parseFloat(bv); if (isNaN(bv)) bv = -1;
            return yon === 'asc' ? av - bv : bv - av;
          } else {
            av = (av||'').toString();
            bv = (bv||'').toString();
            var c = av.localeCompare(bv, 'tr');
            return yon === 'asc' ? c : -c;
          }
        });
        // Yeniden ekle — her ana satırdan sonra ilgili cozenler satırı
        // (DOM'dan koparmadan önce eşlemeyi yap, sonra frag'a sırayla ekle)
        var anaSatirlarSiraIle = anaSatirlar.slice();
        var frag = document.createDocumentFragment();
        anaSatirlarSiraIle.forEach(function(r){
          // İlgili cozenler tr'sini onclick içindeki ID'den çıkar
          var btn = r.querySelector('button[onclick^="cozumlerAcKapa"]');
          var soruId = null;
          if (btn) {
            var m = btn.getAttribute('onclick').match(/cozumlerAcKapa\('([^']+)'/);
            if (m) soruId = m[1];
          }
          frag.appendChild(r);
          if (soruId) {
            var cz = document.getElementById('cozenler-row-' + soruId);
            if (cz) frag.appendChild(cz);
          }
        });
        tbody.appendChild(frag);
      });
    })();
  </script>

<% } else if (mod === 'soruListesi') { %>
  <div class="admin-card">
    <div class="admin-card-title" style="display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap;">
      <span>Soru Filtrele</span>
      <div style="display:flex; gap:8px; flex-wrap:wrap;">
        <form action="/soru-no-onar" method="POST" style="margin:0;" onsubmit="return confirm('Numarasız sorulara _id sırasıyla soruNo atanacak. Devam edilsin mi?');">
          <button type="submit" style="background:#fff3cd; color:#856404; border:1px solid #ffe082; padding:6px 12px; border-radius:6px; font-size:12px; font-weight:600; cursor:pointer;">🔧 Numarasız soruları onar</button>
        </form>
        <form action="/soru-latex-onar" method="POST" style="margin:0;" onsubmit="return confirm('Tüm sorularda kayıp LaTeX backslash\\'ları aranacak ve onarılacak ($rac→\\frac, $qrt→\\sqrt vb). Devam edilsin mi?');">
          <button type="submit" style="background:#e3f2fd; color:#1565c0; border:1px solid #90caf9; padding:6px 12px; border-radius:6px; font-size:12px; font-weight:600; cursor:pointer;">🔬 LaTeX onarımı</button>
        </form>
      </div>
    </div>
    <form method="GET" action="/admin" style="display:flex; flex-wrap:wrap; gap:10px; align-items:flex-end;">
      <input type="hidden" name="mod" value="soruListesi">
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Sınıf</label>
        <select name="filSinif" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:90px;">
          <option value="">Tümü</option>
          <% tumSoruSiniflar.forEach(function(s) { %>
            <option value="<%= s %>" <%= filSinif==s?'selected':'' %>><%= s %>. Sınıf</option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ders</label>
        <select name="filDers" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruDersler.forEach(function(d) { %>
            <option value="<%= d %>" <%= filDers==d?'selected':'' %>><%= d %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Ünite</label>
        <select name="filUnite" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:140px;">
          <option value="">Tümü</option>
          <% tumSoruUniteler.forEach(function(u) { %>
            <option value="<%= u %>" <%= filUnite==u?'selected':'' %>><%= u %></option>
          <% }); %>
        </select>
      </div>
      <div style="display:flex; flex-direction:column; gap:4px;">
        <label style="font-size:11px; color:#888; font-weight:600;">Konu</label>
        <select name="filKonu" onchange="this.form.submit()" style="padding:7px 10px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; min-width:160px;">
          <option value="">Tümü</option>
          <% tumSoruKonular.forEach(function(k) { %>
            <option value="<%= k %>" <%= filKonu==k?'selected':'' %>><%= k %></option>
          <% }); %>
        </select>
