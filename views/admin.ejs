  .admin-grup-btn {
    color: #6b7a99;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    padding: 0 16px;
    height: 56px;
    display: inline-flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
  }
  .admin-grup-btn:hover { color: #0c447c; background: #f7f9fc; }
  .admin-grup-btn.active { color: #0c447c; border-bottom-color: #0c447c; font-weight: 600; }

  /* v4.2.3: Grup etiketi — alt nav satırının solunda küçük kategori adı.
     Minimal stil: arka plan yok, sadece koyu mavi yazı + üstte ince çizgi. */
