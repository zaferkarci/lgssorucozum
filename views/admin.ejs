  var _editKonu  = '<%- editSoru ? (editSoru.konu||"") : "" %>';

  // v4.3.29: Soru ekle — sınıf dropdownı da ünitelerden gelir.
  function seSiniflariYukle(seciliSinif, sonraCallback) {
    var sinifSelect = document.getElementById('se_sinif');
    fetch('/api/unite-bilgi')
      .then(function(r){ return r.json(); })
      .then(function(v){
        if (!v.ok) return;
        sinifSelect.innerHTML = '';
        (v.siniflar || []).forEach(function(s){
          var opt = document.createElement('option');
          opt.value = s; opt.textContent = s + '. Sınıf';
          if (String(s) === String(seciliSinif)) opt.selected = true;
          sinifSelect.appendChild(opt);
        });
        if (!sinifSelect.value && sinifSelect.options.length) sinifSelect.selectedIndex = 0;
        if (sonraCallback) sonraCallback();
      })
      ['catch'](function(){});
  }

  function sinifDegisti(hedefUnite, hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    fetch('/api/unite-bilgi?sinif=' + sinif)
      .then(function(r){ return r.json(); })
      .then(function(v){
        if (!v.ok) return;
        _tumUniteler = v.uniteler;
        var dersSelect = document.getElementById('se_ders');
        var mevcutDers = dersSelect.value;
        if (v.dersler.length) {
          var hedefDers = mevcutDers || _editDers || 'Matematik';
          dersSelect.innerHTML = '';
          v.dersler.forEach(function(d){
            var opt = document.createElement('option');
            opt.value = d; opt.textContent = d;
            if (d === hedefDers) opt.selected = true;
            dersSelect.appendChild(opt);
          });
          if (!dersSelect.value) dersSelect.selectedIndex = 0;
        }
        dersDegisti(hedefUnite || '', hedefKonu || '');
      })
      ['catch'](function(){});
  }

  function dersDegisti(hedefUnite, hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    var ders  = document.getElementById('se_ders').value;
    var uniteSelect = document.getElementById('se_unite');
    // hedefUnite yoksa mevcut seçimi koru
    var secilenUnite = (hedefUnite !== undefined) ? hedefUnite : uniteSelect.value;
    uniteSelect.innerHTML = '<option value="">-- Ünite Seçin (Opsiyonel) --</option>';
    _tumUniteler
      .filter(function(u){ return u.ders === ders && (!u.sinif || String(u.sinif) === String(sinif)); })
      .forEach(function(u){
        var opt = document.createElement('option');
        opt.value = u.uniteAdi;
        opt.textContent = u.uniteNo + '. ' + u.uniteAdi;
        if (u.uniteAdi === secilenUnite) opt.selected = true;
        uniteSelect.appendChild(opt);
      });
    uniteDegisti(hedefKonu || '');
  }

  function uniteDegisti(hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    var ders  = document.getElementById('se_ders').value;
    var unite = document.getElementById('se_unite').value;
    var konuSelect = document.getElementById('se_konu');
    var secilenKonu = (hedefKonu !== undefined) ? hedefKonu : konuSelect.value;
    konuSelect.innerHTML = '<option value="">-- Konu Seçin (Opsiyonel) --</option>';
    var seciliUnite = _tumUniteler.find(function(u){
      return u.ders === ders && u.uniteAdi === unite && (!u.sinif || String(u.sinif) === String(sinif));
    });
    if (seciliUnite) {
      seciliUnite.konular.forEach(function(k){
        var opt = document.createElement('option');
        opt.value = k; opt.textContent = k;
        if (k === secilenKonu) opt.selected = true;
        konuSelect.appendChild(opt);
      });
    }
  }

  function ekle(alanId, html, imlecGeri) {
    var ta = document.getElementById(alanId);
    var bas = ta.selectionStart, son = ta.selectionEnd;
    var secili = ta.value.substring(bas, son);
    var eklenen;
    if (secili && imlecGeri > 0) {
      eklenen = html.slice(0, html.length - imlecGeri) + secili + html.slice(html.length - imlecGeri);
    } else {
      eklenen = html;
    }
    ta.value = ta.value.substring(0, bas) + eklenen + ta.value.substring(son);
    ta.focus();
    ta.selectionStart = ta.selectionEnd = bas + eklenen.length - (secili ? 0 : imlecGeri);
  }
  function onizlemeGoster() {
    var metin = document.getElementById('soruMetni').value;
    var div = document.getElementById('onizleme');
    div.innerHTML = metin;
    div.style.display = div.style.display === 'none' ? 'block' : 'none';
  }
  window.addEventListener('DOMContentLoaded', function(){
    // v4.3.29: Önce sınıf listesini ünitelerden yükle, sonra zinciri başlat.
    // editSoru varsa o sınıf seçili gelir, yoksa ilk sınıf.
    seSiniflariYukle(_editSinif, function(){
      sinifDegisti(_editUnite, _editKonu);
    });
  });

  function tabloSikOlusturucu() {
    tabloGuncelle();
    document.getElementById('tabloModal').style.display = 'flex';
  }

  function tabloGuncelle() {
    var sutun = parseInt(document.getElementById('tablo_sutunSayisi').value);
    var romenler = ['I.', 'II.', 'III.', 'IV.', 'V.', 'VI.'];
    var harfler = ['A', 'B', 'C', 'D'];

    // Sütun başlıkları
    var baslikHTML = '<label class="form-label">Sütun başlıkları</label><div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:6px;">';
    for (var s = 0; s < sutun; s++) {
      var mevcutVal = document.getElementById('tablo_baslik_' + s) ? document.getElementById('tablo_baslik_' + s).value : romenler[s] + ' çuval';
      baslikHTML += '<input id="tablo_baslik_' + s + '" value="' + mevcutVal + '" class="input-sm" style="width:100px;" placeholder="Başlık ' + (s+1) + '">';
    }
    baslikHTML += '</div>';
    document.getElementById('tablo_sutunBasliklari').innerHTML = baslikHTML;

    // Şık değerleri — her şık için sütun sayısı kadar input
    var sikHTML = '<label class="form-label" style="margin-top:12px; display:block;">Şık değerleri</label>';
    for (var i = 0; i < 4; i++) {
      sikHTML += '<div style="display:flex; align-items:center; gap:6px; margin-top:8px;"><b style="min-width:24px;">' + harfler[i] + ')</b>';
      for (var s2 = 0; s2 < sutun; s2++) {
        var mevcut = document.getElementById('tablo_val_' + i + '_' + s2) ? document.getElementById('tablo_val_' + i + '_' + s2).value : '';
        sikHTML += '<input id="tablo_val_' + i + '_' + s2 + '" value="' + mevcut + '" placeholder="' + romenler[s2] + '" class="input-sm" style="width:70px; text-align:center;">';
      }
      sikHTML += '</div>';
    }
    document.getElementById('tablo_siklar').innerHTML = sikHTML;
  }

  function tabloHtmlUret() {
    var sutun = parseInt(document.getElementById('tablo_sutunSayisi').value);
    var harfler = ['A', 'B', 'C', 'D'];
    var basliklar = [];
    for (var s = 0; s < sutun; s++) {
      basliklar.push(document.getElementById('tablo_baslik_' + s).value || ('Col ' + (s+1)));
    }

    // Sabit genişlikler — başlık ve değer hücreleri aynı genişlikte olsun ki hizalansın
    var harfGenislik = '48px';
    var sutunGenislik = '90px';

    // Başlıkları gizli input'a JSON olarak kaydet — öncül 1'e dokunma
    document.getElementById('tabloBaslikGizli').value = JSON.stringify(basliklar);

    // Her şık sadece kendi değer satırını içersin
    for (var i = 0; i < 4; i++) {
      var degerSatir = '<table style="border-collapse:collapse; font-size:13px; table-layout:fixed;"><tr><td style="padding:4px 0; width:' + harfGenislik + '; font-weight:500;">' + harfler[i] + ')</td>';
      for (var s3 = 0; s3 < sutun; s3++) {
        var val = document.getElementById('tablo_val_' + i + '_' + s3).value || '-';
        degerSatir += '<td style="padding:4px 0; width:' + sutunGenislik + '; text-align:center;">' + val + '</td>';
      }
      degerSatir += '</tr></table>';
      document.getElementById('sikMetin' + i).value = degerSatir;
    }
    document.getElementById('tabloModal').style.display = 'none';
  }
  </script>

<% } else if (mod === 'kullanicilar') { %>

  <!-- v4.3.69: Bugünün aktivite özeti -->
  <% if (aktiviteOzetiData) {
       var bugunStr = new Date().toLocaleDateString('tr-TR', { timeZone: 'Europe/Istanbul', day:'numeric', month:'long', year:'numeric' });
       var sinifAnahtarlari = Object.keys(aktiviteOzetiData.sinifOzeti).sort();
  %>
  <div class="card" style="background:#f0f7ff; border:1px solid #b3d7ff;">
    <h3 style="margin:0 0 6px; font-size:16px;">📊 Bugünün Aktivitesi <span style="font-size:12px; color:#666; font-weight:400;">— <%= bugunStr %></span></h3>
    <p style="margin:0 0 14px; font-size:13px; color:#555;">
      Toplam <b><%= aktiviteOzetiData.toplamGiris %></b> öğrenci sisteme girdi · <b><%= aktiviteOzetiData.toplamCozum %></b> soru çözüldü
    </p>
    <% if (sinifAnahtarlari.length > 0) { %>
    <div style="display:flex; gap:10px; flex-wrap:wrap;">
      <% sinifAnahtarlari.forEach(function(sinif) {
           var s = aktiviteOzetiData.sinifOzeti[sinif];
      %>
        <div style="background:#fff; border:1px solid #e0e0e0; border-radius:8px; padding:10px 14px; min-width:160px;">
          <div style="font-size:11px; color:#888; text-transform:uppercase; letter-spacing:0.3px; font-weight:600;"><%= sinif %>. Sınıf</div>
          <div style="font-size:13px; color:#333; margin-top:4px;">
            <b style="color:#1a73e8;"><%= s.girisYapan %></b>/<%= s.toplam %> giriş
          </div>
          <div style="font-size:13px; color:#333;">
            <b style="color:#43a047;"><%= s.cozumYapan %></b> kişi · <b><%= s.toplamCozum %></b> soru
          </div>
        </div>
      <% }); %>
    </div>
    <% } else { %>
      <p style="margin:0; color:#999; font-style:italic; font-size:13px;">Bugün henüz aktif öğrenci yok.</p>
    <% } %>

    <% if (aktiviteOzetiData.detayListe.length > 0) { %>
      <details style="margin-top:14px;">
        <summary style="cursor:pointer; font-size:13px; color:#1a73e8; font-weight:600;">
          📋 Aktif öğrenci listesi (<%= aktiviteOzetiData.detayListe.length %> kişi)
        </summary>
        <div style="max-height:400px; overflow-y:auto; margin-top:10px; background:#fff; border:1px solid #e0e0e0; border-radius:8px;">
          <table style="width:100%; border-collapse:collapse; font-size:12px;">
            <thead style="background:#f8f9fa; position:sticky; top:0;">
              <tr>
                <th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e0e0e0;">#</th>
                <th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e0e0e0;">Kullanıcı</th>
                <th style="text-align:center; padding:8px 10px; border-bottom:1px solid #e0e0e0;">Sınıf</th>
                <th style="text-align:left; padding:8px 10px; border-bottom:1px solid #e0e0e0;">Okul</th>
                <th style="text-align:center; padding:8px 10px; border-bottom:1px solid #e0e0e0;">Giriş</th>
                <th style="text-align:center; padding:8px 10px; border-bottom:1px solid #e0e0e0;">Çözüm</th>
              </tr>
            </thead>
            <tbody>
              <% aktiviteOzetiData.detayListe.slice(0, 100).forEach(function(d, i) { %>
                <tr style="border-bottom:1px solid #f0f0f0;">
                  <td style="padding:6px 10px; color:#999;"><%= i+1 %></td>
                  <td style="padding:6px 10px;"><a href="/kullanici-detay?kullaniciAdi=<%= encodeURIComponent(d.kullaniciAdi) %>" style="color:#1a73e8; text-decoration:none;"><%= d.kullaniciAdi %></a></td>
                  <td style="padding:6px 10px; text-align:center;"><%= d.sinif %><%= d.sube ? '/'+d.sube : '' %></td>
                  <td style="padding:6px 10px; color:#666; max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;"><%= d.okul %></td>
                  <td style="padding:6px 10px; text-align:center;"><%= d.girisYaptiMi ? '✓' : '—' %></td>
                  <td style="padding:6px 10px; text-align:center; font-weight:600; color:<%= d.cozumSayisi > 0 ? '#43a047' : '#999' %>;"><%= d.cozumSayisi %></td>
                </tr>
              <% }); %>
              <% if (aktiviteOzetiData.detayListe.length > 100) { %>
                <tr><td colspan="6" style="padding:8px; text-align:center; color:#999; font-style:italic;">... ve <%= aktiviteOzetiData.detayListe.length - 100 %> kişi daha</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </details>
    <% } %>
  </div>
  <% } %>

  <div class="card">
    <h3>Kullanıcı Listesi (Toplam: <%= filtreliKullanicilar.length %>)</h3>
    <form method="GET" action="/admin" style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap;">
      <input type="hidden" name="mod" value="kullanicilar">
      <select name="il" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm İller</option>
        <% iller.forEach(function(il) { %><option value="<%= il %>" <%= filIl===il?'selected':'' %>><%= il %></option><% }); %>
      </select>
      <select name="ilce" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm İlçeler</option>
        <% ilceler.forEach(function(ilce) { %><option value="<%= ilce %>" <%= filIlce===ilce?'selected':'' %>><%= ilce %></option><% }); %>
      </select>
      <select name="okul" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm Okullar</option>
        <% okullar.forEach(function(okul) { %><option value="<%= okul %>" <%= filOkul===okul?'selected':'' %>><%= okul %></option><% }); %>
      </select>
      <!-- v4.3.60: Sınıf seviyesi filtresi -->
      <select name="kullaniciSinif" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm Sınıflar</option>
        <option value="5" <%= filKullaniciSinif==='5'?'selected':'' %>>5. Sınıf</option>
        <option value="6" <%= filKullaniciSinif==='6'?'selected':'' %>>6. Sınıf</option>
        <option value="7" <%= filKullaniciSinif==='7'?'selected':'' %>>7. Sınıf</option>
        <option value="8" <%= filKullaniciSinif==='8'?'selected':'' %>>8. Sınıf</option>
      </select>
    </form>
    <%
      // v4.3.60: Akıllı sıralama
      //   • Öğrenciler: Türkiye sırası (1, 2, 3...) → eşit ise il/ilçe alfabetik
      //   • Niteliksiz öğrenciler (Türkiye sırası 0): puan azalan, sonra il/ilçe
      //   • Yöneticiler/öğretmenler/veliler: il/ilçe alfabetik
      //   • Öğrenciler en üstte, sonra yöneticiler/diğerleri
      function rolGrubu(r) {
        if (r === 'ogrenci' || r === 'demo') return 0;
        if (r === 'kurumsal' || r === 'moderator') return 1;
        if (r === 'ogretmen') return 2;
        if (r === 'veli') return 3;
        return 4;
      }
      function turkiyeSira(k) {
        // v4.3.61: siralamaCache cron'da { ...genel, dersSiralamalari } olarak
        // yayılarak yazılıyor — yani turkiye/il/ilce/okul doğrudan üst seviyede,
        // .genel.turkiye DEĞİL. Eski v4.3.60 kodu .genel.turkiye okuyordu →
        // her zaman null dönüyordu → TR# hep "—" görünüyordu.
        var sc = k.siralamaCache;
        if (sc && typeof sc.turkiye === 'number' && sc.turkiye > 0) return sc.turkiye;
        return null;
      }
      var siraliKullanicilar = [...filtreliKullanicilar].sort(function(a, b) {
        // Önce rol grubu (öğrenciler önce)
        var ga = rolGrubu(a.rol), gb = rolGrubu(b.rol);
        if (ga !== gb) return ga - gb;
        // Öğrenci grubu: Türkiye sırası
        if (ga === 0) {
          var ta = turkiyeSira(a), tb = turkiyeSira(b);
          if (ta !== null && tb !== null) {
            if (ta !== tb) return ta - tb;
          } else if (ta !== null) return -1;
          else if (tb !== null) return 1;
          else {
            // İkisi de niteliksiz: puana göre azalan
            var pa = a.puan || 0, pb = b.puan || 0;
            if (pa !== pb) return pb - pa;
          }
        }
        // Yöneticiler veya öğrenci eşit sırada: il/ilçe alfabetik
        var ilA = (a.il||'').toLowerCase(), ilB = (b.il||'').toLowerCase();
        if (ilA !== ilB) return ilA.localeCompare(ilB, 'tr');
        var ilceA = (a.ilce||'').toLowerCase(), ilceB = (b.ilce||'').toLowerCase();
        if (ilceA !== ilceB) return ilceA.localeCompare(ilceB, 'tr');
        return (a.kullaniciAdi||'').localeCompare(b.kullaniciAdi||'', 'tr');
      });
    %>
    <table class="tablo">
      <thead><tr><th style="width:40px;">TR#</th><th>Kullanıcı Adı</th><th>Sınıf</th><th>İl</th><th>İlçe</th><th>Okul</th><th>Çözülen</th><th>Puan</th><th>İşlem</th></tr></thead>
      <tbody>
        <% siraliKullanicilar.forEach(function(k) {
            var ts = turkiyeSira(k);
        %>
          <tr>
            <td style="text-align:center; color:#888; font-size:12px; font-weight:600;">
              <% if (k.rol === 'ogrenci' || k.rol === 'demo') { %>
                <% if (ts) { %><%= ts %><% } else { %>—<% } %>
              <% } else { %>—<% } %>
            </td>
            <td>
              <%= k.kullaniciAdi %>
              <% if (k.rol === 'moderator') { %><span style="background:#e8f0fe; color:#1a73e8; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">MOD</span><% } %>
              <% if (k.rol === 'ogretmen') { %><span style="background:#f3e5f5; color:#6a1b9a; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">👩‍🏫 ÖĞRETMEN</span><% } %>
              <% if (k.rol === 'kurumsal') { %><span style="background:#e0f2f1; color:#00695c; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">🏛️ YÖNETİCİ</span><% } %>
              <% if (k.rol === 'veli') { %><span style="background:#fff3e0; color:#e65100; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">👪 VELİ</span><% } %>
              <% if (k.rol === 'demo') { %><span style="background:#ede7f6; color:#5e35b1; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">🧪 DEMO</span><% } %>
            </td>
            <td style="text-align:center;"><% if (k.rol === 'ogretmen') { %><span style="background:#f3e5f5; color:#6a1b9a; font-size:10px; font-weight:700; padding:2px 7px; border-radius:10px;">ÖĞR</span><% } else if (k.rol === 'kurumsal') { %><span style="background:#e0f2f1; color:#00695c; font-size:10px; font-weight:700; padding:2px 7px; border-radius:10px;">YÖN</span><% } else if (k.rol === 'veli') { %><span style="background:#fff3e0; color:#e65100; font-size:10px; font-weight:700; padding:2px 7px; border-radius:10px;">VELİ</span><% } else if (k.rol === 'demo') { %><span style="background:#ede7f6; color:#5e35b1; font-size:10px; font-weight:700; padding:2px 7px; border-radius:10px;">DEMO</span><% } else { %><%= k.sinif %><% } %></td>
            <td><%= k.il||'-' %></td>
            <td><%= k.ilce||'-' %></td>
            <td><%= k.okul||'-' %></td>
            <td style="text-align:center;"><%= k.soruIndex %></td>
            <td style="text-align:center; font-weight:bold; color:#1a73e8;"><%= puanFmt(k.puan) %></td>
            <td style="text-align:center; display:flex; gap:4px; flex-wrap:wrap; justify-content:center;">
              <a href="/kullanici-detay?kullaniciAdi=<%= encodeURIComponent(k.kullaniciAdi) %>" class="admin-btn admin-btn-onizle" style="font-size:10px; padding:3px 8px;">📊 Detay</a>
              <a href="/panel/<%= encodeURIComponent(k.kullaniciAdi) %>?mod=profil" class="admin-btn admin-btn-duzenle" style="font-size:10px; padding:3px 8px;">👁️ Profil</a>
              <form action="/kullanici-rol" method="POST" style="display:inline;">
                <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
                <input type="hidden" name="il" value="<%= filIl %>">
                <input type="hidden" name="ilce" value="<%= filIlce %>">
                <input type="hidden" name="okul" value="<%= filOkul %>">
                <button class="admin-btn <%= k.rol === 'moderator' ? 'admin-btn-sil' : 'admin-btn-duzenle' %>" style="font-size:10px; padding:3px 8px;">
                  <%= k.rol === 'moderator' ? '🔓 Mod Al' : '🔑 Mod Ver' %>
                </button>
              </form>
              <form action="/kullanici-sil" method="POST" style="display:inline;">
                <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
                <input type="hidden" name="il" value="<%= filIl %>">
                <input type="hidden" name="ilce" value="<%= filIlce %>">
                <input type="hidden" name="okul" value="<%= filOkul %>">
                <button onclick="return confirm('<%= k.kullaniciAdi %> silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <!-- Yasaklı İsimler -->
  <div class="admin-card" style="margin-top:16px;">
    <div class="admin-card-title">
      🚫 Yasaklı İsimler
      <span style="font-size:12px; color:#888; font-weight:400;">— Tek başına kullanılamayacak kullanıcı adları</span>
    </div>
    <form action="/yasakli-ekle" method="POST" style="display:flex; gap:8px; margin-bottom:14px;">
      <input type="text" name="kelime" placeholder="Yasaklanacak kelime..." required
        style="flex:1; padding:8px 12px; border:1.5px solid #eaecf0; border-radius:8px; font-size:13px; background:#fafbfc; outline:none;">
      <button class="ekle-btn" style="padding:8px 16px;">+ Ekle</button>
    </form>
    <% if (yasakliKelimeler && yasakliKelimeler.length > 0) { %>
    <div style="display:flex; flex-wrap:wrap; gap:6px;">
      <% yasakliKelimeler.forEach(function(y) { %>
        <div style="display:inline-flex; align-items:center; gap:6px; background:#ffebee; border:1px solid #ffcdd2; border-radius:20px; padding:4px 12px; font-size:13px; color:#c62828; font-weight:500;">
          <%= y.kelime %>
          <form action="/yasakli-sil" method="POST" style="display:inline; margin:0;">
            <input type="hidden" name="id" value="<%= y._id %>">
            <button type="submit" style="background:none; border:none; cursor:pointer; color:#c62828; font-size:14px; line-height:1; padding:0; margin:0;" title="Kaldır">×</button>
          </form>
        </div>
      <% }); %>
    </div>
    <% } else { %>
      <p style="font-size:13px; color:#aaa;">Henüz yasaklı kelime eklenmemiş.</p>
    <% } %>
  </div>

<% } else if (mod === 'uniteler') { %>

<!-- ── Ünite / Konu Yönetimi ── -->
<div class="card">
  <h3>📚 Ünite ve Konu Yönetimi</h3>
  <p style="color:#666; font-size:13px; margin-bottom:16px;">
    Excel şablonunu indirin, doldurun ve yükleyin. Satır ve sütun yapısına göre otomatik okunur.
  </p>

  <!-- Şablon İndir -->
  <a href="/unite-sablon-indir" class="btn" style="background:#1a73e8; color:white; margin-bottom:16px; display:inline-block;">
    📥 Excel Şablonunu İndir
  </a>

  <!-- Yükleme Alanı -->
  <div style="border:2px dashed #1a73e8; border-radius:10px; padding:30px; text-align:center; background:#f8f9ff; cursor:pointer; margin-bottom:16px;" id="excelDropZone">
    <div style="font-size:32px; margin-bottom:6px;">📊</div>
    <div style="color:#1a73e8; font-weight:bold; margin-bottom:4px;">Excel dosyasını buraya sürükleyin veya tıklayın</div>
    <div style="color:#888; font-size:13px;">.xlsx veya .xls — Maks 5 MB</div>
    <input type="file" id="excelInput" accept=".xlsx,.xls" style="display:none;">
  </div>

  <div id="excelSecilenDosya" style="display:none; padding:10px 14px; background:#e8f5e9; border-radius:8px; margin-bottom:12px;">
    ✅ <span id="excelDosyaAd" style="font-weight:500;"></span>
  </div>

  <div style="display:flex; gap:10px; align-items:center; margin-bottom:12px; flex-wrap:wrap;">
    <label style="font-size:13px; color:#666;">Kayıt modu:</label>
    <label style="font-size:13px; cursor:pointer;">
      <input type="radio" name="kayitMod" value="ekle" checked> Mevcut ünitelere ekle
    </label>
    <label style="font-size:13px; cursor:pointer;">
      <input type="radio" name="kayitMod" value="sifirla"> Tümünü sil, yeniden yükle
    </label>
  </div>

  <button id="excelAnalizBtn" onclick="excelAnalizBaslat()" class="btn btn-success" style="display:none;">📊 Analiz Et ve Önizle</button>
  <div id="excelHata" style="display:none; padding:10px; background:#ffebee; border:1px solid #ef9a9a; border-radius:8px; color:#c62828; margin-top:10px;"></div>
</div>

<!-- v4.8.17: Manuel Ünite Ekle -->
<div class="card" style="margin-top:16px;">
  <h3>➕ Manuel Ünite Ekle</h3>
  <p style="color:#666; font-size:13px; margin-bottom:12px;">Excel'e gerek kalmadan tek ünite ekle. Konuları her satıra bir tane (veya virgülle ayırarak) yaz.</p>
  <form method="POST" action="/unite-ekle">
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-bottom:10px;">
      <label style="font-size:13px;">Sınıf<br><input type="number" name="sinif" min="1" max="12" placeholder="7" style="width:80px; padding:7px 9px; border:1px solid #ccc; border-radius:6px;"></label>
      <label style="font-size:13px;">Ders<br><input type="text" name="ders" placeholder="Matematik" required style="width:170px; padding:7px 9px; border:1px solid #ccc; border-radius:6px;"></label>
      <label style="font-size:13px;">Ünite No<br><input type="number" name="uniteNo" min="0" placeholder="1" style="width:90px; padding:7px 9px; border:1px solid #ccc; border-radius:6px;"></label>
      <label style="font-size:13px; flex:1; min-width:220px;">Ünite Adı<br><input type="text" name="uniteAdi" placeholder="Tam Sayılar" required style="width:100%; padding:7px 9px; border:1px solid #ccc; border-radius:6px; box-sizing:border-box;"></label>
    </div>
    <label style="font-size:13px; display:block; margin-bottom:10px;">Konular (her satıra bir konu veya virgülle)<br>
      <textarea name="konularMetin" rows="4" placeholder="Tam Sayılarla İşlemler&#10;Mutlak Değer" style="width:100%; padding:8px 10px; border:1px solid #ccc; border-radius:6px; box-sizing:border-box; font-family:inherit;"></textarea>
    </label>
    <button type="submit" class="btn btn-success">💾 Üniteyi Kaydet</button>
  </form>
</div>

<!-- Önizleme -->
<div id="excelOnizleme" style="display:none;">
  <div class="card" style="background:#e8f5e9; border-color:#a5d6a7;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
      <div>
        <b style="color:#2e7d32;">✅ <span id="excelToplamUnite"></span> ünite, <span id="excelToplamKonu"></span> konu bulundu</b>
        <p style="color:#555; font-size:13px; margin-top:4px;">Kontrol edin, ardından kaydedin.</p>
      </div>
      <button onclick="excelKaydet()" class="btn btn-success">💾 Veritabanına Kaydet</button>
    </div>
  </div>
  <div id="excelOnizlemeListesi"></div>
</div>

<!-- Mevcut Üniteler Listesi -->
<div class="card" style="margin-top:16px;">
  <h3>Kayıtlı Üniteler (<%= tumUniteler.length %>)</h3>
  <% if (tumUniteler.length === 0) { %>
    <p style="color:#888; font-size:13px;">Henüz ünite eklenmemiş.</p>
  <% } else { %>
    <table class="tablo">
      <thead><tr><th>Sınıf</th><th>Ünite No</th><th>Ders</th><th>Ünite Adı</th><th>Konu Sayısı</th><th>Konular</th><th>İşlem</th></tr></thead>
      <tbody>
        <% tumUniteler.forEach(function(u) { %>
          <tr>
            <td style="text-align:center;"><%= u.sinif||"-" %></td>
            <td style="text-align:center;"><%= u.uniteNo %></td>
            <td><%= u.ders %></td>
            <td><b><%= u.uniteAdi %></b></td>
            <td style="text-align:center;"><%= u.konular.length %></td>
            <td style="font-size:12px; color:#666;"><%= u.konular.join(', ') %></td>
            <td style="text-align:center; white-space:nowrap;">
              <button type="button" onclick="uniteDuzenleAc('<%= u._id %>')" class="btn" style="background:#1a73e8; color:white; padding:4px 10px; font-size:12px; margin-right:4px;">DÜZENLE</button>
              <form action="/unite-sil" method="POST" style="display:inline;">
                <input type="hidden" name="id" value="<%= u._id %>">
                <button onclick="return confirm('Bu ünite silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
          <!-- v4.3.26: Düzenleme satırı (gizli, JS ile açılır) -->
          <tr id="duzenle-satir-<%= u._id %>" style="display:none; background:#f0f7ff;">
            <td colspan="7" style="padding:14px 18px;">
              <form action="/unite-guncelle" method="POST">
                <input type="hidden" name="id" value="<%= u._id %>">
                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(140px, 1fr)); gap:10px; margin-bottom:10px;">
                  <div>
                    <label style="font-size:11px; color:#666; font-weight:600; display:block; margin-bottom:3px;">Sınıf</label>
                    <input type="text" name="sinif" value="<%= u.sinif||'' %>" class="input-sm" style="width:100%;">
                  </div>
                  <div>
                    <label style="font-size:11px; color:#666; font-weight:600; display:block; margin-bottom:3px;">Ders</label>
                    <input type="text" name="ders" value="<%= u.ders||'' %>" class="input-sm" style="width:100%;" required>
                  </div>
                  <div>
                    <label style="font-size:11px; color:#666; font-weight:600; display:block; margin-bottom:3px;">Ünite No</label>
                    <input type="number" name="uniteNo" value="<%= u.uniteNo||0 %>" class="input-sm" style="width:100%;">
                  </div>
                  <div style="grid-column:span 2;">
                    <label style="font-size:11px; color:#666; font-weight:600; display:block; margin-bottom:3px;">Ünite Adı</label>
                    <input type="text" name="uniteAdi" value="<%= u.uniteAdi||'' %>" class="input-sm" style="width:100%;" required>
                  </div>
                </div>
                <div style="margin-bottom:10px;">
                  <label style="font-size:11px; color:#666; font-weight:600; display:block; margin-bottom:3px;">Konular (her satıra bir konu veya virgülle ayır)</label>
                  <textarea name="konularMetin" rows="4" class="input-sm" style="width:100%; resize:vertical; font-family:inherit;"><%= (u.konular||[]).join('\n') %></textarea>
                </div>
                <div style="display:flex; gap:8px;">
                  <button type="submit" class="btn btn-success" style="padding:6px 16px; font-size:13px;">💾 Kaydet</button>
                  <button type="button" onclick="uniteDuzenleKapat('<%= u._id %>')" class="btn" style="background:#eee; color:#666; padding:6px 16px; font-size:13px;">İptal</button>
                </div>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
var excelOnizlemeVeri = [];

// v4.3.26: Ünite düzenleme satırı aç/kapat
function uniteDuzenleAc(id) {
  var satir = document.getElementById('duzenle-satir-' + id);
  if (satir) satir.style.display = '';
}
function uniteDuzenleKapat(id) {
  var satir = document.getElementById('duzenle-satir-' + id);
  if (satir) satir.style.display = 'none';
}

// Drag & Drop
(function() {
  var zone  = document.getElementById('excelDropZone');
  var input = document.getElementById('excelInput');
  zone.addEventListener('click', function() { input.click(); });
  zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.style.background='#e3f2fd'; });
  zone.addEventListener('dragleave', function() { zone.style.background='#f8f9ff'; });
  zone.addEventListener('drop', function(e) {
    e.preventDefault(); zone.style.background='#f8f9ff';
    if (e.dataTransfer.files[0]) excelDosyaSec(e.dataTransfer.files[0]);
  });
  input.addEventListener('change', function() { if (input.files[0]) excelDosyaSec(input.files[0]); });
})();

function excelDosyaSec(f) {
  document.getElementById('excelDosyaAd').textContent = f.name;
  document.getElementById('excelSecilenDosya').style.display = 'block';
  document.getElementById('excelAnalizBtn').style.display = 'inline-block';
  document.getElementById('excelHata').style.display = 'none';
  window._seciliExcel = f;
}

function excelAnalizBaslat() {
  if (!window._seciliExcel) return;
  var fd = new FormData();
  fd.append('excelDosyasi', window._seciliExcel);
  fetch('/unite-excel-yukle', {
    method: 'POST',
    headers: { 'Authorization': 'Basic <%- adminToken %>' },
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(v) {
    if (!v.ok) { gosterExcelHata(v.hata); return; }
    excelOnizlemeVeri = v.onizleme;
    document.getElementById('excelToplamUnite').textContent = v.toplamUnite;
    document.getElementById('excelToplamKonu').textContent = v.toplamKonu;
    var liste = document.getElementById('excelOnizlemeListesi');
    liste.innerHTML = '';
    v.onizleme.forEach(function(u) {
      var div = document.createElement('div');
      div.className = 'card';
      div.style.cssText = 'margin-bottom:8px; border-left:4px solid #1a73e8;';
      div.innerHTML = '<b style="color:#1a73e8;">' + u.uniteNo + '. ' + u.uniteAdi + '</b>' +
        '<span style="color:#888; font-size:12px; margin-left:8px;">(' + u.ders + (u.sinif ? ' · ' + u.sinif + '. sınıf' : '') + ')</span>' +
        '<div style="margin-top:6px; font-size:13px; color:#444;">' +
        u.konular.map(function(k,i){ return '<span style="background:#f0f2f5; border-radius:4px; padding:2px 8px; margin:2px; display:inline-block;">' + (i+1) + '. ' + k + '</span>'; }).join('') +
        '</div>';
      liste.appendChild(div);
    });
    document.getElementById('excelOnizleme').style.display = 'block';
  })
  ['catch'](function(e) { gosterExcelHata(e.message); });
}

function excelKaydet() {
  if (!excelOnizlemeVeri.length) return;
  var mod = document.querySelector('input[name="kayitMod"]:checked').value;
  var onay = mod === 'sifirla'
    ? 'Tüm mevcut üniteler silinip yenileri yüklenecek. Emin misiniz?'
    : excelOnizlemeVeri.length + ' ünite eklenecek. Onaylıyor musunuz?';
  if (!confirm(onay)) return;
  fetch('/unite-kaydet', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic <%- adminToken %>' },
    body: JSON.stringify({ uniteler: excelOnizlemeVeri, mod: mod })
  })
  .then(function(r) { return r.json(); })
  .then(function(v) {
    if (!v.ok) { gosterExcelHata(v.hata); return; }
    alert(v.kaydedilen + ' ünite başarıyla kaydedildi!');
    window.location.reload();
  })
  ['catch'](function(e) { gosterExcelHata(e.message); });
}

function gosterExcelHata(msg) {
  var k = document.getElementById('excelHata');
  k.textContent = '⚠️ ' + msg;
  k.style.display = 'block';
}
</script>

<% } else if (mod === 'konuIzinleri') { %>
<div class="admin-card">
  <div class="admin-card-title">🔓 Konu İzinleri</div>
  <p style="font-size:13px; color:#666; line-height:1.5; margin:0 0 14px;">
    Öğrencilere hangi ünite/konulardan soru geleceğini buradan açıp kapatabilirsin.
    <b>Varsayılan: tüm konular AÇIK.</b> Kapattığın konular öğrencilere gelmez
    (öğretmen / kurumsal / demo hesapları tüm soruları görmeye devam eder).
    Liste “Üniteler” menündeki sınıf / ders / ünite / konulardan çekilir.
  </p>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:14px;">
    <label style="font-size:13px;">Sınıf:
      <select id="kiSinifFiltre" onchange="kiCiz()" style="padding:5px 8px; border:1px solid #ccc; border-radius:6px;"><option value="">Tümü</option></select>
    </label>
    <button type="button" class="btn" onclick="kiHepsi(true)">Hepsini Aç</button>
    <button type="button" class="btn" onclick="kiHepsi(false)">Hepsini Kapat</button>
    <span id="kiOzet" style="margin-left:auto; font-size:12px; color:#888;"></span>
  </div>
  <div id="kiAgac" style="max-height:60vh; overflow:auto;">Yükleniyor…</div>
  <div style="margin-top:16px; display:flex; gap:10px; align-items:center;">
    <button type="button" class="btn btn-success" onclick="kiKaydet()">💾 Kaydet</button>
    <span id="kiDurum" style="font-size:13px;"></span>
  </div>
</div>
<script>
(function(){
  var VERI=[], DURUM={};
  function key(s,d,u,k){ return s+'|'+d+'|'+u+'|'+k; }
  function esc(x){ return String(x==null?'':x).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;'); }
  function yukle(){
    fetch('/admin/konu-izinleri-veri', {credentials:'same-origin'})
      .then(function(r){ return r.json(); })
      .then(function(d){
        VERI=(d&&d.ok&&d.agac)?d.agac:[]; DURUM={};
        VERI.forEach(function(u){ (u.konular||[]).forEach(function(kn){ DURUM[key(u.sinif,u.ders,u.unite,kn.konu)] = kn.acik!==false; }); });
        var sel=document.getElementById('kiSinifFiltre'), ss={};
        VERI.forEach(function(u){ if(u.sinif) ss[u.sinif]=1; });
        Object.keys(ss).sort(function(a,b){return Number(a)-Number(b);}).forEach(function(s){ var o=document.createElement('option'); o.value=s; o.textContent=s+'. Sınıf'; sel.appendChild(o); });
        kiCiz();
      })
      .catch(function(e){ document.getElementById('kiAgac').innerHTML='<span style=\"color:#c62828;\">Yüklenemedi: '+esc(e.message)+'</span>'; });
  }
  function kiCiz(){
    var filtre=document.getElementById('kiSinifFiltre').value;
    var hedef=document.getElementById('kiAgac');
    var liste=VERI.filter(function(u){ return !filtre || String(u.sinif)===filtre; });
    if(!liste.length){ hedef.innerHTML='<p style=\"color:#888;\">Bu filtrede ünite yok. Önce “Üniteler” menüsünden sınıf/ders/ünite/konu tanımla.</p>'; kiOzetGuncelle(); return; }
    var html='', bySinif={};
    liste.forEach(function(u){ (bySinif[u.sinif]=bySinif[u.sinif]||[]).push(u); });
    Object.keys(bySinif).sort(function(a,b){return Number(a)-Number(b);}).forEach(function(sin){
      html+='<div style=\"margin-bottom:18px;\"><div style=\"font-weight:700; color:#333; margin-bottom:6px;\">'+esc(sin)+'. Sınıf</div>';
      var byDers={};
      bySinif[sin].forEach(function(u){ (byDers[u.ders]=byDers[u.ders]||[]).push(u); });
      Object.keys(byDers).sort().forEach(function(ders){
        html+='<div style=\"margin:0 0 10px 10px;\"><div style=\"font-weight:600; color:#555; margin-bottom:4px;\">'+esc(ders)+'</div>';
        byDers[ders].sort(function(a,b){return (a.uniteNo||0)-(b.uniteNo||0);}).forEach(function(u){
          html+='<div style=\"border:1px solid #eee; border-radius:8px; padding:8px 10px; margin:0 0 6px 10px;\">';
          html+='<label style=\"font-weight:600; display:flex; align-items:center; gap:6px; cursor:pointer;\"><input type=\"checkbox\" class=\"ki-unite\" data-sinif=\"'+esc(u.sinif)+'\" data-ders=\"'+esc(u.ders)+'\" data-unite=\"'+esc(u.unite)+'\"> '+(u.uniteNo?esc(u.uniteNo)+'. ':'')+esc(u.unite)+'</label>';
          html+='<div style=\"margin:6px 0 0 22px; display:flex; flex-wrap:wrap; gap:6px 16px;\">';
          (u.konular||[]).forEach(function(kn){
            var kk=key(u.sinif,u.ders,u.unite,kn.konu);
            html+='<label style=\"display:flex; align-items:center; gap:5px; font-size:13px; cursor:pointer;\"><input type=\"checkbox\" class=\"ki-konu\" data-key=\"'+esc(kk)+'\"'+(DURUM[kk]?' checked':'')+'> '+esc(kn.konu)+'</label>';
          });
          html+='</div></div>';
        });
        html+='</div>';
      });
      html+='</div>';
    });
    hedef.innerHTML=html;
    hedef.querySelectorAll('.ki-unite').forEach(function(cb){
      senkronUnite(cb);
      cb.addEventListener('change', function(){
        var pre=cb.getAttribute('data-sinif')+'|'+cb.getAttribute('data-ders')+'|'+cb.getAttribute('data-unite')+'|';
        hedef.querySelectorAll('.ki-konu').forEach(function(k){ if(k.getAttribute('data-key').indexOf(pre)===0){ k.checked=cb.checked; DURUM[k.getAttribute('data-key')]=cb.checked; } });
        cb.indeterminate=false; kiOzetGuncelle();
      });
    });
    hedef.querySelectorAll('.ki-konu').forEach(function(cb){
      cb.addEventListener('change', function(){ DURUM[cb.getAttribute('data-key')]=cb.checked; senkronTumUniteler(); kiOzetGuncelle(); });
    });
    kiOzetGuncelle();
  }
  function senkronUnite(cb){
    var hedef=document.getElementById('kiAgac');
    var pre=cb.getAttribute('data-sinif')+'|'+cb.getAttribute('data-ders')+'|'+cb.getAttribute('data-unite')+'|';
    var konular=[].slice.call(hedef.querySelectorAll('.ki-konu')).filter(function(k){ return k.getAttribute('data-key').indexOf(pre)===0; });
    var acik=konular.filter(function(k){return k.checked;}).length;
    cb.checked = konular.length>0 && acik===konular.length;
    cb.indeterminate = acik>0 && acik<konular.length;
  }
  function senkronTumUniteler(){ document.getElementById('kiAgac').querySelectorAll('.ki-unite').forEach(senkronUnite); }
  function kiOzetGuncelle(){ var t=0,a=0; Object.keys(DURUM).forEach(function(kk){ t++; if(DURUM[kk]) a++; }); document.getElementById('kiOzet').textContent=t+' konu · '+a+' açık · '+(t-a)+' kapalı'; }
  window.kiCiz=kiCiz;
  window.kiHepsi=function(acik){ Object.keys(DURUM).forEach(function(kk){ DURUM[kk]=acik; }); kiCiz(); };
  window.kiKaydet=function(){
    var kapalilar=[];
    Object.keys(DURUM).forEach(function(kk){ if(!DURUM[kk]){ var p=kk.split('|'); kapalilar.push({sinif:p[0],ders:p[1],unite:p[2],konu:p.slice(3).join('|')}); } });
    var d=document.getElementById('kiDurum'); d.style.color='#555'; d.textContent='Kaydediliyor…';
    fetch('/admin/konu-izinleri-kaydet', { method:'POST', credentials:'same-origin', headers:{'Content-Type':'application/json'}, body: JSON.stringify({kapalilar:kapalilar}) })
      .then(function(r){ return r.json(); })
      .then(function(res){ if(res&&res.ok){ d.style.color='#1a7f37'; d.textContent='✓ Kaydedildi ('+res.kapaliSayisi+' konu kapalı).'; } else { d.style.color='#c62828'; d.textContent='Hata: '+((res&&res.hata)||'bilinmiyor'); } })
      .catch(function(e){ d.style.color='#c62828'; d.textContent='Hata: '+e.message; });
  };
  yukle();
})();
</script>

<% } else if (mod === 'soruDagilim') { %>
<div class="admin-card">
  <div class="admin-card-title">📊 Soru Dağılımı</div>
  <p style="font-size:13px; color:#666; line-height:1.5; margin:0 0 14px;">
    Her sınıf / ders / ünite / konu için kaç soru olduğunu gösterir (0 olanlar dahil).
    Liste "Üniteler" menündeki yapıdan üretilir. Üstteki menülerden filtreleyebilirsin.
  </p>
  <div style="display:flex; gap:8px; flex-wrap:wrap; align-items:center; margin-bottom:14px;">
    <select id="sdSinif" onchange="sdSinifDegisti()" style="padding:5px 8px; border:1px solid #ccc; border-radius:6px; font-size:13px;"><option value="">Tüm sınıflar</option></select>
    <select id="sdDers" onchange="sdDersDegisti()" style="padding:5px 8px; border:1px solid #ccc; border-radius:6px; font-size:13px;"><option value="">Tüm dersler</option></select>
    <select id="sdUnite" onchange="sdUniteDegisti()" style="padding:5px 8px; border:1px solid #ccc; border-radius:6px; font-size:13px;"><option value="">Tüm üniteler</option></select>
    <select id="sdKonu" onchange="sdCiz()" style="padding:5px 8px; border:1px solid #ccc; border-radius:6px; font-size:13px;"><option value="">Tüm konular</option></select>
    <button type="button" class="btn" onclick="sdSifirla()">Temizle</button>
    <span id="sdOzet" style="margin-left:auto; font-size:12px; color:#888;"></span>
  </div>
  <div id="sdTablo" style="max-height:60vh; overflow:auto;">Yükleniyor…</div>
</div>
<script>
(function(){
  var VERI=[];
  function esc(x){ return String(x==null?'':x).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function uniq(arr){ var s={},o=[]; arr.forEach(function(x){ if(x!==undefined&&x!==null&&x!==''&&!s[x]){s[x]=1;o.push(x);} }); return o; }
  function val(id){ return document.getElementById(id).value; }
  function opt(sel, list, hepsi){ var cur=sel.value; sel.innerHTML='<option value="">'+hepsi+'</option>'+list.map(function(x){return '<option value="'+esc(x)+'">'+esc(x)+'</option>';}).join(''); sel.value=(list.indexOf(cur)>=0)?cur:''; }
  function yukle(){
    fetch('/admin/soru-dagilim-veri',{credentials:'same-origin'})
      .then(function(r){return r.json();})
      .then(function(d){
        VERI=(d&&d.ok&&d.satirlar)?d.satirlar:[];
        window.__sdMeta={toplamDB:(d&&d.toplamDB)||0, yayindaDB:(d&&d.yayindaDB)||0, eslesmeyen:(d&&d.eslesmeyen)||0};
        opt(document.getElementById('sdSinif'), uniq(VERI.map(function(r){return r.sinif;})).sort(function(a,b){return Number(a)-Number(b);}), 'Tüm sınıflar');
        sdSinifDegisti();
      })
      .catch(function(e){ document.getElementById('sdTablo').innerHTML='<span style="color:#c62828;">Yüklenemedi: '+esc(e.message)+'</span>'; });
  }
  window.sdSinifDegisti=function(){
    var s=val('sdSinif');
    opt(document.getElementById('sdDers'), uniq(VERI.filter(function(r){return !s||r.sinif===s;}).map(function(r){return r.ders;})).sort(), 'Tüm dersler');
    sdDersDegisti();
  };
  window.sdDersDegisti=function(){
    var s=val('sdSinif'), d=val('sdDers');
    opt(document.getElementById('sdUnite'), uniq(VERI.filter(function(r){return (!s||r.sinif===s)&&(!d||r.ders===d);}).map(function(r){return r.unite;})).sort(), 'Tüm üniteler');
    sdUniteDegisti();
  };
  window.sdUniteDegisti=function(){
    var s=val('sdSinif'), d=val('sdDers'), u=val('sdUnite');
    opt(document.getElementById('sdKonu'), uniq(VERI.filter(function(r){return (!s||r.sinif===s)&&(!d||r.ders===d)&&(!u||r.unite===u);}).map(function(r){return r.konu;})).sort(), 'Tüm konular');
    sdCiz();
  };
  window.sdSifirla=function(){ ['sdSinif','sdDers','sdUnite','sdKonu'].forEach(function(id){document.getElementById(id).value='';}); sdSinifDegisti(); };
  window.sdCiz=function(){
    var s=val('sdSinif'),d=val('sdDers'),u=val('sdUnite'),k=val('sdKonu');
    var rows=VERI.filter(function(r){return (!s||r.sinif===s)&&(!d||r.ders===d)&&(!u||r.unite===u)&&(!k||r.konu===k);});
    var tT=0,tY=0; rows.forEach(function(r){tT+=r.toplam;tY+=r.yayinda;});
    var meta=window.__sdMeta||{};
    document.getElementById('sdOzet').textContent = rows.length+' konu · '+tT+' soru ('+tY+' yayında)';
    var html='<table style="width:100%; border-collapse:collapse; font-size:13px;">';
    html+='<thead><tr style="background:#f5f5f5; text-align:left;"><th style="padding:6px 8px;">Sınıf</th><th style="padding:6px 8px;">Ders</th><th style="padding:6px 8px;">Ünite</th><th style="padding:6px 8px;">Konu</th><th style="padding:6px 8px; text-align:right;">Toplam</th><th style="padding:6px 8px; text-align:right;">Yayında</th></tr></thead><tbody>';
    if(!rows.length){ html+='<tr><td colspan="6" style="padding:12px; color:#888;">Kayıt yok.</td></tr>'; }
    rows.forEach(function(r){
      var renk = r.toplam===0 ? 'color:#c62828; font-weight:600;' : '';
      html+='<tr style="border-bottom:1px solid #eee;"><td style="padding:6px 8px;">'+esc(r.sinif)+'</td><td style="padding:6px 8px;">'+esc(r.ders)+'</td><td style="padding:6px 8px;">'+(r.uniteNo?esc(r.uniteNo)+'. ':'')+esc(r.unite)+'</td><td style="padding:6px 8px;">'+esc(r.konu)+'</td><td style="padding:6px 8px; text-align:right; '+renk+'">'+r.toplam+'</td><td style="padding:6px 8px; text-align:right;">'+r.yayinda+'</td></tr>';
    });
    html+='</tbody><tfoot><tr style="background:#fafafa; font-weight:600; border-top:2px solid #ddd;"><td colspan="4" style="padding:6px 8px; text-align:right;">Toplam</td><td style="padding:6px 8px; text-align:right;">'+tT+'</td><td style="padding:6px 8px; text-align:right;">'+tY+'</td></tr></tfoot></table>';
    if(meta.eslesmeyen){ html+='<p style="font-size:12px; color:#e65100; margin-top:10px;">⚠️ '+meta.eslesmeyen+' soru tanımlı bir ünite/konuya eşleşmiyor (raporda görünmez). Bu soruların sınıf/ders/ünite/konu adlarını Üniteler ile birebir aynı yap.</p>'; }
    document.getElementById('sdTablo').innerHTML=html;
  };
  yukle();
})();
</script>

<% } else if (mod === 'okullar') { %>

  <!-- Excel'den Toplu Okul Yükleme -->
  <div class="card" style="margin-bottom:16px;">
    <h3>📊 Excel'den Toplu Okul Yükleme</h3>
    <p style="color:#666; font-size:13px; margin-bottom:12px;">
      Excel formatı: <b>A sütunu</b> = İl, <b>B sütunu</b> = İlçe, <b>C sütunu</b> = Okul Adı (1. satır başlık)
    </p>
    <div id="okulDropZone" style="border:2px dashed #1a73e8; border-radius:10px; padding:24px; text-align:center; background:#f8f9ff; cursor:pointer; margin-bottom:10px;">
      <div style="font-size:28px; margin-bottom:4px;">📊</div>
      <div style="color:#1a73e8; font-weight:bold; margin-bottom:2px;">Excel dosyasını buraya sürükleyin veya tıklayın</div>
      <div style="color:#888; font-size:12px;">.xlsx veya .xls — Maks 5 MB</div>
      <input type="file" id="okulExcelInput" accept=".xlsx,.xls" style="display:none;">
    </div>
    <div id="okulSecilenDosya" style="display:none; padding:8px 12px; background:#e8f5e9; border-radius:6px; margin-bottom:10px;">
      ✅ <span id="okulDosyaAd" style="font-weight:500;"></span>
    </div>
    <div style="display:flex; gap:12px; align-items:center; margin-bottom:10px; flex-wrap:wrap;">
      <label style="font-size:13px; color:#666;">Kayıt modu:</label>
      <label style="font-size:13px; cursor:pointer;"><input type="radio" name="okulMod" value="ekle" checked> Mevcut okullara ekle (tekrar olanları atla)</label>
      <label style="font-size:13px; cursor:pointer;"><input type="radio" name="okulMod" value="sifirla"> Tümünü sil, yeniden yükle</label>
    </div>
    <button id="okulAnalizBtn" onclick="okulExcelAnalizBaslat()" class="btn btn-success" style="display:none;">📊 Analiz Et ve Önizle</button>
    <div id="okulHata" style="display:none; padding:10px; background:#ffebee; border:1px solid #ef9a9a; border-radius:6px; color:#c62828; margin-top:8px;"></div>
  </div>

  <!-- Önizleme -->
  <div id="okulOnizleme" style="display:none;" class="card" style="margin-bottom:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; background:#e8f5e9; padding:12px; border-radius:8px; margin-bottom:10px;">
      <b style="color:#2e7d32;">✅ <span id="okulToplamSayi"></span> okul bulundu</b>
      <button onclick="okulExcelKaydet()" class="btn btn-success">💾 Kaydet</button>
    </div>
    <div id="okulOnizlemeTablosu" style="max-height:300px; overflow-y:auto;">
      <table class="tablo">
        <thead><tr><th>İl</th><th>İlçe</th><th>Okul Adı</th></tr></thead>
        <tbody id="okulOnizlemeSatirlar"></tbody>
      </table>
    </div>
  </div>

  <script>
  var _okulOnizlemeVeri = [];
  (function(){
    var zone = document.getElementById('okulDropZone');
    var input = document.getElementById('okulExcelInput');
    zone.addEventListener('click', function(){ input.click(); });
    zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.style.background='#e3f2fd'; });
    zone.addEventListener('dragleave', function(){ zone.style.background='#f8f9ff'; });
    zone.addEventListener('drop', function(e){
      e.preventDefault(); zone.style.background='#f8f9ff';
      if(e.dataTransfer.files[0]) okulDosyaSec(e.dataTransfer.files[0]);
    });
    input.addEventListener('change', function(){ if(input.files[0]) okulDosyaSec(input.files[0]); });
  })();

  function okulDosyaSec(f) {
    document.getElementById('okulDosyaAd').textContent = f.name;
    document.getElementById('okulSecilenDosya').style.display = 'block';
    document.getElementById('okulAnalizBtn').style.display = 'inline-block';
    document.getElementById('okulHata').style.display = 'none';
    window._seciliOkulExcel = f;
  }

  function okulExcelAnalizBaslat() {
    if (!window._seciliOkulExcel) return;
    var fd = new FormData();
    fd.append('okulExcelDosyasi', window._seciliOkulExcel);
    fetch('/okul-excel-yukle', {
      method: 'POST',
      headers: { 'Authorization': 'Basic <%- adminToken %>' },
      body: fd
    })
    .then(function(r){ return r.json(); })
    .then(function(v){
      if (!v.ok) { document.getElementById('okulHata').textContent = '⚠️ ' + v.hata; document.getElementById('okulHata').style.display='block'; return; }
      _okulOnizlemeVeri = v.onizleme;
      document.getElementById('okulToplamSayi').textContent = v.toplam;
      var tbody = document.getElementById('okulOnizlemeSatirlar');
      // Sadece ilk 100 satırı göster — performans için
      var rows = '';
      var gosterilen = Math.min(v.onizleme.length, 100);
      for (var i = 0; i < gosterilen; i++) {
        var o = v.onizleme[i];
        rows += '<tr><td>'+o.il+'</td><td>'+o.ilce+'</td><td>'+o.ad+'</td></tr>';
      }
      if (v.onizleme.length > 100) {
        rows += '<tr><td colspan="3" style="text-align:center; color:#888; font-style:italic;">... ve ' + (v.onizleme.length - 100) + ' okul daha</td></tr>';
      }
      tbody.innerHTML = rows;
      document.getElementById('okulOnizleme').style.display = 'block';
    })
    ['catch'](function(e){ document.getElementById('okulHata').textContent = '⚠️ ' + e.message; document.getElementById('okulHata').style.display='block'; });
  }

  function okulExcelKaydet() {
    if (!_okulOnizlemeVeri.length) return;
    var mod = document.querySelector('input[name="okulMod"]:checked').value;
    var onay = mod === 'sifirla' ? 'Tüm okullar silinip yenileri yüklenecek. Emin misiniz?' : _okulOnizlemeVeri.length + ' okul eklenecek. Onaylıyor musunuz?';
    if (!confirm(onay)) return;
    fetch('/okul-excel-kaydet', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic <%- adminToken %>' },
      body: JSON.stringify({ okullar: _okulOnizlemeVeri, mod: mod })
    })
    .then(function(r){ return r.json(); })
    .then(function(v){
      if (!v.ok) { alert('Hata: ' + v.hata); return; }
      alert(v.eklenen + ' okul eklendi, ' + v.atlanan + ' tekrar atlandı.');
      window.location.reload();
    })
    ['catch'](function(e){ alert('Hata: ' + e.message); });
  }
  </script>

  <div class="card">
    <h3>Okul Yönetimi</h3>

    <!-- Yeni Okul Ekleme Formu -->
    <form action="/okul-ekle" method="POST" style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; align-items:flex-end;">
      <div><label class="form-label">İl</label><br><select name="il" id="adminIlSelect" onchange="adminIlDegisti()" required class="input-sm"><option value="">İl Seçiniz</option></select></div>
      <div><label class="form-label">İlçe</label><br><select name="ilce" id="adminIlceSelect" required class="input-sm"><option value="">İlçe Seçiniz</option></select></div>
      <div><label class="form-label">Okul Adı</label><br><input name="ad" placeholder="Okul adını giriniz" required style="padding:8px; border:1px solid #ddd; border-radius:6px; min-width:250px;"></div>
      <button type="submit" class="btn btn-success">EKLE</button>
    </form>

    <!-- Filtre -->
    <div style="display:flex; gap:10px; margin-bottom:15px; flex-wrap:wrap;">
      <select id="filIlSelect" onchange="filtrele()" class="input-sm"><option value="">Tüm İller</option></select>
      <select id="filIlceSelect" onchange="filtrele()" class="input-sm"><option value="">Tüm İlçeler</option></select>
    </div>

    <!-- Düzenleme Formu (gizli) -->
    <div id="duzenleForm" style="display:none; background:#fffbe6; border:1px solid #f0c040; border-radius:8px; padding:15px; margin-bottom:15px;">
      <b>Okul Düzenle</b>
      <form action="/okul-guncelle" method="POST" style="display:flex; gap:10px; margin-top:10px; flex-wrap:wrap; align-items:flex-end;">
        <input type="hidden" name="id" id="duzenleId">
        <div><label class="form-label">İl</label><br><input name="il" id="duzenleIl" class="input-sm" required></div>
        <div><label class="form-label">İlçe</label><br><input name="ilce" id="duzenleIlce" class="input-sm" required></div>
        <div><label class="form-label">Okul Adı</label><br><input name="ad" id="duzenleAd" style="padding:8px; border:1px solid #ddd; border-radius:6px; min-width:250px;" required></div>
        <button type="submit" class="btn btn-success">KAYDET</button>
        <button type="button" onclick="document.getElementById('duzenleForm').style.display='none'" class="btn" style="background:#888; color:white;">İPTAL</button>
      </form>
    </div>

    <table class="tablo" id="okulTablosu">
      <thead><tr><th>İl</th><th>İlçe</th><th>Okul Adı</th><th>İşlem</th></tr></thead>
      <tbody>
        <% tumOkullar.sort(function(a,b){ var ilc = a.ilce.localeCompare(b.ilce,'tr'); return ilc !== 0 ? ilc : a.ad.localeCompare(b.ad,'tr'); }).forEach(function(o) { %>
          <tr data-il="<%= o.il %>" data-ilce="<%= o.ilce %>">
            <td><%= o.il %></td>
            <td><%= o.ilce %></td>
            <td><%= o.ad %></td>
            <td style="text-align:center; white-space:nowrap;">
              <button onclick="duzenle('<%= o._id %>','<%= o.il %>','<%= o.ilce %>','<%= o.ad %>')" class="btn-duzenle">DÜZENLE</button>
              <form action="/okul-sil" method="POST" style="display:inline;">
                <input type="hidden" name="id" value="<%= o._id %>">
                <button onclick="return confirm('<%= o.ad %> silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <script>
  var adminIlIdMap = {};
  fetch('https://api.turkiyeapi.dev/v1/provinces')
    .then(function(r){ return r.json(); })
    .then(function(data) {
      var sel = document.getElementById('adminIlSelect');
      var filSel = document.getElementById('filIlSelect');
      (data.data||[]).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(il) {
        adminIlIdMap[il.name] = il.id;
        sel.innerHTML += '<option value="'+il.name+'">'+il.name+'</option>';
        filSel.innerHTML += '<option value="'+il.name+'">'+il.name+'</option>';
      });
    })
    .then(function(){})
    ['catch'](function(e){ console.log('İller yüklenemedi'); });

  function adminIlDegisti() {
    var ilAdi = document.getElementById('adminIlSelect').value;
    var ilceSelect = document.getElementById('adminIlceSelect');
    ilceSelect.innerHTML = '<option value="">İlçe Yükleniyor...</option>';
    var ilId = adminIlIdMap[ilAdi];
    if (!ilId) return;
    fetch('https://api.turkiyeapi.dev/v1/provinces/'+ilId)
      .then(function(r){ return r.json(); })
      .then(function(data) {
        ilceSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';
        ((data.data&&data.data.districts)||[]).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(ilce) {
          ilceSelect.innerHTML += '<option value="'+ilce.name+'">'+ilce.name+'</option>';
        });
      })
      ['catch'](function(e){ ilceSelect.innerHTML='<option>İlçeler yüklenemedi</option>'; });
  }

  function filtrele() {
    var secIl = document.getElementById('filIlSelect').value;
    var secIlce = document.getElementById('filIlceSelect').value;
    var satırlar = document.querySelectorAll('#okulTablosu tbody tr');

    // İlçe filtresini il'e göre güncelle
    var ilceSet = {};
    satırlar.forEach(function(tr) {
      if (!secIl || tr.getAttribute('data-il') === secIl) {
        ilceSet[tr.getAttribute('data-ilce')] = true;
      }
    });
    var filIlceSel = document.getElementById('filIlceSelect');
    var mevcutIlce = filIlceSel.value;
    filIlceSel.innerHTML = '<option value="">Tüm İlçeler</option>';
    Object.keys(ilceSet).sort(function(a,b){ return a.localeCompare(b,'tr'); }).forEach(function(ilce) {
      var opt = document.createElement('option');
      opt.value = ilce; opt.textContent = ilce;
      if (ilce === mevcutIlce) opt.selected = true;
      filIlceSel.appendChild(opt);
    });
    secIlce = filIlceSel.value;

    satırlar.forEach(function(tr) {
      var ilEsles = !secIl || tr.getAttribute('data-il') === secIl;
      var ilceEsles = !secIlce || tr.getAttribute('data-ilce') === secIlce;
      tr.style.display = (ilEsles && ilceEsles) ? '' : 'none';
    });
  }

  function duzenle(id, il, ilce, ad) {
    document.getElementById('duzenleId').value = id;
    document.getElementById('duzenleIl').value = il;
    document.getElementById('duzenleIlce').value = ilce;
    document.getElementById('duzenleAd').value = ad;
    document.getElementById('duzenleForm').style.display = 'block';
    document.getElementById('duzenleForm').scrollIntoView({ behavior: 'smooth' });
  }
  </script>

<% } else if (mod === 'haberler') { %>

  <div class="admin-card">
    <div class="admin-card-title" style="display:flex; justify-content:space-between; align-items:center;">
      <span>📰 Yeni Haber / Duyuru Ekle</span>
