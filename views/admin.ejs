          <p style="margin:0;">Şıklar (Doğru seçeneği işaretleyin):</p>
        </div>
        <% for (var i=0; i<4; i++) { %>
          <div class="sik-row" style="flex-wrap:wrap; gap:4px;">
            <div style="width:100%; display:flex; flex-wrap:wrap; gap:2px; align-items:center; background:#f8f9fa; border-radius:6px; padding:3px 6px; margin-bottom:2px;">
              <span style="font-size:10px; color:#aaa; margin-right:2px;">MAT:</span>
              <button type="button" onclick="ekle('sikMetin<%=i%>','<sup></sup>',6)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Üst simge">x²</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','<sub></sub>',6)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Alt simge">x₂</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','$\\sqrt{}$',8)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Karekök">√</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','$\\sqrt[3]{}$',11)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Küpkök">∛</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','$\\frac{}{}$',8)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Kesir">a/b</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','$\\pi$',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Pi">π</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','±',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">±</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','×',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">×</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','÷',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">÷</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','≤',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">≤</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','≥',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">≥</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','≠',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">≠</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','°',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;">°</button>
              <span style="display:inline-block;width:1px;height:16px;background:#ddd;margin:0 2px;vertical-align:middle;"></span>
              <button type="button" onclick="ekle('sikMetin<%=i%>','∠',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Açı">∠</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','△',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Üçgen">△</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','∈',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Eleman">∈</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','∪',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Birleşim">∪</button>
              <button type="button" onclick="ekle('sikMetin<%=i%>','∩',0)" class="toolbar-btn" style="padding:1px 5px; font-size:11px;" title="Kesişim">∩</button>
            </div>
            <b style="align-self:center;"><%= String.fromCharCode(65+i) %>:</b>
            <input name="metin<%= i %>" id="sikMetin<%= i %>" placeholder="Metin veya HTML" value="<%= editSoru&&editSoru.secenekler[i] ? editSoru.secenekler[i].metin : '' %>" style="flex:2;" required>
            <input name="gorsel<%= i %>" placeholder="Görsel URL" value="<%= editSoru&&editSoru.secenekler[i] ? editSoru.secenekler[i].gorsel : '' %>" style="flex:1;">
            <input type="radio" name="dogruCevap" value="<%= i %>" <%= editSoru&&editSoru.dogruCevapIndex===i ? 'checked' : '' %> required>
          </div>
        <% } %>
      </div>

      <!-- Tablo Şıkkı Oluşturucu Modal -->
      <div id="tabloModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">
        <div style="background:white; border-radius:12px; padding:24px; width:520px; max-width:95vw; max-height:90vh; overflow-y:auto;">
          <h3 style="margin:0 0 16px;">🔢 Tablo Şıkkı Oluştur</h3>

          <!-- Sütun başlıkları -->
          <div style="margin-bottom:12px;">
            <label class="form-label">Sütun sayısı (çuval sayısı)</label>
            <select id="tablo_sutunSayisi" class="input-sm" onchange="tabloGuncelle()" style="margin-left:8px;">
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4" selected>4</option>
              <option value="5">5</option>
              <option value="6">6</option>
            </select>
          </div>

          <div id="tablo_sutunBasliklari" style="margin-bottom:12px;"></div>

          <!-- 4 şık için değerler -->
          <div id="tablo_siklar"></div>

          <div style="display:flex; gap:10px; margin-top:16px;">
            <button type="button" onclick="tabloHtmlUret()" class="btn btn-success">Şıklara Uygula</button>
            <button type="button" onclick="document.getElementById('tabloModal').style.display='none'" class="btn" style="background:#888; color:white;">İptal</button>
          </div>
        </div>
      </div>
      <button type="submit" class="btn btn-success">KAYDET</button>
    </form>
  </div>
  <script>
  var _tumUniteler = [];
  // Düzenleme modunda mevcut değerler — EJS server-side inject
  var _editDers  = '<%- editSoru ? (editSoru.ders||"") : "" %>';
  var _editUnite = '<%- editSoru ? (editSoru.unite||"") : "" %>';
  var _editKonu  = '<%- editSoru ? (editSoru.konu||"") : "" %>';

  function sinifDegisti(hedefUnite, hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    fetch('/api/unite-bilgi?sinif=' + sinif)
      .then(function(r){ return r.json(); })
      .then(function(v){
        if (!v.ok) return;
        _tumUniteler = v.uniteler;
        var dersSelect = document.getElementById('se_ders');
        var mevcutDers = dersSelect.value;
        // Ünite verisi varsa ders listesini güncelle
        if (v.dersler.length) {
          // Koruma sırası: 1) mevcut seçili ders, 2) editSoru dersi, 3) Matematik
          var hedefDers = mevcutDers || _editDers || 'Matematik';
          dersSelect.innerHTML = '';
          v.dersler.forEach(function(d){
            var opt = document.createElement('option');
            opt.value = d; opt.textContent = d;
            if (d === hedefDers) opt.selected = true;
            dersSelect.appendChild(opt);
          });
          // Hiçbiri seçilmediyse ilkini seç
          if (!dersSelect.value) dersSelect.selectedIndex = 0;
        }
        dersDegisti(hedefUnite || '', hedefKonu || '');
      })
      ['catch'](function(){});
  }

  function dersDegisti(hedefUnite, hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    var ders  = document.getElementById('se_ders').value;
    var uniteSelect = document.getElementById('se_unite');
    // hedefUnite yoksa mevcut seçimi koru
    var secilenUnite = (hedefUnite !== undefined) ? hedefUnite : uniteSelect.value;
    uniteSelect.innerHTML = '<option value="">-- Ünite Seçin (Opsiyonel) --</option>';
    _tumUniteler
      .filter(function(u){ return u.ders === ders && (!u.sinif || String(u.sinif) === String(sinif)); })
      .forEach(function(u){
        var opt = document.createElement('option');
        opt.value = u.uniteAdi;
        opt.textContent = u.uniteNo + '. ' + u.uniteAdi;
        if (u.uniteAdi === secilenUnite) opt.selected = true;
        uniteSelect.appendChild(opt);
      });
    uniteDegisti(hedefKonu || '');
  }

  function uniteDegisti(hedefKonu) {
    var sinif = document.getElementById('se_sinif').value;
    var ders  = document.getElementById('se_ders').value;
    var unite = document.getElementById('se_unite').value;
    var konuSelect = document.getElementById('se_konu');
    var secilenKonu = (hedefKonu !== undefined) ? hedefKonu : konuSelect.value;
    konuSelect.innerHTML = '<option value="">-- Konu Seçin (Opsiyonel) --</option>';
    var seciliUnite = _tumUniteler.find(function(u){
      return u.ders === ders && u.uniteAdi === unite && (!u.sinif || String(u.sinif) === String(sinif));
    });
    if (seciliUnite) {
      seciliUnite.konular.forEach(function(k){
        var opt = document.createElement('option');
        opt.value = k; opt.textContent = k;
        if (k === secilenKonu) opt.selected = true;
        konuSelect.appendChild(opt);
      });
    }
  }

  function ekle(alanId, html, imlecGeri) {
    var ta = document.getElementById(alanId);
    var bas = ta.selectionStart, son = ta.selectionEnd;
    var secili = ta.value.substring(bas, son);
    var eklenen;
    if (secili && imlecGeri > 0) {
      eklenen = html.slice(0, html.length - imlecGeri) + secili + html.slice(html.length - imlecGeri);
    } else {
      eklenen = html;
    }
    ta.value = ta.value.substring(0, bas) + eklenen + ta.value.substring(son);
    ta.focus();
    ta.selectionStart = ta.selectionEnd = bas + eklenen.length - (secili ? 0 : imlecGeri);
  }
  function onizlemeGoster() {
    var metin = document.getElementById('soruMetni').value;
    var div = document.getElementById('onizleme');
    div.innerHTML = metin;
    div.style.display = div.style.display === 'none' ? 'block' : 'none';
  }
  window.addEventListener('DOMContentLoaded', function(){
    sinifDegisti(_editUnite, _editKonu);
  });

  function tabloSikOlusturucu() {
    tabloGuncelle();
    document.getElementById('tabloModal').style.display = 'flex';
  }

  function tabloGuncelle() {
    var sutun = parseInt(document.getElementById('tablo_sutunSayisi').value);
    var romenler = ['I.', 'II.', 'III.', 'IV.', 'V.', 'VI.'];
    var harfler = ['A', 'B', 'C', 'D'];

    // Sütun başlıkları
    var baslikHTML = '<label class="form-label">Sütun başlıkları</label><div style="display:flex; gap:6px; flex-wrap:wrap; margin-top:6px;">';
    for (var s = 0; s < sutun; s++) {
      var mevcutVal = document.getElementById('tablo_baslik_' + s) ? document.getElementById('tablo_baslik_' + s).value : romenler[s] + ' çuval';
      baslikHTML += '<input id="tablo_baslik_' + s + '" value="' + mevcutVal + '" class="input-sm" style="width:100px;" placeholder="Başlık ' + (s+1) + '">';
    }
    baslikHTML += '</div>';
    document.getElementById('tablo_sutunBasliklari').innerHTML = baslikHTML;

    // Şık değerleri — her şık için sütun sayısı kadar input
    var sikHTML = '<label class="form-label" style="margin-top:12px; display:block;">Şık değerleri</label>';
    for (var i = 0; i < 4; i++) {
      sikHTML += '<div style="display:flex; align-items:center; gap:6px; margin-top:8px;"><b style="min-width:24px;">' + harfler[i] + ')</b>';
      for (var s2 = 0; s2 < sutun; s2++) {
        var mevcut = document.getElementById('tablo_val_' + i + '_' + s2) ? document.getElementById('tablo_val_' + i + '_' + s2).value : '';
        sikHTML += '<input id="tablo_val_' + i + '_' + s2 + '" value="' + mevcut + '" placeholder="' + romenler[s2] + '" class="input-sm" style="width:70px; text-align:center;">';
      }
      sikHTML += '</div>';
    }
    document.getElementById('tablo_siklar').innerHTML = sikHTML;
  }

  function tabloHtmlUret() {
    var sutun = parseInt(document.getElementById('tablo_sutunSayisi').value);
    var harfler = ['A', 'B', 'C', 'D'];
    var basliklar = [];
    for (var s = 0; s < sutun; s++) {
      basliklar.push(document.getElementById('tablo_baslik_' + s).value || ('Col ' + (s+1)));
    }

    // Sabit genişlikler — başlık ve değer hücreleri aynı genişlikte olsun ki hizalansın
    var harfGenislik = '48px';
    var sutunGenislik = '90px';

    // Başlıkları gizli input'a JSON olarak kaydet — öncül 1'e dokunma
    document.getElementById('tabloBaslikGizli').value = JSON.stringify(basliklar);

    // Her şık sadece kendi değer satırını içersin
    for (var i = 0; i < 4; i++) {
      var degerSatir = '<table style="border-collapse:collapse; font-size:13px; table-layout:fixed;"><tr><td style="padding:4px 0; width:' + harfGenislik + '; font-weight:500;">' + harfler[i] + ')</td>';
      for (var s3 = 0; s3 < sutun; s3++) {
        var val = document.getElementById('tablo_val_' + i + '_' + s3).value || '-';
        degerSatir += '<td style="padding:4px 0; width:' + sutunGenislik + '; text-align:center;">' + val + '</td>';
      }
      degerSatir += '</tr></table>';
      document.getElementById('sikMetin' + i).value = degerSatir;
    }
    document.getElementById('tabloModal').style.display = 'none';
  }
  </script>

<% } else if (mod === 'kullanicilar') { %>
  <div class="card">
    <h3>Kullanıcı Listesi (Toplam: <%= filtreliKullanicilar.length %>)</h3>
    <form method="GET" action="/admin" style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap;">
      <input type="hidden" name="mod" value="kullanicilar">
      <select name="il" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm İller</option>
        <% iller.forEach(function(il) { %><option value="<%= il %>" <%= filIl===il?'selected':'' %>><%= il %></option><% }); %>
      </select>
      <select name="ilce" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm İlçeler</option>
        <% ilceler.forEach(function(ilce) { %><option value="<%= ilce %>" <%= filIlce===ilce?'selected':'' %>><%= ilce %></option><% }); %>
      </select>
      <select name="okul" onchange="this.form.submit()" class="input-sm">
        <option value="">Tüm Okullar</option>
        <% okullar.forEach(function(okul) { %><option value="<%= okul %>" <%= filOkul===okul?'selected':'' %>><%= okul %></option><% }); %>
      </select>
    </form>
    <table class="tablo">
      <thead><tr><th>Kullanıcı Adı</th><th>Sınıf</th><th>İl</th><th>İlçe</th><th>Okul</th><th>Çözülen</th><th>Puan</th><th>İşlem</th></tr></thead>
      <tbody>
        <% filtreliKullanicilar.sort(function(a,b){ return b.puan-a.puan; }).forEach(function(k) { %>
          <tr>
            <td>
              <%= k.kullaniciAdi %>
              <% if (k.rol === 'moderator') { %><span style="background:#e8f0fe; color:#1a73e8; font-size:10px; font-weight:600; padding:2px 7px; border-radius:10px; margin-left:4px;">MOD</span><% } %>
            </td>
            <td style="text-align:center;"><%= k.sinif %></td>
            <td><%= k.il||'-' %></td>
            <td><%= k.ilce||'-' %></td>
            <td><%= k.okul||'-' %></td>
            <td style="text-align:center;"><%= k.soruIndex %></td>
            <td style="text-align:center; font-weight:bold; color:#1a73e8;"><%= k.puan %></td>
            <td style="text-align:center; display:flex; gap:4px; flex-wrap:wrap; justify-content:center;">
              <a href="/kullanici-detay?kullaniciAdi=<%= encodeURIComponent(k.kullaniciAdi) %>" class="admin-btn admin-btn-onizle" style="font-size:10px; padding:3px 8px;">📊 Detay</a>
              <form action="/kullanici-rol" method="POST" style="display:inline;">
                <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
                <input type="hidden" name="il" value="<%= filIl %>">
                <input type="hidden" name="ilce" value="<%= filIlce %>">
                <input type="hidden" name="okul" value="<%= filOkul %>">
                <button class="admin-btn <%= k.rol === 'moderator' ? 'admin-btn-sil' : 'admin-btn-duzenle' %>" style="font-size:10px; padding:3px 8px;">
                  <%= k.rol === 'moderator' ? '🔓 Mod Al' : '🔑 Mod Ver' %>
                </button>
              </form>
              <form action="/kullanici-sil" method="POST" style="display:inline;">
                <input type="hidden" name="kullaniciAdi" value="<%= k.kullaniciAdi %>">
                <input type="hidden" name="il" value="<%= filIl %>">
                <input type="hidden" name="ilce" value="<%= filIlce %>">
                <input type="hidden" name="okul" value="<%= filOkul %>">
                <button onclick="return confirm('<%= k.kullaniciAdi %> silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

<% } else if (mod === 'uniteler') { %>

<!-- ── Ünite / Konu Yönetimi ── -->
<div class="card">
  <h3>📚 Ünite ve Konu Yönetimi</h3>
  <p style="color:#666; font-size:13px; margin-bottom:16px;">
    Excel şablonunu indirin, doldurun ve yükleyin. Satır ve sütun yapısına göre otomatik okunur.
  </p>

  <!-- Şablon İndir -->
  <a href="/unite-sablon-indir" class="btn" style="background:#1a73e8; color:white; margin-bottom:16px; display:inline-block;">
    📥 Excel Şablonunu İndir
  </a>

  <!-- Yükleme Alanı -->
  <div style="border:2px dashed #1a73e8; border-radius:10px; padding:30px; text-align:center; background:#f8f9ff; cursor:pointer; margin-bottom:16px;" id="excelDropZone">
    <div style="font-size:32px; margin-bottom:6px;">📊</div>
    <div style="color:#1a73e8; font-weight:bold; margin-bottom:4px;">Excel dosyasını buraya sürükleyin veya tıklayın</div>
    <div style="color:#888; font-size:13px;">.xlsx veya .xls — Maks 5 MB</div>
    <input type="file" id="excelInput" accept=".xlsx,.xls" style="display:none;">
  </div>

  <div id="excelSecilenDosya" style="display:none; padding:10px 14px; background:#e8f5e9; border-radius:8px; margin-bottom:12px;">
    ✅ <span id="excelDosyaAd" style="font-weight:500;"></span>
  </div>

  <div style="display:flex; gap:10px; align-items:center; margin-bottom:12px; flex-wrap:wrap;">
    <label style="font-size:13px; color:#666;">Kayıt modu:</label>
    <label style="font-size:13px; cursor:pointer;">
      <input type="radio" name="kayitMod" value="ekle" checked> Mevcut ünitelere ekle
    </label>
    <label style="font-size:13px; cursor:pointer;">
      <input type="radio" name="kayitMod" value="sifirla"> Tümünü sil, yeniden yükle
    </label>
  </div>

  <button id="excelAnalizBtn" onclick="excelAnalizBaslat()" class="btn btn-success" style="display:none;">📊 Analiz Et ve Önizle</button>
  <div id="excelHata" style="display:none; padding:10px; background:#ffebee; border:1px solid #ef9a9a; border-radius:8px; color:#c62828; margin-top:10px;"></div>
</div>

<!-- Önizleme -->
<div id="excelOnizleme" style="display:none;">
  <div class="card" style="background:#e8f5e9; border-color:#a5d6a7;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px;">
      <div>
        <b style="color:#2e7d32;">✅ <span id="excelToplamUnite"></span> ünite, <span id="excelToplamKonu"></span> konu bulundu</b>
        <p style="color:#555; font-size:13px; margin-top:4px;">Kontrol edin, ardından kaydedin.</p>
      </div>
      <button onclick="excelKaydet()" class="btn btn-success">💾 Veritabanına Kaydet</button>
    </div>
  </div>
  <div id="excelOnizlemeListesi"></div>
</div>

<!-- Mevcut Üniteler Listesi -->
<div class="card" style="margin-top:16px;">
  <h3>Kayıtlı Üniteler (<%= tumUniteler.length %>)</h3>
  <% if (tumUniteler.length === 0) { %>
    <p style="color:#888; font-size:13px;">Henüz ünite eklenmemiş.</p>
  <% } else { %>
    <table class="tablo">
      <thead><tr><th>Sınıf</th><th>Ünite No</th><th>Ders</th><th>Ünite Adı</th><th>Konu Sayısı</th><th>Konular</th><th>İşlem</th></tr></thead>
      <tbody>
        <% tumUniteler.forEach(function(u) { %>
          <tr>
            <td style="text-align:center;"><%= u.sinif||"-" %></td>
            <td style="text-align:center;"><%= u.uniteNo %></td>
            <td><%= u.ders %></td>
            <td><b><%= u.uniteAdi %></b></td>
            <td style="text-align:center;"><%= u.konular.length %></td>
            <td style="font-size:12px; color:#666;"><%= u.konular.join(', ') %></td>
            <td style="text-align:center;">
              <form action="/unite-sil" method="POST" style="display:inline;">
                <input type="hidden" name="id" value="<%= u._id %>">
                <button onclick="return confirm('Bu ünite silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<script>
var excelOnizlemeVeri = [];

// Drag & Drop
(function() {
  var zone  = document.getElementById('excelDropZone');
  var input = document.getElementById('excelInput');
  zone.addEventListener('click', function() { input.click(); });
  zone.addEventListener('dragover', function(e) { e.preventDefault(); zone.style.background='#e3f2fd'; });
  zone.addEventListener('dragleave', function() { zone.style.background='#f8f9ff'; });
  zone.addEventListener('drop', function(e) {
    e.preventDefault(); zone.style.background='#f8f9ff';
    if (e.dataTransfer.files[0]) excelDosyaSec(e.dataTransfer.files[0]);
  });
  input.addEventListener('change', function() { if (input.files[0]) excelDosyaSec(input.files[0]); });
})();

function excelDosyaSec(f) {
  document.getElementById('excelDosyaAd').textContent = f.name;
  document.getElementById('excelSecilenDosya').style.display = 'block';
  document.getElementById('excelAnalizBtn').style.display = 'inline-block';
  document.getElementById('excelHata').style.display = 'none';
  window._seciliExcel = f;
}

function excelAnalizBaslat() {
  if (!window._seciliExcel) return;
  var fd = new FormData();
  fd.append('excelDosyasi', window._seciliExcel);
  fetch('/unite-excel-yukle', {
    method: 'POST',
    headers: { 'Authorization': 'Basic <%- adminToken %>' },
    body: fd
  })
  .then(function(r) { return r.json(); })
  .then(function(v) {
    if (!v.ok) { gosterExcelHata(v.hata); return; }
    excelOnizlemeVeri = v.onizleme;
    document.getElementById('excelToplamUnite').textContent = v.toplamUnite;
    document.getElementById('excelToplamKonu').textContent = v.toplamKonu;
    var liste = document.getElementById('excelOnizlemeListesi');
    liste.innerHTML = '';
    v.onizleme.forEach(function(u) {
      var div = document.createElement('div');
      div.className = 'card';
      div.style.cssText = 'margin-bottom:8px; border-left:4px solid #1a73e8;';
      div.innerHTML = '<b style="color:#1a73e8;">' + u.uniteNo + '. ' + u.uniteAdi + '</b>' +
        '<span style="color:#888; font-size:12px; margin-left:8px;">(' + u.ders + ')</span>' +
        '<div style="margin-top:6px; font-size:13px; color:#444;">' +
        u.konular.map(function(k,i){ return '<span style="background:#f0f2f5; border-radius:4px; padding:2px 8px; margin:2px; display:inline-block;">' + (i+1) + '. ' + k + '</span>'; }).join('') +
        '</div>';
      liste.appendChild(div);
    });
    document.getElementById('excelOnizleme').style.display = 'block';
  })
  ['catch'](function(e) { gosterExcelHata(e.message); });
}

function excelKaydet() {
  if (!excelOnizlemeVeri.length) return;
  var mod = document.querySelector('input[name="kayitMod"]:checked').value;
  var onay = mod === 'sifirla'
    ? 'Tüm mevcut üniteler silinip yenileri yüklenecek. Emin misiniz?'
    : excelOnizlemeVeri.length + ' ünite eklenecek. Onaylıyor musunuz?';
  if (!confirm(onay)) return;
  fetch('/unite-kaydet', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic <%- adminToken %>' },
    body: JSON.stringify({ uniteler: excelOnizlemeVeri, mod: mod })
  })
  .then(function(r) { return r.json(); })
  .then(function(v) {
    if (!v.ok) { gosterExcelHata(v.hata); return; }
    alert(v.kaydedilen + ' ünite başarıyla kaydedildi!');
    window.location.reload();
  })
  ['catch'](function(e) { gosterExcelHata(e.message); });
}

function gosterExcelHata(msg) {
  var k = document.getElementById('excelHata');
  k.textContent = '⚠️ ' + msg;
  k.style.display = 'block';
}
</script>

<% } else if (mod === 'okullar') { %>

  <!-- Excel'den Toplu Okul Yükleme -->
  <div class="card" style="margin-bottom:16px;">
    <h3>📊 Excel'den Toplu Okul Yükleme</h3>
    <p style="color:#666; font-size:13px; margin-bottom:12px;">
      Excel formatı: <b>A sütunu</b> = İl, <b>B sütunu</b> = İlçe, <b>C sütunu</b> = Okul Adı (1. satır başlık)
    </p>
    <div id="okulDropZone" style="border:2px dashed #1a73e8; border-radius:10px; padding:24px; text-align:center; background:#f8f9ff; cursor:pointer; margin-bottom:10px;">
      <div style="font-size:28px; margin-bottom:4px;">📊</div>
      <div style="color:#1a73e8; font-weight:bold; margin-bottom:2px;">Excel dosyasını buraya sürükleyin veya tıklayın</div>
      <div style="color:#888; font-size:12px;">.xlsx veya .xls — Maks 5 MB</div>
      <input type="file" id="okulExcelInput" accept=".xlsx,.xls" style="display:none;">
    </div>
    <div id="okulSecilenDosya" style="display:none; padding:8px 12px; background:#e8f5e9; border-radius:6px; margin-bottom:10px;">
      ✅ <span id="okulDosyaAd" style="font-weight:500;"></span>
    </div>
    <div style="display:flex; gap:12px; align-items:center; margin-bottom:10px; flex-wrap:wrap;">
      <label style="font-size:13px; color:#666;">Kayıt modu:</label>
      <label style="font-size:13px; cursor:pointer;"><input type="radio" name="okulMod" value="ekle" checked> Mevcut okullara ekle (tekrar olanları atla)</label>
      <label style="font-size:13px; cursor:pointer;"><input type="radio" name="okulMod" value="sifirla"> Tümünü sil, yeniden yükle</label>
    </div>
    <button id="okulAnalizBtn" onclick="okulExcelAnalizBaslat()" class="btn btn-success" style="display:none;">📊 Analiz Et ve Önizle</button>
    <div id="okulHata" style="display:none; padding:10px; background:#ffebee; border:1px solid #ef9a9a; border-radius:6px; color:#c62828; margin-top:8px;"></div>
  </div>

  <!-- Önizleme -->
  <div id="okulOnizleme" style="display:none;" class="card" style="margin-bottom:16px;">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; background:#e8f5e9; padding:12px; border-radius:8px; margin-bottom:10px;">
      <b style="color:#2e7d32;">✅ <span id="okulToplamSayi"></span> okul bulundu</b>
      <button onclick="okulExcelKaydet()" class="btn btn-success">💾 Kaydet</button>
    </div>
    <div id="okulOnizlemeTablosu" style="max-height:300px; overflow-y:auto;">
      <table class="tablo">
        <thead><tr><th>İl</th><th>İlçe</th><th>Okul Adı</th></tr></thead>
        <tbody id="okulOnizlemeSatirlar"></tbody>
      </table>
    </div>
  </div>

  <script>
  var _okulOnizlemeVeri = [];
  (function(){
    var zone = document.getElementById('okulDropZone');
    var input = document.getElementById('okulExcelInput');
    zone.addEventListener('click', function(){ input.click(); });
    zone.addEventListener('dragover', function(e){ e.preventDefault(); zone.style.background='#e3f2fd'; });
    zone.addEventListener('dragleave', function(){ zone.style.background='#f8f9ff'; });
    zone.addEventListener('drop', function(e){
      e.preventDefault(); zone.style.background='#f8f9ff';
      if(e.dataTransfer.files[0]) okulDosyaSec(e.dataTransfer.files[0]);
    });
    input.addEventListener('change', function(){ if(input.files[0]) okulDosyaSec(input.files[0]); });
  })();

  function okulDosyaSec(f) {
    document.getElementById('okulDosyaAd').textContent = f.name;
    document.getElementById('okulSecilenDosya').style.display = 'block';
    document.getElementById('okulAnalizBtn').style.display = 'inline-block';
    document.getElementById('okulHata').style.display = 'none';
    window._seciliOkulExcel = f;
  }

  function okulExcelAnalizBaslat() {
    if (!window._seciliOkulExcel) return;
    var fd = new FormData();
    fd.append('okulExcelDosyasi', window._seciliOkulExcel);
    fetch('/okul-excel-yukle', {
      method: 'POST',
      headers: { 'Authorization': 'Basic <%- adminToken %>' },
      body: fd
    })
    .then(function(r){ return r.json(); })
    .then(function(v){
      if (!v.ok) { document.getElementById('okulHata').textContent = '⚠️ ' + v.hata; document.getElementById('okulHata').style.display='block'; return; }
      _okulOnizlemeVeri = v.onizleme;
      document.getElementById('okulToplamSayi').textContent = v.toplam;
      var tbody = document.getElementById('okulOnizlemeSatirlar');
      // Sadece ilk 100 satırı göster — performans için
      var rows = '';
      var gosterilen = Math.min(v.onizleme.length, 100);
      for (var i = 0; i < gosterilen; i++) {
        var o = v.onizleme[i];
        rows += '<tr><td>'+o.il+'</td><td>'+o.ilce+'</td><td>'+o.ad+'</td></tr>';
      }
      if (v.onizleme.length > 100) {
        rows += '<tr><td colspan="3" style="text-align:center; color:#888; font-style:italic;">... ve ' + (v.onizleme.length - 100) + ' okul daha</td></tr>';
      }
      tbody.innerHTML = rows;
      document.getElementById('okulOnizleme').style.display = 'block';
    })
    ['catch'](function(e){ document.getElementById('okulHata').textContent = '⚠️ ' + e.message; document.getElementById('okulHata').style.display='block'; });
  }

  function okulExcelKaydet() {
    if (!_okulOnizlemeVeri.length) return;
    var mod = document.querySelector('input[name="okulMod"]:checked').value;
    var onay = mod === 'sifirla' ? 'Tüm okullar silinip yenileri yüklenecek. Emin misiniz?' : _okulOnizlemeVeri.length + ' okul eklenecek. Onaylıyor musunuz?';
    if (!confirm(onay)) return;
    fetch('/okul-excel-kaydet', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Basic <%- adminToken %>' },
      body: JSON.stringify({ okullar: _okulOnizlemeVeri, mod: mod })
    })
    .then(function(r){ return r.json(); })
    .then(function(v){
      if (!v.ok) { alert('Hata: ' + v.hata); return; }
      alert(v.eklenen + ' okul eklendi, ' + v.atlanan + ' tekrar atlandı.');
      window.location.reload();
    })
    ['catch'](function(e){ alert('Hata: ' + e.message); });
  }
  </script>

  <div class="card">
    <h3>Okul Yönetimi</h3>

    <!-- Yeni Okul Ekleme Formu -->
    <form action="/okul-ekle" method="POST" style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap; align-items:flex-end;">
      <div><label class="form-label">İl</label><br><select name="il" id="adminIlSelect" onchange="adminIlDegisti()" required class="input-sm"><option value="">İl Seçiniz</option></select></div>
      <div><label class="form-label">İlçe</label><br><select name="ilce" id="adminIlceSelect" required class="input-sm"><option value="">İlçe Seçiniz</option></select></div>
      <div><label class="form-label">Okul Adı</label><br><input name="ad" placeholder="Okul adını giriniz" required style="padding:8px; border:1px solid #ddd; border-radius:6px; min-width:250px;"></div>
      <button type="submit" class="btn btn-success">EKLE</button>
    </form>

    <!-- Filtre -->
    <div style="display:flex; gap:10px; margin-bottom:15px; flex-wrap:wrap;">
      <select id="filIlSelect" onchange="filtrele()" class="input-sm"><option value="">Tüm İller</option></select>
      <select id="filIlceSelect" onchange="filtrele()" class="input-sm"><option value="">Tüm İlçeler</option></select>
    </div>

    <!-- Düzenleme Formu (gizli) -->
    <div id="duzenleForm" style="display:none; background:#fffbe6; border:1px solid #f0c040; border-radius:8px; padding:15px; margin-bottom:15px;">
      <b>Okul Düzenle</b>
      <form action="/okul-guncelle" method="POST" style="display:flex; gap:10px; margin-top:10px; flex-wrap:wrap; align-items:flex-end;">
        <input type="hidden" name="id" id="duzenleId">
        <div><label class="form-label">İl</label><br><input name="il" id="duzenleIl" class="input-sm" required></div>
        <div><label class="form-label">İlçe</label><br><input name="ilce" id="duzenleIlce" class="input-sm" required></div>
        <div><label class="form-label">Okul Adı</label><br><input name="ad" id="duzenleAd" style="padding:8px; border:1px solid #ddd; border-radius:6px; min-width:250px;" required></div>
        <button type="submit" class="btn btn-success">KAYDET</button>
        <button type="button" onclick="document.getElementById('duzenleForm').style.display='none'" class="btn" style="background:#888; color:white;">İPTAL</button>
      </form>
    </div>

    <table class="tablo" id="okulTablosu">
      <thead><tr><th>İl</th><th>İlçe</th><th>Okul Adı</th><th>İşlem</th></tr></thead>
      <tbody>
        <% tumOkullar.sort(function(a,b){ var ilc = a.ilce.localeCompare(b.ilce,'tr'); return ilc !== 0 ? ilc : a.ad.localeCompare(b.ad,'tr'); }).forEach(function(o) { %>
          <tr data-il="<%= o.il %>" data-ilce="<%= o.ilce %>">
            <td><%= o.il %></td>
            <td><%= o.ilce %></td>
            <td><%= o.ad %></td>
            <td style="text-align:center; white-space:nowrap;">
              <button onclick="duzenle('<%= o._id %>','<%= o.il %>','<%= o.ilce %>','<%= o.ad %>')" class="btn-duzenle">DÜZENLE</button>
              <form action="/okul-sil" method="POST" style="display:inline;">
                <input type="hidden" name="id" value="<%= o._id %>">
                <button onclick="return confirm('<%= o.ad %> silinsin mi?')" class="btn-sil">SİL</button>
              </form>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
  <script>
  var adminIlIdMap = {};
  fetch('https://api.turkiyeapi.dev/v1/provinces')
    .then(function(r){ return r.json(); })
    .then(function(data) {
      var sel = document.getElementById('adminIlSelect');
      var filSel = document.getElementById('filIlSelect');
      (data.data||[]).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(il) {
        adminIlIdMap[il.name] = il.id;
        sel.innerHTML += '<option value="'+il.name+'">'+il.name+'</option>';
        filSel.innerHTML += '<option value="'+il.name+'">'+il.name+'</option>';
      });
    })
    .then(function(){})
    ['catch'](function(e){ console.log('İller yüklenemedi'); });

  function adminIlDegisti() {
    var ilAdi = document.getElementById('adminIlSelect').value;
    var ilceSelect = document.getElementById('adminIlceSelect');
    ilceSelect.innerHTML = '<option value="">İlçe Yükleniyor...</option>';
    var ilId = adminIlIdMap[ilAdi];
    if (!ilId) return;
    fetch('https://api.turkiyeapi.dev/v1/provinces/'+ilId)
      .then(function(r){ return r.json(); })
      .then(function(data) {
        ilceSelect.innerHTML = '<option value="">İlçe Seçiniz</option>';
        ((data.data&&data.data.districts)||[]).sort(function(a,b){ return a.name.localeCompare(b.name,'tr'); }).forEach(function(ilce) {
          ilceSelect.innerHTML += '<option value="'+ilce.name+'">'+ilce.name+'</option>';
        });
      })
      ['catch'](function(e){ ilceSelect.innerHTML='<option>İlçeler yüklenemedi</option>'; });
  }

  function filtrele() {
    var secIl = document.getElementById('filIlSelect').value;
    var secIlce = document.getElementById('filIlceSelect').value;
    var satırlar = document.querySelectorAll('#okulTablosu tbody tr');

    // İlçe filtresini il'e göre güncelle
    var ilceSet = {};
    satırlar.forEach(function(tr) {
      if (!secIl || tr.getAttribute('data-il') === secIl) {
        ilceSet[tr.getAttribute('data-ilce')] = true;
      }
    });
    var filIlceSel = document.getElementById('filIlceSelect');
    var mevcutIlce = filIlceSel.value;
    filIlceSel.innerHTML = '<option value="">Tüm İlçeler</option>';
    Object.keys(ilceSet).sort(function(a,b){ return a.localeCompare(b,'tr'); }).forEach(function(ilce) {
      var opt = document.createElement('option');
      opt.value = ilce; opt.textContent = ilce;
      if (ilce === mevcutIlce) opt.selected = true;
      filIlceSel.appendChild(opt);
    });
    secIlce = filIlceSel.value;

    satırlar.forEach(function(tr) {
      var ilEsles = !secIl || tr.getAttribute('data-il') === secIl;
      var ilceEsles = !secIlce || tr.getAttribute('data-ilce') === secIlce;
      tr.style.display = (ilEsles && ilceEsles) ? '' : 'none';
    });
  }

  function duzenle(id, il, ilce, ad) {
    document.getElementById('duzenleId').value = id;
    document.getElementById('duzenleIl').value = il;
    document.getElementById('duzenleIlce').value = ilce;
    document.getElementById('duzenleAd').value = ad;
    document.getElementById('duzenleForm').style.display = 'block';
    document.getElementById('duzenleForm').scrollIntoView({ behavior: 'smooth' });
  }
  </script>

